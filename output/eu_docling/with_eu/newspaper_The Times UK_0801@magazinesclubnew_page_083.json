        "id": "docling_newspaper_The Times UK_0801@magazinesclubnew_page_083_53",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Visits to a selection of villages on Lake Garda, the Dolomites and a tour of a local vineyard with a tasting",

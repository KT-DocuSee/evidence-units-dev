        "id": "docling_newspaper_The Times UK_0801@magazinesclubnew_page_083_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sample the wines of Mount Etna and lunch amidst the surroundings of a historic winery",
        "bbox": [
          0.3512014844395817,
          0.7529069768310294,
          0.47504620915253143,

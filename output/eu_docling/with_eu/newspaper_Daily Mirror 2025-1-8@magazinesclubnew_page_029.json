          0.9574861409454323,
          0.3313953515435608
        ],
        "order": 5
      },
      {
        "id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_029_3",
        "observed_type": "caption",
        "canon_role": "support_paragraph",
        "text": "FAMILY Harry, Holly, Emma and Steve",
        "bbox": [
          0.05175601243244797,
          0.17286706354040257,
          0.21996303058973304,
          0.181795634968974
        ],
        "order": 7
      },
      {
        "id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_029_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A t the age of four, while her little pals were running about, laughing and giggling, Emma Griffin remembers \"playing with dead people\".",
        "bbox": [
          0.04805915048691148,
          0.22093023371843448,
          0.19963031298025008,
          0.2892441857867058
        ],
        "order": 10
      },
      {
        "id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_029_7",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Another childhood memory is of Sunday afternoons, when other mums and dads were out for a stroll after lunch and her parents, Pat and Pip, would be holding a seance to commune with the other side.",
        "bbox": [
          0.04805914833352479,
          0.28918650793774625,
          0.16451016386610562,
          0.38665674597462807
        ],
        "order": 11
      },
      {
        "id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_029_25",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The modern Molly Weasley who is using chat brooms to work magic",
        "bbox": [
          0.7519175522254175,
          0.3385416663191054,
          0.9541822645861726,
          0.5316343515592934
        ],
        "order": 12
      },
      {
        "id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_029_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Emma, 48, now a fulltime witch, says: \"It seemed normal for me to see - and play with dead people from the age of just four.",
        "bbox": [
          0.04805915029328594,
          0.38808139556219473,
          0.1700554534035717,
          0.44622092987385187
        ],
        "order": 13
      }
    ]
  },

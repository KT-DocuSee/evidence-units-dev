      {
        "id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_029_21",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Soon after, moving from London to Cornwall to be closer to nature, Emma began giving",
        "bbox": [
          0.2846428115395406,
          0.8807043649220143,
          0.40665434353296165,

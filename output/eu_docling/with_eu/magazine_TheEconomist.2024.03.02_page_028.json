      {
        "id": "docling_magazine_TheEconomist.2024.03.02_page_028_40",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The waning popularity of the war on drugs is one part of the problem. That us allies question its commitment to the drug war at home is another. They cite the insatiable market for illegal drugs and the sale of guns to organised crime groups across Latin America. This has encouraged a softer stance on drugs across the region.",
        "bbox": [
          0.6583969444277805,
          0.2557043652695193,
          0.9408396913151019,
          0.35912698392218445
        ],
        "order": 21
      },
      {
        "id": "docling_magazine_TheEconomist.2024.03.02_page_028_30",
        "observed_type": "text",
        "canon_role": "support_paragraph",

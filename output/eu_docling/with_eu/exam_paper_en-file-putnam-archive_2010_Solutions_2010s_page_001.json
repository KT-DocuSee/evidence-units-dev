      {
        "id": "docling_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Since N> 1010\" > 10\" + 1 ≥ 102 + 1, it follows that N is composite.",

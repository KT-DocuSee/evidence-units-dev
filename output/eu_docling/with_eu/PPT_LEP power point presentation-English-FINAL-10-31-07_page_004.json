        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "August 11, 2000: President Bill Clinton issued the Executive Order 13166.",
        "bbox": [
          0.0791666588888891,
          0.29431217014550265,
          0.9124999922222224,
          0.38593262569539477
        ],

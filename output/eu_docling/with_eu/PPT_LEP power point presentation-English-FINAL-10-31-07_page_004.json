      },
      {
        "id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_3",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Designed to improve access to federally conducted and federally assisted programs/activities for LEP persons",
        "bbox": [
          0.07916666908931695,
          0.3999999998795897,
          0.8624999782023501,
          0.49612403022559254
        ],
        "order": 4
      },
      {
        "id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_4",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Federal agencies were asked to develop and implement a system to provide LEP persons access to services.",
        "bbox": [
          0.07830870842457195,
          0.5095410929300931,
          0.8881979417261283,
          0.6028439154601944
        ],
        "order": 5
      },
      {
        "id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_5",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Each federal agency was asked to prepare a plan to improve access to LEP persons, and submit plans to the U.S. Department of Justice.",
        "bbox": [
          0.07994186267772976,
          0.6162790698067073,
          0.9215116118135496,
          0.7559523803484247
        ],
        "order": 6
      },

      {
        "id": "docling_magazine_TheEconomist.2024.03.09_page_029_40",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "2021, 1=best",
        "bbox": [
          0.45506692283081723,
          0.29505813987905516,

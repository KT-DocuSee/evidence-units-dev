          0.7645348840651016,
          0.46845124281578243,
          0.7733134920996292
        ],
        "order": 64
      },
      {
        "id": "docling_magazine_TheEconomist.2024.03.09_page_029_56",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1,400",
        "bbox": [
          0.3690248568977974,

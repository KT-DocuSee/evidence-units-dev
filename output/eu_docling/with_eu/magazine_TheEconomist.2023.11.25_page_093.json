    "member_count": 1,
    "elements": [
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Cities across America, Europe and Asia have successfully built infrastructural, environmental, social and economic resilience.",
        "bbox": [

  {
    "eu_id": "EU-0011",
    "kind": "text_cluster_panel",
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "primary_id": "docling_magazine_TheEconomist.2023.11.25_page_093_12",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Resilient cities continue to adapt and grow amid uncertainty and change. They identify risks and create systems that enable businesses and residents to recover and thrive after unexpected events. The Resilient Cities Index 2023, devised by Economist Impact, examines the preparedness of 25 cities in four vital areas- critical infrastructure, environment, socioinstitutional and economic.",
        "bbox": [
          0.055308159410373,
          0.6366279068891345,
          0.6316793751709014,
          0.7021329363505858
        ],
        "order": 23
      }
    ]
  },
  {
    "eu_id": "EU-0012",
    "kind": "text_cluster_panel",
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "primary_id": "docling_magazine_TheEconomist.2023.11.25_page_093_23",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_23",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "\"A resilience strategy is not something developed at a desk by a city official. Cities need to bring a variety of stakeholders together, including community representation, the poor and the vulnerable.\"",
        "bbox": [
          0.6507633561985566,
          0.6366279074491777,
          0.9351145021814266,
          0.765988371695378
        ],
        "order": 24
      }
    ]
  },
  {
    "eu_id": "EU-0013",
    "kind": "text_cluster_panel",
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "primary_id": "docling_magazine_TheEconomist.2023.11.25_page_093_13",
    "source": "text_cluster",
    "member_count": 2,
    "elements": [
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The research highlights the following strategies to build resilience:",
        "bbox": [
          0.057251912974674406,
          0.7135416664985149,
          0.4694656525215087,
          0.7252906975502718
        ],
        "order": 25
      },
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_14",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Incentivise businesses and residents to guard against future risks by using financial rewards for hitting targets.",
        "bbox": [
          0.055343502126481835,
          0.7353670634657267,
          0.6068702245433657,
          0.7616567459897424
        ],
        "order": 26
      }
    ]
  },
  {
    "eu_id": "EU-0014",
    "kind": "section_text_panel",
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "primary_id": "docling_magazine_TheEconomist.2023.11.25_page_093_24",
    "source": "header_anchor",
    "member_count": 6,
    "elements": [
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_24",
        "observed_type": "section_header",
        "canon_role": "section_header",
        "text": "Katrin Bruebach",
        "bbox": [
          0.8511450373787045,
          0.7688492062128575,
          0.9446564870010665,
          0.77761627885641
        ],
        "order": 27
      },
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_15",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Plan a cohesive response to shocks by integrating vulnerable groups and offering comprehensive social safety-nets.",
        "bbox": [
          0.05534351742571936,
          0.7703373013557755,
          0.622137384434968,
          0.7951388889041135
        ],
        "order": 28
      },
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_25",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Global director of programmes and delivery Resilient Cities Network",
        "bbox": [
          0.7212029138909314,
          0.7793211581691555,
          0.9448480408504225,
          0.8023313490994703
        ],
        "order": 29
      },
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_16",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Drive innovative, scalable and cost-effective solutions through a dynamic business ecosystem.",
        "bbox": [
          0.05534350615835989,
          0.8052325583505594,
          0.616412203892531,
          0.8315482317147299
        ],
        "order": 30
      },
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_17",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Promote community stewardship through education and collaboration.",
        "bbox": [
          0.05534351708654004,
          0.8415178570295113,
          0.5305343573886505,
          0.8531976743162603
        ],
        "order": 31
      },
      {
        "id": "docling_magazine_TheEconomist.2023.11.25_page_093_18",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "What is stopping cities from building holistic resilience? Read the report to find out more about the risks, rankings and best practices at https://impact.economist.com/projects/ resilient-cities/",
        "bbox": [
          0.17366412057809838,
          0.8968023255809949,
          0.6202290046874377,
          0.9505813952636607
        ],
        "order": 34
      }
    ]
  },

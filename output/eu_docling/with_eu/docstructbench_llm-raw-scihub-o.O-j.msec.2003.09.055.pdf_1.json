        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "° Department of Chemistry, Korea Advanced Institute of Science and Technology, Taejon 305-701, South Korea",
        "bbox": [
          0.18992250448532447,
          0.3196924605379852,
          0.7965116192065355,

  {
    "eu_id": "EU-0008",
    "kind": "text_cluster_panel",
    "page": "magazine_TheEconomist.2024.02.24_page_008",
    "primary_id": "docling_magazine_TheEconomist.2024.02.24_page_008_3",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "docling_magazine_TheEconomist.2024.02.24_page_008_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Japan's Nikkei 225 stockmarket index hit a new high, surpassing the previous record set 34 years ago. The Nikkei is up by 18% since the start of this year, as foreign investors flock to Japanese stocks made cheaper by the weak yen.",
        "bbox": [
          0.05916030520526896,
          0.281976744348953,
          0.26526716975497294,
          0.38665674609775347
        ],
        "order": 11
      }
    ]
  },
  {

        "id": "docling_magazine_TheEconomist.2024.02.24_page_008_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Australia. Nickel prices have collapsed amid a global glut of the metal, caused by Indonesia pumping up production at its cheaper mines. Traders are also paring their bets on the price amid slowing growth in the demand for electric vehicles, which contain nickel in their batteries.",
        "bbox": [
          0.507633586152391,
          0.0828373013729435,
          0.7137404573026829,
          0.2136627905034863
        ],
        "order": 4
      }
    ]

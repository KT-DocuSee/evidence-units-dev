        "order": 1
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_3718_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "FLUENCY is when a child can see a word and instantly recognize it.",
        "bbox": [
          0.4736842223207695,
          0.1162790702274921,
          0.8646616435438922,
          0.1976744184310331
        ],
        "order": 3
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_3718_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A child may need to see a word twenty, thirty or forty times before it becomes \"automatic\" ·Ifa child has a learning disability, the number of exposures needed to automatically remember a word may go up to well over a hundred.",
        "bbox": [
          0.3061794224487564,
          0.23255813981324794,
          0.8890977311103,
          0.35029069750506614
        ],
        "order": 5
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_3718_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Tests have shown that children have about ten seconds of \"working memory\" - if a child can read a sentence in ten or less seconds, he/she can \"get\" (comprehend) the \"big idea\" of the sentence.",
        "bbox": [
          0.07120727814709814,
          0.374999999563666,
          0.6296992375012774,
          0.4898313493504765
        ],
        "order": 8
      }
    ]

      {
        "id": "docling_docstructbench_llm-raw-scihub-o.O-ijc.22999.pdf_3_69",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "In vitro characterization of a B16F 10 melanoma clone which produces PDGF-BB",
        "bbox": [
          0.09807692443428566,
          0.8168604652377929,
          0.4211538464930204,
          0.8401162791975586

  {
    "eu_id": "EU-0007",
    "kind": "text_cluster_panel",
    "page": "exam_paper_en-file-putnam-archive_2001_Solutions_2001s_page_001",
    "primary_id": "docling_exam_paper_en-file-putnam-archive_2001_Solutions_2001s_page_001_9",

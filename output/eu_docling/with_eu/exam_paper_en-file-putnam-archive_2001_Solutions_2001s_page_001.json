    "member_count": 1,
    "elements": [
      {
        "id": "docling_exam_paper_en-file-putnam-archive_2001_Solutions_2001s_page_001_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "First suppose this subset has a single element, say vm ‡ V2; this element must be a rational number. Then (Vm # V2) = 2 + m 2V 2m is an integer, so m is twice a perfect square, say m = 2n. But then Vm = V2 = (n ‡ 1) V2 is only rational if n = ‡1, i.e., if m = 2.",
        "bbox": [
          0.12781954970176249,
          0.6264534882675261,
          0.49060151109241035,
          0.7108134921078971
        ],
        "order": 16
      }
    ]
  },
  {
    "eu_id": "EU-0008",
    "kind": "text_cluster_panel",
    "page": "exam_paper_en-file-putnam-archive_2001_Solutions_2001s_page_001",
    "primary_id": "docling_exam_paper_en-file-putnam-archive_2001_Solutions_2001s_page_001_19",

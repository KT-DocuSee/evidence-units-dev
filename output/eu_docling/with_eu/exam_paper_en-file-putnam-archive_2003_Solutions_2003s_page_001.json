      {
        "id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_17",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "In terms of the function",
        "bbox": [
          0.5582706779317022,
          0.2805059524116231,
          0.7142857141265683,
          0.29216269844336923
        ],
        "order": 8

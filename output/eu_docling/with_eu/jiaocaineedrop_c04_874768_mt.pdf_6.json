      {
        "id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "When you encounter an ethical decision and must choose a course of action, ask yourself these important questions:",
        "bbox": [
          0.3075471615725595,
          0.0755813949939648,
          0.8433962234126705,

          0.30754717134977216,
          0.2557043646148702,
          0.8396226358357173,
          0.2892441860386063
        ],
        "order": 9
      },
      {
        "id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_9",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Identify the ethical dilemma.",
        "bbox": [
          0.3264150956847605,
          0.2993551585396042,
          0.598113211635994,
          0.31547619028563606
        ],
        "order": 10
      },
      {
        "id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_11",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Decide who might be affected.",

        "id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_4",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Is it against the law? Does it violate company or professional policies?",
        "bbox": [
          0.3226415256082073,
          0.1177325589296219,
          0.864150934061604,
          0.1535773562678762

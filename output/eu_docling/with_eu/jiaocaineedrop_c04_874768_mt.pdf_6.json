        "id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_5",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Even if everyone is doing it, how would I feel if someone did this to me?",
        "bbox": [
          0.3226415134827287,
          0.154017856897997,
          0.8660377453851957,
          0.18750000011667928
        ],
        "order": 6
      },
      {
        "id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_6",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Am I sacrificing long-term benefits for short-term gains?",

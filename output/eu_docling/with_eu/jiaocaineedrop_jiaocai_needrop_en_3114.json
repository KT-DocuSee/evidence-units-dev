  {
    "eu_id": "EU-0003",
    "kind": "table_panel",
    "page": "jiaocaineedrop_jiaocai_needrop_en_3114",
    "primary_id": "docling_jiaocaineedrop_jiaocai_needrop_en_3114_11",

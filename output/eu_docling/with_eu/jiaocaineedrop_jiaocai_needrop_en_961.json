          0.34593023286113567
        ],
        "order": 10
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Sarah, Sam, come here, please.",
        "bbox": [
          0.21560575730432133,
          0.3241279077668312,
          0.5195071835581015,
          0.34156976708781983
        ],
        "order": 11
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sarah: What's wrong?",
        "bbox": [
          0.20533880574349203,
          0.344476744505082,
          0.38603695975958824,
          0.3591269843360073
        ],
        "order": 12
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_10",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Your father is ill. He should see a doctor this morning, so we can't go to the zoo today.",
        "bbox": [
          0.21765913933717576,
          0.363343253974921,
          0.5359342832624817,
          0.41569767434181715
        ],
        "order": 13
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sam: Oh, no!",
        "bbox": [
          0.2195147009844019,
          0.41930883240460814,
          0.3246331408607496,
          0.43534232952620716
        ],
        "order": 14
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Don't be sad. We can go next time.",
        "bbox": [
          0.21765915021813825,
          0.43895348869112855,
          0.5503080066607114,
          0.45348837177398776
        ],
        "order": 15
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sam: How does Dad feel now?",
        "bbox": [
          0.22176591290788605,
          0.45783730148395635,
          0.46201231517219626,
          0.4694940475157024
        ],
        "order": 16
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Not well. Let's go to the hospital. How does Sam feel? What should he do?",
        "bbox": [
          0.21765914695732413,
          0.4766865083109499,
          0.5338809004348728,
          0.52616279023329
        ],
        "order": 17
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_17",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Your friends need some help. Call them and give your suggestions.",
        "bbox": [
          0.25256673811341135,
          0.5566860468306635,
          0.7843942608085596,
          0.5712209299135227
        ],
        "order": 19
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_18",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "you",
        "bbox": [
          0.4661190966241779,
          0.6133720929159663,
          0.4948665294880741,
          0.6206395349304484
        ],
        "order": 21
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Don't be angry. You should take a deep breath.",
        "bbox": [
          0.24435318678972923,
          0.6438492062095239,
          0.39219712417536323,
          0.6875000000258363
        ],
        "order": 22
      },
      {
        "id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_21",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "I'm angry.",

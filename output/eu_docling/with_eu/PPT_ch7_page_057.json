      },
      {
        "id": "docling_PPT_ch7_page_057_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Now consider the equation where C, Cy ..., Cm are any scalars.",
        "bbox": [
          0.05905173812045685,

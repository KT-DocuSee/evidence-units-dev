      {
        "id": "docling_PPT_ch7_page_057_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Given any set of m vectors a1) ... , am) (with the same number of components), a linear combination of these vectors is an expression of the form",
        "bbox": [

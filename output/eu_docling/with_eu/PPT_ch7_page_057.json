      {
        "id": "docling_PPT_ch7_page_057_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Clearly, this vector equation (1) holds if we choose all c's zero, because then it becomes 0 = 0.",
        "bbox": [
          0.05833334574927912,
          0.565806877227645,
          0.9026162907824792,
          0.661111110627335

      {
        "id": "docling_jiaocaineedrop_chap10.pdf_8_1",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Verify that 2 sec? x = I + sin x + | - sin x is an identity. (Lesson 7-2)",

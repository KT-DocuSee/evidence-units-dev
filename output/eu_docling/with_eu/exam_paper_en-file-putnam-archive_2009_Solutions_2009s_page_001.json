        ],
        "order": 10
      },
      {
        "id": "docling_exam_paper_en-file-putnam-archive_2009_Solutions_2009s_page_001_6",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "A-2 Multiplying the first differential equation by gh, the second by fh, and the third by fg, and summing gives",
        "bbox": [
          0.09586466658834576,
          0.4723837208317219,
          0.49060150869360897,
          0.49999999982598164
        ],
        "order": 11

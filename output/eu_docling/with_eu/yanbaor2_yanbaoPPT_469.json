      {
        "id": "docling_yanbaor2_yanbaoPPT_469_25",
        "observed_type": "list_item",
        "canon_role": "support_paragraph",
        "text": "Aentiy astr leverage quick wins to prove potential Emate organizations hangd on insights",
        "bbox": [
          0.2583826500775585,
          0.529017857305943,
          0.820512824675893,

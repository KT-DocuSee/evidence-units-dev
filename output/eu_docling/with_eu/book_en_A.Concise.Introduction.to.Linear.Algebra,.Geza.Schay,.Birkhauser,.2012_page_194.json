        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "With Definition 4.2.4 Theorems 4.2.8 and 4.2.9 lead to the following theorem.",
        "bbox": [
          0.1183761977566969,
          0.4084302323460205,
          0.8766519716588825,

  {
    "eu_id": "EU-0004",
    "kind": "text_cluster_panel",
    "page": "docstructbench_llm-raw-scihub-o.O-s00348-006-0117-x.pdf_11",
    "primary_id": "docling_docstructbench_llm-raw-scihub-o.O-s00348-006-0117-x.pdf_11_3",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "docling_docstructbench_llm-raw-scihub-o.O-s00348-006-0117-x.pdf_11_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "An example is given in Fig. 10a where two vortices of opposite sense of rotation are close to each other, and both are affecting the other vortex flow field adversely. In (a) the vortex centre was manually set to the centre of the disturbing structure, using the scalar field of 22-convolution. After elimination of this structure using a best fit to Vatistas swirl model the remaining vortex is clearly unaffected by other structures (b) and its parameters can be identified. To do even more, the shear layer at the lower left of the image could be eliminated by the same procedure.",
        "bbox": [
          0.08036084143894928,
          0.31686046547031965,
          0.4923371666795479,
          0.47674418607234803
        ],
        "order": 23
      }
    ]
  },

    "canon_role": "support_paragraph",
    "bbox": [
      0.5482546205970742,
      0.7747093027085126,
      0.7063654973358485,
      0.7834302323690068
    ],
    "page": "docstructbench_enbook-zlib-o.O-21353024.pdf_39",
    "order": 26
  },
  {
    "chunk_id": "docling_docstructbench_enbook-zlib-o.O-21353024.pdf_39_10",
    "text": "I mentioned the boards I got as a kid, with bent-over component leads. I religiously unsoldered all of them. These days I won't touch such components unless they are really special; it's not worth the effort.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.06981519135160465,
      0.7891865079322843,
      0.5010266869851514,
      0.8299418605929074
    ],
    "page": "docstructbench_enbook-zlib-o.O-21353024.pdf_39",
    "order": 27
  },
  {
    "chunk_id": "docling_docstructbench_enbook-zlib-o.O-21353024.pdf_39_28",
    "text": "— WEBLINKS",
    "canon_role": "section_header",
    "bbox": [
      0.5277207426586079,
      0.8328373014486199,
      0.6529774134673331,
      0.8430232555652595
    ],
    "page": "docstructbench_enbook-zlib-o.O-21353024.pdf_39",
    "order": 28
  },
  {
    "chunk_id": "docling_docstructbench_enbook-zlib-o.O-21353024.pdf_39_11",
    "text": "Electrolytic capacitors should always be tested, especially large power supply types, and look for domes on the tops - a dead giveaway that they have gone dry or leaky.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.06981519629790668,
      0.8473837211900385,
      0.5030800864889154,
      0.8866567459332352
    ],
    "page": "docstructbench_enbook-zlib-o.O-21353024.pdf_39",
    "order": 29
  },
  {
    "chunk_id": "docling_docstructbench_enbook-zlib-o.O-21353024.pdf_39_29",
    "text": "Good datasheet site with lots of options: www.alldatasheet.com/",
    "canon_role": "support_paragraph",

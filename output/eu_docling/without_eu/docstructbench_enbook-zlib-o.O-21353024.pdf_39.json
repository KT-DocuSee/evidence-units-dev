  {
    "chunk_id": "docling_docstructbench_enbook-zlib-o.O-21353024.pdf_39_9",
    "text": "Be Selective",
    "canon_role": "section_header",
    "bbox": [
      0.06981519418389916,
      0.7747093024642633,
      0.17864476202759985,
      0.7864583335160201
    ],

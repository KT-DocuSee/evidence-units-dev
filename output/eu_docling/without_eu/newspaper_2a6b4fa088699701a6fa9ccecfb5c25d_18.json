    "text": "[FR Doc. 2016-24142 Filed 10-5-16; 8:45 am] BILLING CODE 4333-15-P",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07330827105011722,
      0.2732558142976599,
      0.31578946846116107,
      0.2951388888197481
    ],

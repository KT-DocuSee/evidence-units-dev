    "order": 5
  },
  {
    "chunk_id": "docling_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_18_3",
    "text": "The primary authors of this document are the staff members of the Unified Listing Team, Ecological Services Program.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07142857137625111,
      0.09151785740871911,
      0.34774435410747245,
      0.1438953483364876
    ],

    "page": "jiaocaineedrop_c04_874768_mt.pdf_6",
    "order": 19
  },
  {
    "chunk_id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_18",
    "text": "What is the difference between personal and business ethics?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10188680100318442,
      0.595930232677652,
      0.6264150735251177,
      0.6091269839164599
    ],
    "page": "jiaocaineedrop_c04_874768_mt.pdf_6",
    "order": 20
  },
  {
    "chunk_id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_19",
    "text": "Describe some of the ways that unethical business practices can affect a business.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1018868035487882,
      0.6148255819566325,
      0.7981132195329719,
      0.6294642859235302
    ],
    "page": "jiaocaineedrop_c04_874768_mt.pdf_6",
    "order": 21
  },
  {
    "chunk_id": "docling_jiaocaineedrop_c04_874768_mt.pdf_6_20",
    "text": "What is the relationship between illegal behaviors of business and unethical behaviors of business?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10188680019163805,
      0.6336805555499997,
      0.8169811362549027,
      0.662790697645749
    ],
    "page": "jiaocaineedrop_c04_874768_mt.pdf_6",
    "order": 22
  },

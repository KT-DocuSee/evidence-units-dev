[
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_0",
    "text": "Let's try",
    "canon_role": "section_header",
    "bbox": [
      0.25251962162877445,
      0.1524937149511099,
      0.36555019305137804,
      0.17454116840756456
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 1
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_1",
    "text": "It's seven o'clock in the morning, and it's time to get up. Listen and circle.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2505133378782902,
      0.18168604711276146,
      0.7782340848321823,
      0.2136627908018201
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 2
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_2",
    "text": "Who are the people talking?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2505133512654816,
      0.21800595213349666,
      0.49691991714167594,
      0.2341269838795285
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 3
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_4",
    "text": "B. Parents.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4474022371583795,
      0.2332384552117468,
      0.5382240477162117,
      0.24931968430054519
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 4
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_3",
    "text": "Doctors.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.27306486750223136,
      0.2338756682687719,
      0.3716989961530411,
      0.2472289829334007
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 5
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_5",
    "text": "What are they talking about?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2505133521371745,
      0.2543604647588111,
      0.5112936331077653,
      0.2703488373798933
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 6
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_6",
    "text": "Going to the zoo. B. Going to school.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2751540161715778,
      0.2688492061731867,
      0.5995893211316389,
      0.28348214268112326
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 7
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_22",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.5450302179375756,
      0.2721068866235571,
      0.8365831294399939,
      0.537666754622702
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 8
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_7",
    "text": "Let's talk",
    "canon_role": "section_header",
    "bbox": [
      0.2525667362903755,
      0.29651162833369166,
      0.38193018284035685,
      0.3139880952467636
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 9
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_16",
    "text": "200",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5954825462659291,
      0.31831395339532415,
      0.708418889850886,
      0.34593023286113567
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 10
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_8",
    "text": "Mum: Sarah, Sam, come here, please.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21560575730432133,
      0.3241279077668312,
      0.5195071835581015,
      0.34156976708781983
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 11
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_9",
    "text": "Sarah: What's wrong?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.20533880574349203,
      0.344476744505082,
      0.38603695975958824,
      0.3591269843360073
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 12
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_10",
    "text": "Mum: Your father is ill. He should see a doctor this morning, so we can't go to the zoo today.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21765913933717576,
      0.363343253974921,
      0.5359342832624817,
      0.41569767434181715
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 13
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_11",
    "text": "Sam: Oh, no!",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2195147009844019,
      0.41930883240460814,
      0.3246331408607496,
      0.43534232952620716
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 14
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_12",
    "text": "Mum: Don't be sad. We can go next time.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21765915021813825,
      0.43895348869112855,
      0.5503080066607114,
      0.45348837177398776
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 15
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_13",
    "text": "Sam: How does Dad feel now?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.22176591290788605,
      0.45783730148395635,
      0.46201231517219626,
      0.4694940475157024
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 16
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_14",
    "text": "Mum: Not well. Let's go to the hospital. How does Sam feel? What should he do?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21765914695732413,
      0.4766865083109499,
      0.5338809004348728,
      0.52616279023329
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 17
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_15",
    "text": "Act with your friends.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2525667349221792,
      0.5406746035724799,
      0.45379876764455596,
      0.5567956353185116
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 18
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_17",
    "text": "Your friends need some help. Call them and give your suggestions.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.25256673811341135,
      0.5566860468306635,
      0.7843942608085596,
      0.5712209299135227
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 19
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_23",
    "text": "",
    "canon_role": "picture",
    "bbox": [

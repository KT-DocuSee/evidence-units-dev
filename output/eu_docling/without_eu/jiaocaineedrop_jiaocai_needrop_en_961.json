      0.5733234981228623,
      0.733085143378741,
      0.7628774524703399
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 20
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_18",
    "text": "you",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4661190966241779,
      0.6133720929159663,
      0.4948665294880741,
      0.6206395349304484
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 21
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_19",
    "text": "Don't be angry. You should take a deep breath.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24435318678972923,
      0.6438492062095239,
      0.39219712417536323,
      0.6875000000258363
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 22
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_961_21",
    "text": "I'm angry.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3696098572387732,
      0.728197674330995,
      0.4271047229665657,
      0.7587209302329585
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 23
  },
  {

    "chunk_id": "docling_scihub_j.jallcom.2003.09.015.pdf_1_33",
    "text": "sence of the ternary boride ErNiB 10 in the Er-Ni-B system (Table 2).",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5240805023676788,
      0.43303571407646996,
      0.9284332730778259,
      0.4625070676133161
    ],

      0.24851190430852155,
      0.5626283412302274,
      0.2805232561966635
    ],
    "page": "notes_f7f010b78016aeebd76e56d9283eb67f_112",
    "order": 6
  },
  {
    "chunk_id": "docling_notes_f7f010b78016aeebd76e56d9283eb67f_112_6",
    "text": "This is a phenomenon that many people are interested in.",
    "canon_role": "support_paragraph",
    "bbox": [

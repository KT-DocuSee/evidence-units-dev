  {
    "chunk_id": "docling_docstructbench_llm-raw-scihub-o.O-j.physletb.2004.11.060.pdf_2_21",
    "text": "while integration of (6) over all frequencies yields the well-known Stefan-Boltzmann law",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5187376653756441,
      0.7209302320942554,
      0.9171597628294844,

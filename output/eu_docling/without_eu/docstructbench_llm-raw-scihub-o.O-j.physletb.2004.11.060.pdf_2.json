  {
    "chunk_id": "docling_docstructbench_llm-raw-scihub-o.O-j.physletb.2004.11.060.pdf_2_8",
    "text": "they would have obtained",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5187376730268337,

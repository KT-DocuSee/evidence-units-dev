  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_006_5",
    "text": "Hyundai introduces the IONIQ 5 robotaxi.",
    "canon_role": "section_header",
    "bbox": [
      0.05916031692281133,
      0.7978670633567152,
      0.3416030489168832,

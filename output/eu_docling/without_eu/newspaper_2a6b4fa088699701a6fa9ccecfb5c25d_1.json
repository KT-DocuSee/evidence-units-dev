  {
    "chunk_id": "docling_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_23",
    "text": "Stephen Guertin,",
    "canon_role": "section_header",
    "bbox": [
      0.07138080975476369,
      0.5346668576068472,
      0.18049888818000337,
      0.5496354666598383

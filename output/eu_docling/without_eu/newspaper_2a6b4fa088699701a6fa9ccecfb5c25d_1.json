    "order": 26
  },
  {
    "chunk_id": "docling_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_22",
    "text": "Acting Director, U.S. Fish and Wildlife Service.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07142857208646614,
      0.5478670635007318,
      0.30263157054200024,
      0.5726744184659694
    ],
    "page": "newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1",
    "order": 27
  },
  {
    "chunk_id": "docling_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_32",
    "text": "SUMMARY: We, the U.S. Fish and Wildlife Service (Service), announce 12month findings on petitions to list 10 species as endangered or threatened species under the Endangered Species Act of 1973, as amended (Act). After a review of the best available scientific and commercial information, we find that listing the Huachuca-Canelo population of the Arizona treefrog, the Arkansas darter, black mudalia, Highlands tiger beetle, Dichanthelium (=panicum) hirstii (Hirst Brothers' panic grass), two Kentucky cave beetles (Louisville cave beetle and Tatum Cave beetle), relict leopard frog, sicklefin redhorse sucker, and Stephan's riffle beetle is not warranted at this time.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.35902255413533835,
      0.5610119046452253,
      0.6372180478759397,
      0.7921626982499024
    ],
    "page": "newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1",
    "order": 28
  },
  {
    "chunk_id": "docling_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_24",
    "text": "(FR Doc. 2016-24138 Filed 10-5-16; 8:45 am] BILLING CODE 4333-15-P",
    "canon_role": "support_paragraph",
    "bbox": [
      0.06954888087842978,
      0.5741279068782335,
      0.3176691704373595,
      0.6002906975876097
    ],
    "page": "newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1",
    "order": 29
  },

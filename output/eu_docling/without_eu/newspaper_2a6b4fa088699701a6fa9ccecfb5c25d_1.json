  {
    "chunk_id": "docling_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_9",
    "text": "Accordingly, we amend part 17, subchapter B of chapter I, title 50 of the Code of Federal Regulations, as follows:",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6503759453358314,
      0.09300595242879116,
      0.9210526258671763,
      0.13081395292708842
    ],
    "page": "newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1",
    "order": 6
  },
  {

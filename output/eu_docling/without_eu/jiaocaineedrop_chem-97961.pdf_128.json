  {
    "chunk_id": "docling_jiaocaineedrop_chem-97961.pdf_128_2",
    "text": "Video 5.1.2: A science experiment in the kitchen shows what happens to sugar molecules when they are heated. The experiment did not disappoint!",
    "canon_role": "support_paragraph",
    "bbox": [
      0.09586466831668083,
      0.31540697675468704,

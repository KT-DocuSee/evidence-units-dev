  {
    "chunk_id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_2",
    "text": "August 11, 2000: President Bill Clinton issued the Executive Order 13166.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.0791666588888891,
      0.29431217014550265,
      0.9124999922222224,
      0.38593262569539477
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 3
  },
  {
    "chunk_id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_3",
    "text": "Designed to improve access to federally conducted and federally assisted programs/activities for LEP persons",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07916666908931695,
      0.3999999998795897,
      0.8624999782023501,
      0.49612403022559254
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 4
  },
  {
    "chunk_id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_4",
    "text": "Federal agencies were asked to develop and implement a system to provide LEP persons access to services.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07830870842457195,
      0.5095410929300931,
      0.8881979417261283,
      0.6028439154601944
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 5
  },
  {
    "chunk_id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_5",
    "text": "Each federal agency was asked to prepare a plan to improve access to LEP persons, and submit plans to the U.S. Department of Justice.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07994186267772976,
      0.6162790698067073,
      0.9215116118135496,
      0.7559523803484247
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 6
  },
  {
    "chunk_id": "docling_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_6",
    "text": "Executive Order charged the Department of Justice with the responsibility of providing LEP guidance to federal agencies.",

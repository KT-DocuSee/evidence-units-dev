    "order": 5
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_4",
    "text": "Senior Adviser, Innovation",
    "canon_role": "section_header",
    "bbox": [
      0.07632323637420532,
      0.22807624799839116,
      0.2084405978158469,
      0.2593499845414799
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 6
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_9",
    "text": "Shape the future monetary and financial system as part of the BIS's mission to support central banks' pursuit of monetary and financial stability.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24474187546027998,
      0.23110465137414696,
      0.5621414895492803,
      0.2674418604717835
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 7
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_21",
    "text": "· Have the ability to produce high-quality policy outputs and to conduct and publish high-quality research - a very good knowledge of the workings of international institutions and of research networks in academia and policy institutions is required · Have an excellent understanding of monetary and financial stability policymaking and innovation issues",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6061185435494936,
      0.2311046513933162,
      0.9120458887194376,
      0.3169642858616359
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 8
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_10",
    "text": "The Monetary and Economic Department of the BIS seeks a Senior Adviser to spearhead work on issues of innovation, digitalisation and their impact on the monetary and financial system. You will play an intellectual leadership role in the BIS's innovation agenda and play a pivotal role in its policyrelevant research.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24474187066868314,
      0.2805059524842976,
      0.5908221747018501,
      0.35466269843510123
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 9
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_5",
    "text": "Basel, Switzerland",
    "canon_role": "support_paragraph",
    "bbox": [
      0.08030593048955023,
      0.2819767443974027,
      0.20267686004582267,
      0.2936507937521376
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 10
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_6",
    "text": "Bank for International Settlements (BIS)",
    "canon_role": "support_paragraph",
    "bbox": [
      0.0783938806824684,
      0.30668604642789027,
      0.18355640288094155,
      0.3241567460587487
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 11
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_7",
    "text": "Promoting global monetary and financial stability through international cooperation",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07839388359662482,
      0.32837301593952345,
      0.22179732077940062,
      0.35615079356778406
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 12
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_22",
    "text": "In return, we offer the opportunity to work at the hub for central bank cooperation, in an intellectually stimulating international setting alongside colleagues from more than 60 countries, with competitive employment conditions. The BIS is fully committed to equal opportunity employment and strives for diversity among its staff.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6061185512449003,
      0.34447674452052807,
      0.9120458925030924,
      0.4288194442430888
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 13
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_11",
    "text": "The successful candidate will:",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24474187435249617,
      0.36773255826104867,
      0.4149139616417676,
      0.37797619027866874
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 14
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_12",
    "text": "· Have a PhD or equivalent experience in economics, finance, engineering or computer science and an outstanding publication record in financial economics, artificial intelligence and other policy-relevant areas of research",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24282982916393256,
      0.38070436490284515,
      0.5544933094230753,
      0.44040697695102726
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 15
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_8",
    "text": "Deadline for applications: 12 January 2024",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07839388363708616,
      0.45203488393428787,
      0.1797323093648259,
      0.4869186047387724
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 16
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_13",
    "text": "To find out more, visit www.bis.org/careers",

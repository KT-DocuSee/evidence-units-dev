    "order": 23
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_26",
    "text": "Help us build institutional capacity and develop the finance sector across Latin America and the Caribbean.",
    "canon_role": "section_header",
    "bbox": [
      0.5258126238213628,
      0.5988372094760123,
      0.8527724614941248,
      0.6424418601218559
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 24
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_27",
    "text": "Sector Manager, Institutions for Development, Washington DC",
    "canon_role": "section_header",
    "bbox": [
      0.5239005710084106,
      0.6453373017515196,
      0.8910133795843238,
      0.6716269842895853
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 25
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_28",
    "text": "The leading source of development finance for Latin America and the Caribbean, the IDB partners with 48 member countries to promote inclusive, sustainable and climate-friendly development that reduces poverty and inequality. Reporting to the Vice President for Sectors and Knowledge, you will lead a high-calibre team helping us to conceptualize, prepare, implement and supervise our operations and knowledge work in the areas of governance, citizen security and justice, public sector strengthening and reform, decentralization and fiscal and economic issues.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5239005751114075,
      0.6743551589396823,
      0.9273422575791945,
      0.7674418601064099
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 26
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_29",
    "text": "This will require extensive experience in senior leadership roles within international organizations focusing on Latin America and the Caribbean, Naturally, you will be capable of thinking strategically and developing innovative solutions to meet diverse clients' needs, adept at forging partnerships across countries and sectors, and skilled in building successful teams with a strong client service orientation. Finally, it is essential that you are fully fluent in English, preferably backed by proficiency in Spanish and some knowledge of French and Portuguese.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5258126172296008,
      0.770337301394114,
      0.9273422575791945,
      0.8633720927200559
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 27
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_15",
    "text": "Unique Access to Confidential Opportunities",
    "canon_role": "section_header",
    "bbox": [
      0.09751433475388621,
      0.8182043650328834,
      0.43785850933242915,
      0.832848836931795
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 28
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_16",
    "text": "InterExec is the global leader in assisting Top Executives to access £200k to f2m+ unadvertised vacancies worldwide. We act discreetly through our 15,000 strong Headhunter network.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.09751433293061394,
      0.835755814075002,
      0.4378585075091569,
      0.8764880953696096
    ],
    "page": "magazine_TheEconomist.2023.12.09_page_015",
    "order": 29
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.12.09_page_015_30",
    "text": "Please send the complete job description and apply via jobs.ladb.org (reference 2300000972)",
    "canon_role": "support_paragraph",

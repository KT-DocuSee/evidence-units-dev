  {
    "chunk_id": "docling_docstructbench_llm-raw-scihub-o.O-j.mseb.2009.12.004.pdf_2_18",
    "text": "acterisation of the structured monolayers by means of a combined approach to obtain both compositional and topographical aspects",
    "canon_role": "support_paragraph",
    "bbox": [
      0.052325587432204425,
      0.3590116281183329,
      0.4786821502938942,
      0.38372093026344994
    ],

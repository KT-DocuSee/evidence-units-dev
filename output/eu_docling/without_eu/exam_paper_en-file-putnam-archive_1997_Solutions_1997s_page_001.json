    "order": 29
  },
  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_1997_Solutions_1997s_page_001_13",
    "text": "The player to move has at least k pennies.",
    "canon_role": "support_paragraph",
    "bbox": [

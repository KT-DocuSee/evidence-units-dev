  },
  {
    "chunk_id": "docling_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_058_38",
    "text": "Dubravka.. | Hall … | burn... | Botman.. | Livramento .... | Joelinton BOOKED.. | Tonali... | Willock.. | Gordon BOOKED | Murphy. | Isak... | SUBS | Longstaff (Willock 65). | Kelly (Murphy 65) | Barnes (Isak 65). Almiron (Gordon 76)",
    "canon_role": "table",

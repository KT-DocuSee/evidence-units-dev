  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_28",
    "text": "Applying the weighted AM-GM inequality between matching terms in the two sums yields",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5582706824974855,
      0.8110119047552375,
      0.9191729325401083,
      0.8386627906399352
    ],
    "page": "exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001",
    "order": 27
  },

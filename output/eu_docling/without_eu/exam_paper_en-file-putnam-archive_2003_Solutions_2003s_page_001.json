  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_26",
    "text": "for a, b,c, d ≥ 0. The left side can be written as",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5582706888564959,
      0.6758432541441632,
      0.8684210508051579,
      0.6889880954140045
    ],
    "page": "exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001",
    "order": 22
  },
  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_10",
    "text": "Second solution: Write the desired inequality in the form",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12781954002757723,
      0.6787790702207146,
      0.4906015005112703,
      0.7049418603506593
    ],

  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_12",
    "text": "expand both sides, and compare the terms on both sides in which k of the terms are among the aj. On the left, one has the product of each k-element subset of {1,..,n}; on the right, one has",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1259398597267846,
      0.7485119046475582,
      0.4906015104110193,
      0.8038194444136632
    ],
    "page": "exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001",
    "order": 26

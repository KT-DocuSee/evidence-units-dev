    ],
    "page": "exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001",
    "order": 10
  },
  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_19",
    "text": "and the quantities si = logri, we can rewrite the desired inequality as",
    "canon_role": "support_paragraph",
    "bbox": [
      0.556390974386913,
      0.33575581445420993,
      0.9191729348706059,
      0.3633720926315457
    ],
    "page": "exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001",
    "order": 11
  },
  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_20",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5738224882238051,
      0.3745942549272017,
      0.8621120318244485,

  {
    "chunk_id": "docling_docstructbench_llm-raw-the-eye-o.O-Something%27s%20Cooking.pdf_4_11",
    "text": "Damage: Slam 1d8+1 and 1d4 fire",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1897233276758919,
      0.4025297619751034,
      0.4169960455948589,

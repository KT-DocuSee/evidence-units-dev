  {
    "chunk_id": "docling_docstructbench_llm-raw-the-eye-o.O-Something%27s%20Cooking.pdf_4_27",
    "text": "Magic Immunity (Ex): Calzone golems are immune to all spells, spell-like abilities, and supernatural effects, except as follows. Cold-based effects slow them (as the slow spell) for 2d6 rounds, no saving throw. Fire-based effects deal no damage but rather harden the golem temporarily, increasing its natural armor bonus by +1 for every 3 points of damage it would otherwise deal (this hardening fades after 1d4 hours). The golem rolls no saving throw against fire effects.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5828587434357059,
      0.4069767440693672,
      0.9586142541324564,
      0.5479651164139177
    ],
    "page": "docstructbench_llm-raw-the-eye-o.O-Something%27s%20Cooking.pdf_4",
    "order": 16
  },

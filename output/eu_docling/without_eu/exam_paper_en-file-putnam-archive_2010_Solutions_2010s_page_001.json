    "page": "exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001",
    "order": 20
  },
  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_10",
    "text": "Consequently, f' (x + 1) = f(x).",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12781955383207205,
      0.5857558142434542,
      0.34398496176943166,

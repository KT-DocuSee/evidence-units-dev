  {
    "chunk_id": "docling_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_25",
    "text": "Lemma 3. If x, y € G commute, then * xy = 0.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.516917304061387,
      0.5247093026446169,
      0.8308270673045273,
      0.539244185727476

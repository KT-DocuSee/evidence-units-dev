    "order": 16
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_3",
    "text": "Cities across America, Europe and Asia have successfully built infrastructural, environmental, social and economic resilience.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.055343513401795996,
      0.5203373017016479,
      0.2538167903916925,
      0.5901162788584112
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 17
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_9",

  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_7",
    "text": "Scan to reveal the most resilient city",
    "canon_role": "support_paragraph",
    "bbox": [
      0.28244275250708367,
      0.5885416667040044,
      0.38358778473051164,
      0.6091269841755442
    ],

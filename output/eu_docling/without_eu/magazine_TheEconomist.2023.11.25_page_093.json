    "order": 21
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_22",
    "text": "Paris",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8702290086275932,
      0.5886627909110318,
      0.9026717555422541,
      0.5973837205715262
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 22
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_12",
    "text": "Resilient cities continue to adapt and grow amid uncertainty and change. They identify risks and create systems that enable businesses and residents to recover and thrive after unexpected events. The Resilient Cities Index 2023, devised by Economist Impact, examines the preparedness of 25 cities in four vital areas- critical infrastructure, environment, socioinstitutional and economic.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.055308159410373,
      0.6366279068891345,
      0.6316793751709014,
      0.7021329363505858
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 23
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_23",
    "text": "\"A resilience strategy is not something developed at a desk by a city official. Cities need to bring a variety of stakeholders together, including community representation, the poor and the vulnerable.\"",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6507633561985566,
      0.6366279074491777,
      0.9351145021814266,
      0.765988371695378
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 24
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_13",
    "text": "The research highlights the following strategies to build resilience:",
    "canon_role": "support_paragraph",
    "bbox": [
      0.057251912974674406,
      0.7135416664985149,
      0.4694656525215087,
      0.7252906975502718
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 25
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_14",
    "text": "Incentivise businesses and residents to guard against future risks by using financial rewards for hitting targets.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.055343502126481835,
      0.7353670634657267,
      0.6068702245433657,
      0.7616567459897424
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 26
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_24",
    "text": "Katrin Bruebach",
    "canon_role": "section_header",
    "bbox": [
      0.8511450373787045,
      0.7688492062128575,
      0.9446564870010665,
      0.77761627885641
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 27
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_15",
    "text": "Plan a cohesive response to shocks by integrating vulnerable groups and offering comprehensive social safety-nets.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.05534351742571936,
      0.7703373013557755,
      0.622137384434968,
      0.7951388889041135
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 28
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_25",
    "text": "Global director of programmes and delivery Resilient Cities Network",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7212029138909314,
      0.7793211581691555,
      0.9448480408504225,
      0.8023313490994703
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 29
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_16",
    "text": "Drive innovative, scalable and cost-effective solutions through a dynamic business ecosystem.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.05534350615835989,
      0.8052325583505594,
      0.616412203892531,
      0.8315482317147299
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 30
  },
  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_17",
    "text": "Promote community stewardship through education and collaboration.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.05534351708654004,
      0.8415178570295113,
      0.5305343573886505,
      0.8531976743162603
    ],
    "page": "magazine_TheEconomist.2023.11.25_page_093",
    "order": 31

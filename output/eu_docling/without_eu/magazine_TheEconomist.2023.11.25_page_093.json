  {
    "chunk_id": "docling_magazine_TheEconomist.2023.11.25_page_093_2",
    "text": "Top five",
    "canon_role": "section_header",
    "bbox": [
      0.05534351186363945,
      0.50570436493785,
      0.11450381652376514,
      0.5188953487176967
    ],

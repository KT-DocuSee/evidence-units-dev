    "order": 12
  },
  {
    "chunk_id": "docling_docstructbench_llm-raw-scihub-o.O-j.snb.2004.06.022.pdf_2_8",
    "text": "Fig. 2. A scheme of resistance measurements in the two-point method. Changes in resistance were monitored by an automatic data acquisition unit Agilent 34970A for various hydrogen concentrations in nitrogen or in air.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5087040623664395,
      0.1715116276865519,
      0.9187620832815296,
      0.22395833349279584
    ],

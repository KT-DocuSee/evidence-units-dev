  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_4",
    "text": "Peter: Hi, Amy! What's the weather like in Shanghai today?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13034623949197316,
      0.4548611107606729,
      0.659877789998862,
      0.4724702377447999
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 12
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_5",
    "text": "Amy: Hello, Peter! It's sunny and warm here. I'm going to the zoo this afternoon.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13238291512877456,
      0.48401162845481566,
      0.857433797566405,
      0.5014880953678876
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 13
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_6",
    "text": "Peter: That's cool!",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1323828961173934,
      0.5130813951413149,
      0.29735233906590597,
      0.526162790578162
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 14
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_7",
    "text": "Amy: Peter, how is the weather in Beijing now?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13034624187351102,
      0.5436046509423659,
      0.5397148497354504,
      0.5595930235634481
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 15
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_8",
    "text": "Peter: It's cloudy. It's going to rain. So I can't fly a kite in the park.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13034622791989,
      0.5696924604365412,
      0.753564154157503,
      0.5886627900466694
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 16
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_9",
    "text": "Amy: Oh, I see.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13034623383859464,
      0.6016865083363859,
      0.270875765601324,
      0.6178075400824178
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 17
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_10",
    "text": "Peter: Do you know the weather in Guangzhou?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1323828832690615,
      0.6307043651377047,
      0.5437881893039189,
      0.6438953489175515
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 18
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_11",
    "text": "Amy: It's very hot there. The children there usually go swimming in the sea. It's going to rain this afternoon.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13034625880959183,
      0.6584302332563828,
      0.9063136193472311,
      0.7021329365534423
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 19
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_12",
    "text": "Peter: Oh,I like swimming too. But I can't swim now. It's a little cold.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1323828980319061,
      0.7150297620807816,
      0.7556008242695191,
      0.7326388890649086
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 20
  },
  {
    "chunk_id": "docling_jiaocaineedrop_jiaocai_needrop_en_715_13",
    "text": "( )1. It's fine in Shanghai.",
    "canon_role": "plain_text",
    "bbox": [
      0.1303462441533215,
      0.7455357140021257,
      0.3991853308636505,
      0.7616567457481576
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 21
  },

  {
    "chunk_id": "docling_jiaocaineedrop_chem-436205.pdf_793_16",
    "text": "Large 4, (Strong Field)",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6109022632656479,
      0.29067460328701694,
      0.8590225528245776,

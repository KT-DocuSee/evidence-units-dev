    "chunk_id": "docling_newspaper_d7fe1132386670993aae3dabc6247bc9_2_42",
    "text": "Final Results of Expedited Sunset Reviews of Antidumping Duty Orders: Light-Walled Rectangular Pipe and Tube From Mexico, Turkey, the People's Republic of China, and the Republic of Korea",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6484962419793113,
      0.6090116279235339,
      0.9191729272926146,
      0.6845930233351554
    ],

    "order": 10
  },
  {
    "chunk_id": "mineru_jiaocai_jiaocai_en_6_10",
    "text": "苏轼",
    "canon_role": "support_paragraph",
    "bbox": [
      0.48125755743651755,
      0.536411571896822,
      0.5191455058444175,
      0.5512327205358415
    ],
    "page": "jiaocai_jiaocai_en_6",
    "order": 11
  },
  {
    "chunk_id": "mineru_jiaocai_jiaocai_en_6_11",
    "text": "夜饮东坡醒复醉，归来仿佛三更。家童鼻息已雷鸣。敲门都不应，倚杖听江声。 长恨此我有，何时忘却营营?夜阑风静觳纹平。从此逝，江海寄余。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.15074566706972994,
      0.5637736924611657,
      0.7617896009673518,
      0.6076670941998005
    ],
    "page": "jiaocai_jiaocai_en_6",
    "order": 12
  },
  {
    "chunk_id": "mineru_jiaocai_jiaocai_en_6_12",
    "text": "【注释】①营营：往来劳碌。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.154776299879081,
      0.6196380219467009,
      0.37162434502216846,
      0.6350292147641442
    ],

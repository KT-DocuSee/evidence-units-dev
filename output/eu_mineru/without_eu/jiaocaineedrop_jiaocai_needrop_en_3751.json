    "order": 5
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3751_5",
    "text": "自由贸易与绝对成本学说",
    "canon_role": "section_header",
    "bbox": [
      0.13362864525655224,
      0.6802295252999478,
      0.3964562569213732,
      0.7016171100678142
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3751",
    "order": 6
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3751_6",
    "text": "自由贸易是自由放任的重要内容。斯密认为，自由贸易带来的好处，不尺限于国内贸易， 对外贸易同样可以给参与国带来利益。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1343669250645995,
      0.7423056859676578,
      0.8822443706164637,
      0.7814293166405842
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3751",

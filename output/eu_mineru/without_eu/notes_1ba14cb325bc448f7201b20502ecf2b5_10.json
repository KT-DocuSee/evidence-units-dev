    "order": 2
  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_10_2",
    "text": "③常用图例：",
    "canon_role": "support_paragraph",
    "bbox": [
      0.17759181775918179,
      0.25139848634419215,
      0.3217108321710832,
      0.27179993418887793
    ],

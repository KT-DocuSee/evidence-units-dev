  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_10_1",
    "text": "② 注记：用来说明地理事物名称的文字或用说明地理事物数量的数字，称 之为地图的”语言”。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10134821013482101,
      0.18887792036854228,
      0.9363086936308693,
      0.24021059559065483
    ],

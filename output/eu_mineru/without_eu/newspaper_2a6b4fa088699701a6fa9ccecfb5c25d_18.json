  {
    "chunk_id": "mineru_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_18_10",
    "text": "AGENcy: National Marine Fisheries Service (NMFS), National Oceanic and",
    "canon_role": "support_paragraph",
    "bbox": [

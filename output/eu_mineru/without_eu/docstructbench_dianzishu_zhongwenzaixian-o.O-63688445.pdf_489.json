  {
    "chunk_id": "mineru_docstructbench_dianzishu_zhongwenzaixian-o.O-63688445.pdf_489_9",
    "text": "AH头的格式如图16-4所示，包括：下一报头、有效载荷长度、保留位、安全参数索 引、序列号、认证数据。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12333407187326835,
      0.6160085571274743,
      0.8817465735417245,
      0.6542699581912925
    ],
    "page": "docstructbench_dianzishu_zhongwenzaixian-o.O-63688445.pdf_489",
    "order": 11
  },

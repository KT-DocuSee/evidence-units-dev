  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_98_1",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1682938168293817,
      0.18756169792694966,

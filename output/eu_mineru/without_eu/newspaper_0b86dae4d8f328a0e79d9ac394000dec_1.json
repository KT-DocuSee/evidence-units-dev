      0.14047558602014049
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 5
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_14",
    "text": "科教飞",
    "canon_role": "section_header",
    "bbox": [
      0.8278867102396514,
      0.11508843192011509,
      0.8903413217138707,
      0.1265972751121266
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 6
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_15",
    "text": "中科院公布 “棉花控缓释肥”新技术",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8215928346647301,
      0.13946009985613947,
      0.9644153957879448,
      0.1634932724041635
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 7
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_8",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1718712176228516,
      0.15063044766015063,
      0.3113047688211087,
      0.17567910637217568
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 8
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_9",
    "text": "破地域和学科界限，从品种选育、繁 育、推广、加工等方面拉长产业链，为 北方寒冷地区蔬菜产业发展打下良 好基础。”",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3263132413459211,
      0.15063044766015063,
      0.46526264826918423,
      0.18414149107218414
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 9
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_11",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4802711207939966,
      0.15063044766015063,
      0.6197046719922537,
      0.19226538038419227
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 10
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_13",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6356814330670539,
      0.15063044766015063,
      0.775599128540305,
      0.22645341457222645
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 11
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_5",
    "text": "本报记者赵洁",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01597676107480029,
      0.1546923923161547,
      0.15637860082304528,
      0.16383176779216382
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 12
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_6",
    "text": "日前，内蒙古寒冷地区蔬菜产 业技术创新战略联盟在内蒙古赤峰 市正式成立。该联盟由中国农业科 学院蔬菜花卉研究所、内蒙古农业 大学、和润农业公司等14家科研院 所、企业组建而成，以全区1/10的 设施蔬菜温室大棚为依托，通过企",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.16755521706016754,
      0.15637860082304528,
      0.2267919099602268
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 13
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_7",
    "text": "国家大宗蔬菜产业技术体系首 席科学家、中国农业科学院蔬菜花卉 研究所所长杜永臣说：“联盟以高标 准智能化蔬菜产业发展为导向，以和 润农业公司为主体，以形成蔬菜产业 核心竞争力为目标。各方将不断突 业与科研院所的结合，实现蔬菜品 种的良种化、产业体系集约化、设 施蔬菜规模化、技术成果商品化。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.17138707334785766,
      0.17567910637217568,
      0.31082062454611475,
      0.22645341457222645
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 14
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_16",
    "text": "中国科学院合肥物质研究院2010年 在望江、宿松、无为、宣州等地2万多亩棉 田示范控缓释化肥，结果显示，控缓释化肥 只需一次基肥和一次追肥即可，棉花产量 提10%左右，每亩减少用工成本100至 140元。而这种化肥的单价只比普通化肥 贵7%-8%。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8196562575647542,
      0.17601760176017603,
      0.9866860324376664,
      0.2339003131082339
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 15
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_10",
    "text": "“我们成战略联盟就是要围 绕产业技术创新链，运用市场机制集 聚创新资源，实现产、学、研各方在战 略层面的有效结合，突破温室大棚蔬 菜产业发展的技术瓶颈，打造成创建 产业标准、创新产业模式、创立产业 品牌、带动产业发展的现代设施农业 高科技园区。”和润农业董事长赵广 睿说。据了解，近几年，和润农业引 进和自主创新重点成果达12项。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3258290970709271,
      0.18515697723618516,
      0.46526264826918423,
      0.22645341457222645
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 16
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_12",
    "text": "为使公司成为带动中国北方设 施农业发展的龙头企业，和润农业致 力于打造国家农业园区核心园，核心 园总规戈面积9770亩，分三期五年完 工，总投资8.1亿元。目前占地1070 亩的一期工程已完成并投入使用，建 成高标准智能连栋温室、高标准智能 日光育秧温室等约4万余平方米。每 年可向种植户提供4500万株优质种 苗，能满足3万亩蔬菜基地生产的种 苗需求。园区已形成辐射内蒙古及 东北、华北地区的7大示范基地，示 范区覆盖面积达20万亩以上。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4807552650689906,
      0.1932808665481933,
      0.6201888162672476,
      0.22645341457222645
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 17
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_60",
    "text": "据中科院合肥物质研究院研究员吴跃 进介绍，控缓释化肥的意义不仅仅在于节 本增效，更重要的是能减少肥料养分的流 失，最终减少对河流水体的面源污染。施 用普通化肥，农田当季未吸收的氮、磷、钾 等进入水体和大气，造成水质恶化，土壤板 结变硬。按照巢湖流域示范与试验结果， 控缓释化肥平均养分利用率比普通复合肥 提高11%至22%，其中氮素利用率提高6 至13个百分点、磷利用率提高5至20个百 分点、钾的利用率提高21至32个百分点。 这为治理农业面源污染找到一条新途径。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8201404018397482,
      0.2349157992722349,
      0.9866860324376664,
      0.3340949479563341
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 18
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_17",
    "text": "治理53万平方公里沙化土地还要300年",
    "canon_role": "section_header",
    "bbox": [
      0.040183974824497704,
      0.2548870271642549,
      0.3887678528201404,
      0.26978082423626976
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 19
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_18",
    "text": "防沙治沙还须加快步伐",
    "canon_role": "section_header",
    "bbox": [
      0.03824739772452191,
      0.27756621816027754,
      0.5185185185185185,
      0.31344672928831346
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 20
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_32",
    "text": "祝列克说，“南水北调”不是 用调来的水主要用于植树造林，林 业需要保护好“南水北调”工程的 水源的水质，而且保证水源不会减 少。在人口居住地区和人类活动 比较活跃的地区实行必要的灌溉 林业，必须依据当地的水资源情况， 主要是扩大和保护绿洲的面积。从造 林来讲，必须尊重自然规律，我国森 林覆盖率最终只能提高到28%，主要 就是受水和自然条件的限制。在这方 面，近期颁布的天然林保护二期工 程规划已经将“南水北调”工程所辖 的11个县全部纳入到保护当中。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33018639554587265,
      0.3236015909283236,
      0.4628419268942145,
      0.4407209951764407
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 21
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_26",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.18203824739772453,
      0.3242785817043243,
      0.31469377874606635,
      0.3401878649403402
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 22
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_38",
    "text": "300年太久，只争朝夕",
    "canon_role": "section_header",
    "bbox": [
      0.4851125635439361,
      0.3263095540323263,
      0.7363834422657952,
      0.34763476347634764
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 23
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_19",
    "text": "本报记者黄朝武",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03292181069958848,
      0.328002030972328,
      0.1665456305979182,
      0.33680291106033683
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 24
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_61",
    "text": "新华社记者蔡敏",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8980876301137739,
      0.3351104341203351,
      0.9668361171629145,
      0.3432343234323432
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 25
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_27",
    "text": "另外，气候变化对土地沙化的 影响也不可低估，气候变化可能会 引发干旱等极端气候，这对土地荒 漠化和沙化的影响非常严重。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.18203824739772453,
      0.34086485571634084,
      0.31469377874606635,
      0.3736989083523737
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 26
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_20",
    "text": "沙化土地持续净减但仍与目 标相差甚远",
    "canon_role": "section_header",
    "bbox": [
      0.034858387799564274,
      0.3449268003723449,
      0.1626724763979666,
      0.3618515697723618
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 27
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_39",
    "text": "黄朝武",
    "canon_role": "section_header",
    "bbox": [
      0.4841442749939482,
      0.3527121942963527,
      0.5127087872185911,
      0.3604975882203605
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 28
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_62",
    "text": "外聘专家 成为新沂农民智囊团",
    "canon_role": "section_header",
    "bbox": [
      0.8206245461147422,
      0.3564356435643564,
      0.9498910675381264,
      0.38013032072438013
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 29
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_21",
    "text": "最近公布的第四次全国荒漠 化和沙化监测成果表明，2005年 初至2009年底5年间，全国荒漠 化土地面积年均减少2491平方公 里，沙化土地面积年均减少1717 平方公里。荒漠化、沙化土地持 续净减少，土地荒漠化和沙化整 体得到初步遏制。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03389009924957637,
      0.3655750190403656,
      0.1665456305979182,
      0.4319201150884319
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 30
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_40",
    "text": "我国荒漠化、沙化土地连续5 年净减少，这是一个令人兴奋的 好消息。这表明党中央、国务院 采取的一系列重大政策措施，实 施的防沙治沙重点工程，以及沙 区广大人民群众所做的艰苦努 力，均取得了巨大成效。也说明， 只要持之以恒地开展防沙治沙工 作，土地荒漠化和沙化最终是可 治、可控的。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4822076978939724,
      0.3665905052043666,
      0.6119583635923506,
      0.4498603706524499
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 31
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_42",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6279351246671508,
      0.36692900059236694,
      0.757201646090535,
      0.38283828382838286
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 32
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_28",
    "text": "“按照《国家林业发展战略》 提出的到2020年治理一半全国可 治沙化土地的要求还有巨大的差 距。”刘拓说，在第四次全国荒漠 化和沙化监测结果出来以后，对 荒漠化成因和下一步防治对策已 经有了系统的研究，国家林业局 将按照依法防治、科学防治和综 合防治的方针加大力度，因为“防 沙治沙已刻不容缓”。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.18155410312273057,
      0.37403740374037403,
      0.31420963447107236,
      0.45764576457645767
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 33
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_43",
    "text": "我国荒漠化和沙化土地面积 较大，分布区域较广，在这些地区 生态状况比较脆弱，经济发展受 到制约，亟须加大治理力度和加 快治理速度。因此，如果能将可 治的沙化土地在一定时期尽快治 理好并保证不反弹，不仅将给当 地生态和经济发展带来巨变，而 且对于保障整个粮食生产安全、 其他用途用地和国土生态安全， 以及整个国民经济健康发展都具 有重要的现实意义。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6274509803921569,
      0.3841922653803842,
      0.757685790365529,
      0.4826944232884827
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 34
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_63",
    "text": "眼下虽已进入严冬，可江苏省新沂市 瓦窑镇吕庄村农民的温室蔬菜大棚内却 温暖如春，黄瓜、菜花、番茄……一茬茬新 鲜蔬菜换来大把钞票。菜农笑逐颜开，因 为自己有专家指导，让他们每亩有了4万 元左右收入。农民所说的专家，是政府从 山东寿光聘请来的技术员杨云旺。他每 天都要到村里大棚转一转，手把手教农民 种地。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8201404018397482,
      0.39231615469239234,
      0.9866860324376664,
      0.46746213082846744
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 35
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_22",
    "text": "面对这样的成绩，国家林业 局防沙治沙办公室主任刘拓在接 受记者采访时一点也不显得轻松： “我国沙化土地防治任务很重，现 在173万平方公里沙化土地中，可 治理面积有53万平方公里，按照现 在每年缩减1717平方公里的速度， 大概需要300年左右时间。”",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03389009924957637,
      0.4325971058644326,
      0.16702977487291212,
      0.49894220191249894
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 36
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_33",
    "text": "此外，在一些水源易受危害的 地区，也要组织植树造林。对于北 方极度干旱的地区，首先是按照自 然规律植树造林，保护已有的天然 植被。过去中央明令禁止采伐所 有干旱地区天然林，第二期天然林 保护规划继续维持该政策。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33018639554587265,
      0.44105949056444105,
      0.4623577826192205,
      0.4992806973004993
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 37
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_41",
    "text": "但按照目前的速度，53万平 方公里可治沙化土地竞然需要 300年左右时间，距离中央提出的 目标有着遥远的差距。如此的“节 奏”和“步伐”，不免让人在兴奋之 时又颇感失望。个中原因，既有不 以人的意志为转移的自然因素在 作祟，也有大量的人为因素在推 波助澜，其结果还有可能使目前 的防沙治沙成果出现反弹。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4822076978939724,
      0.4505373614284505,
      0.6119583635923506,
      0.5175594482525175
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 38
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_29",
    "text": "沙化治理必须依据当地水资 源条件",
    "canon_role": "section_header",
    "bbox": [
      0.1830065359477124,
      0.46204620462046203,
      0.31082062454611475,
      0.47897097402047895
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 39
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_64",
    "text": "看到政府聘请的技术专家很给力，现 在，新沂有些种植大户干脆自己聘请。新 沂市邵店镇邵西村农民曹广平一个人拥有 鲜切花温室大棚120个，为种植好鲜切花， 她以年薪9.4万元从山东聘请赵贵芬和邢 卫国两位技术员，筛选出一批适合本地种 植的扶郎、郁金香、白菊等品种，摸索出控 制花期的技术，让鲜花在市场紧俏的时候 开，从而获得最大效益，亩均产值4万多元。 当地政府也给予扶持，投入300余万元对 鲜切花种植基地进行道路硬化、水电设施 配套改造等。目前，曹广平生产的鲜切花 不仅销售到上海、南京、青岛等地，还吸引 了韩国和日本客商。 满东广",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8201404018397482,
      0.46813912160446813,
      0.9862018881626725,
      0.5852585258525853
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 40
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_30",
    "text": "“荒漠化与候变化是个 互为反馈的问题，国内外专家对 此深人研究得出的结论是：荒漠 化的过程是一个碳源的过程，荒 漠化防治的过程是一个碳汇的过 程。”国家林业局副局长祝列克接 受记者采访时说，专家们对此有 一些模拟的试验，在理论上，如果 气温升高一度，荒漠化可能会增 加17%。这说明，在气温较高的干 旱地区，治理荒漠化难度非常大。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.18203824739772453,
      0.4826944232884827,
      0.31469377874606635,
      0.5747651688245747
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 41
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_44",
    "text": "尽管防沙治沙“路”不好走， 但只要以只争朝夕的劲头加快“节 奏”大踏步走下去，终究会走出一 条人与生态和谐发展的大道。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6279351246671508,
      0.48404840484048406,
      0.757201646090535,
      0.5172209528645172
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 42
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_23",
    "text": "究其原因，刘拓说，我国生态 的承载能力只有世界平均水平的 1/3，而现在人口、牲口、灶口这“三 口”问题仍十分突出，一些地方滥开 垦、滥放牧、滥樵采和不合理利用水 资源等破坏植被行为依然存在。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03389009924957637,
      0.49961919268849964,
      0.16702977487291212,
      0.5493780147245494
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 43
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_34",
    "text": "增加林草植被是防治沙尘暴 有效办法",
    "canon_role": "section_header",
    "bbox": [
      0.33067053982086664,
      0.504019632732504,
      0.45848462841926896,
      0.5202674113565202
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 44
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_35",
    "text": "既然我国土地荒漠化和沙化 已经得到初步遏制，为何许多地方 沙尘暴和沙尘天气仍然时有发生?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33067053982086664,
      0.5246678514005246,
      0.4623577826192205,
      0.549039519336549
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 45
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_45",
    "text": "发生的动力条件和物质条件。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.47833454369402084,
      0.5317762545485317,
      0.5809731299927379,
      0.5395616484725395
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 46
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_47",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6255144032921811,
      0.5317762545485317,
      0.7581699346405228,
      0.564948802572565
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 47
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_46",
    "text": "目前沙尘暴的发生呈波动式 递减。类对流、大风等然 现象是无法控制的，能够控制的 是尘源，沙尘暴的递减说明了沙 尘源的减少。这给了我们个重 要的启示，增加林草植被是减轻 沙尘暴危害、减少沙尘暴发生的 一种有效的办法。专家研究表 明，在同等气候条件下，林草植被 盖度达到40%以上，风沙活动就不 显著；如果林草植被盖度在15%- 40%，有局部的风沙活动；低于 15%的林草植被盖度，沙尘暴活动 就比较频繁。例如，京津风沙源 区通过10年的建设，林草植被由 44%提升至55%，沙尘暴由过去的 加强区变成了现在的减弱区。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4773662551440329,
      0.5405771346365406,
      0.6105059307673687,
      0.6488956587966489
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 48
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_36",
    "text": "刘拓解释说，沙尘暴是一种自然 现象，就像台风、冰雹一样，属于一种 自然的灾害性天气，不可能消灭。我 国是世界四大沙尘暴频发区之一， 也是中亚地区的沙尘暴频发区。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33067053982086664,
      0.5500550055005501,
      0.46187363834422657,
      0.5906744520605907
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 49
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_24",
    "text": "在投入方面严重不足，与实 际需求相比差距巨大。当前实行 的集中连片重点治理，只有京津 风沙源治理工程属于集中连片、 集中投入的，但京津风沙源只占 全国沙化土地的1/17。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03340595497458242,
      0.5503935008885504,
      0.16702977487291212,
      0.5991368367605991
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 50
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_48",
    "text": "针对有提出沙尘暴在3000 米的高空，植树造林能否起作用 的疑问，刘拓说，沙尘暴的传送是 一个跳跃式的传送过程，有起尘， 有尘降。在起尘的地方，如果林 草植被盖度不高，就有利于起尘； 在尘降的过程中，如果地表比较 平滑、森林植被比较少，可能就会 反弹，而如果遇到森林植被比较 茂密的地方，它就会被抑制。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6255144032921811,
      0.5656257933485657,
      0.7586540789155168,
      0.6488956587966489
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 51
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_31",
    "text": "另外，我国水资源相对紧缺， 尤其是北方很多地方缺水比较严 重。这对于荒漠化和沙化比较严 峻的北方来说，通过植树造林防 治荒漠化和沙化面临着更为不利 的局面，因为没有大量的水资源 可以利用。对此，有人提出，“南 水北调”工程给植树造林带来哪 些积极作用?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.18203824739772453,
      0.5747651688245747,
      0.31469377874606635,
      0.6502496403486503
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 52
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_37",
    "text": "这是由我国所处的特殊的土 地结构和特殊的地理位置所决定 的：北方地区有170多万平方公里的 沙化土地，在周边蒙古、哈萨克斯坦 等国也分布着200多万平方公里的沙 化土地，而且我国经常受到西伯利亚 冷空气的人侵。这就具备了沙尘暴",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33018639554587265,
      0.5916899382245917,
      0.4628419268942145,
      0.6505881357366506
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 53
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_65",
    "text": "华中农大助力 湖北公安县发展",
    "canon_role": "section_header",
    "bbox": [
      0.823045267489712,
      0.5977828552085978,
      0.9242314209634471,
      0.6218160277566218
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 54
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_25",
    "text": "土地沙化危害既有显性的， 也有隐性的，并且隐性的影响比 显性的影响可怕得多。沙化危害 还具有倍增性、滞后性和系统 性。但是在认识上，有些地方对 治沙重要性、紧迫性和艰巨性还 有较大差距，“说起来重要，做起 来次要”。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03292181069958848,
      0.6001523229246002,
      0.16702977487291212,
      0.6505881357366506
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 55
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_66",
    "text": "2010年12月16日，华中农业大学副校 长陈兴荣与湖北公安县县长周昌俊签署了 校县全面合作框架协议。另有相关学院20 多名专家教授分别与公安县相关企业负责 人签订了13个农业项目合作协议。湖北 省政协副主席陈春林、中科院院士张启发 等出席签约仪式。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8206245461147422,
      0.6343403571126344,
      0.9876543209876543,
      0.6925615638486926
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 56
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_49",
    "text": "东阳香榧驶上“科技快车道”",
    "canon_role": "section_header",
    "bbox": [
      0.020334059549745823,
      0.676990776000677,
      0.28564512224642946,
      0.6949310315646949
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 57
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_57",
    "text": "7 O e",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33067053982086664,
      0.678006262164678,
      0.6986201888162672,
      0.8543623593128543
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 58
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_67",
    "text": "现有葡萄种植户9000多户、“经纪人” 200余名的公安县埠河镇，相继被确定为 国家星火富民工程万亩无公害葡萄生产 基地、中国农村科普示范基地、中国葡萄 科普示范基地和湖北省科技创新葡萄生 产基地，急需园艺林学专家在“葡萄优质 苗木繁育技术”等方面给予指导。位于夹 竹园镇陈榨村的一家畜禽生态养殖园，向 该校多个领域的专家提出了技术需求，抛 出渴望合作的“橄榄枝”。崇湖渔场则希 望在“大宗淡水鱼类产业技术体系”方面， 进一步依托学校的科研力量展开合作。 专家们将把这些农业发展问题“打包”带 回学校研究。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8201404018397482,
      0.6932385546246932,
      0.9866860324376664,
      0.8093424727088093
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 59
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_54",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.17041878479786976,
      0.705085893204705,
      0.3093681917211329,
      0.7463823305407464
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 60
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_50",
    "text": "本报记者蒋文龙",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01646090534979424,
      0.7091478378607091,
      0.16025175502299685,
      0.717948717948718
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 61
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_51",
    "text": "从15年结籽缩短到6年结籽， 原本丢弃的废果如今可以提炼精 油，东阳香框依靠科技，终于驶上了 产业发展的“快车道”。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.722010662604722,
      0.1549261679980634,
      0.7548447152407548
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 62
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_58",
    "text": "1月9日，北京 百年农工子弟职业 学校酒店服务专业 学生郝虹霞(右一) 在试穿获赠的羽绒 服。当日，和谐北 京·温暖之都— 北京共青团“两节 送温暖\"项目发布 暨关爱打工子弟暖 春行动在该校举 行，社会各界为学 校的孩子们捐赠 羽绒服等物品。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7044299201161947,
      0.7223491579927224,
      0.775599128540305,
      0.8414995345688415
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 63
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_55",
    "text": "“过去种香框时间长、产量低、 废果多，大家不愿种。现在采用了 新科技，经济效益有了保障。”当地 宅口村村委会主任金晓阳算了一笔 账：这几年，香框干果每公斤可以卖 到200~300元，青果要卖20~30 元。一亩地可种30株树，按一株树 采摘50公斤青果计算，一株香框保 守估计也有上千元收益。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.17090292907286372,
      0.747059321316747,
      0.3093681917211329,
      0.8218668020648219
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 64
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_52",
    "text": "浙江东阳市是香框的原产地， 被国家林业局命名为“中国香框之 乡”。前全市已建成香榧基地6.1 万亩，年产香框干果360多吨，产值 达1.01亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01646090534979424,
      0.7558602014047558,
      0.15541031227305738,
      0.7968181433527968
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 65
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_53",
    "text": "为培育扶持东阳榧这一特 色农产品，近年来，该市启动《万 亩优质高效香框基地总体规划》 和《万亩优质早实香框示范基地 建设项目实施方案》，并推行一系 列鼓励措施：每年拨出资金400余 万元，鼓励农民种植香框。又通过 选用早实品种、坚持壮苗浅栽、摘 顶修枝等新办法，有效地缩短了香 榧的幼年期，实现了香框6年生即 有收、20年株产超60千克的丰产 目标。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01646090534979424,
      0.7974951341287975,
      0.1558944565480513,
      0.8563933316408564
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 66
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_68",
    "text": "本报记者何红卫通讯员胡今天",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8346647300895667,
      0.8103579588728104,
      0.9668361171629145,
      0.8184818481848185
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 67
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_56",
    "text": "据悉，东阳市还制定了未来十 年东阳香框产业规划，计划到2020 年全市香框总面积达到12万亩，总 产量达到3000吨，总产值9.5亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1718712176228516,
      0.8225437928408226,
      0.3093681917211329,
      0.856054836252856
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 68
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_69",
    "text": "华硕57款产品 围“电脑下乡”",
    "canon_role": "section_header",
    "bbox": [
      0.8206245461147422,
      0.8313446729288313,
      0.9213265553134834,
      0.855039350088855
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 69
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_59",
    "text": "新华社记者 罗晓光摄",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7150810941660615,
      0.8398070576288398,
      0.7654320987654321,
      0.856054836252856
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 70
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_80",
    "text": "2010年底，财政部、商务部、工信部联 合公布了家电下乡中标产品，华硕57款投 标产品全部入围。入围的57款产品涵盖 了笔记本、EeePC、台式机、E家族等多款产 品，价格覆盖了从2399元到4999元等多个 价位段。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8201404018397482,
      0.8679021748328679,
      0.9862018881626725,
      0.9173225014809173
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 71
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_70",
    "text": "专家为“十二五”博山有机农业发展出谋划策",
    "canon_role": "section_header",
    "bbox": [
      0.01888162672476398,
      0.873995091816874,
      0.6332607116920842,
      0.8997207413048998
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 72
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_74",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1718712176228516,
      0.9091986121689092,
      0.3113047688211087,
      0.9846830836929846
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 73
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_75",
    "text": "中国农业大学生态学教授、有 机农业专家吴文良告诉记者：“该规 划是长江以北地区第一个整建制有 机农产品生产区产业发展规划，将对 山东省以及其它地区有机产品发展 规划的编制具有示范作用。该规划 可使博山区的有机产品产业开发实 现生产、加工、贸易的全面发展，有利 于全面提高博山区有机产品生产、开 发、管理和产业化经营水平，提升其 农产品质量及市场竞争力。”",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3263132413459211,
      0.9091986121689092,
      0.46574679254417817,
      0.9846830836929846
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 74
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_76",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4807552650689906,
      0.9091986121689092,
      0.6206729605422416,
      0.9257848861809258
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 75
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_78",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6356814330670539,
      0.9095371075569095,
      0.775599128540305,
      0.9508335448929508
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 76
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_71",
    "text": "本报记者曹茸",
    "canon_role": "support_paragraph",
    "bbox": [
      0.015492616799806342,
      0.9135990522129136,
      0.15637860082304528,
      0.9220614369129221
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 77
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_81",
    "text": "据悉，57款各具特色的电脑产品充 分满足了农民用户的切实需要，让更多农 民朋友充分享受IT时代的信息化体验。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8206245461147422,
      0.917999492256918,
      0.9852335996126845,
      0.9427096555809427
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 78
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_72",
    "text": "日前，由中国农业大学资源与环 境学院牵头编写的《博山区整建制有机 农产品生产区产业发展规划》专家论证 会在北京举行。全国有机农业领域的 技术、管理和产业专家共同探讨“十二 五”期间博山区有机农业的发展之路。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01646090534979424,
      0.9257848861809258,
      0.1568627450980392,
      0.9765591943809766
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 79
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_77",
    "text": "据介绍，博山区是山东省24处 纯山区县之一，农作物和林果种植 面积25万亩，平均海拔较高，空气清 新，水质优良，植被完整，土壤富含有 机质，且没有受到农药、化肥污染，基 本保持了原生态，发展有机农业具有 得天独厚的自然优势。目前，博山区 有机农业种植面积已达11万亩，成 为全国最大的有机桔梗生产基地、山 东省最大的有机中药材和有机猕猴 桃生产基地，有机农产品年销售收入 超过10亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4807552650689906,
      0.9264618769569265,
      0.6206729605422416,
      0.985021579080985
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 80
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_82",
    "text": "据介绍，公司还将为用户提供笔记本 产品独家LCD无亮点保证、7×24小时 400-600-6655电话技术咨询、2年全球联 保服务等，帮助农民用户排除购买电脑的 后顾之忧。 本报记者江娜",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8196562575647542,
      0.9433866463569434,
      0.9852335996126845,
      0.985021579080985
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 81
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_79",
    "text": "博山区区长刘荣喜表示，将按 照《规划》的精神，力争把博山区建 成一个集观光、旅游、生态、高效为一 体的现代农业生产基地。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6361655773420479,
      0.9515105356689515,
      0.775599128540305,
      0.9843445883049844
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 82
  },
  {
    "chunk_id": "mineru_newspaper_0b86dae4d8f328a0e79d9ac394000dec_1_73",
    "text": "规划确定：山东淄博市博山区 通过5年左右的时间实现有机生产 的“345”工程，即有机种植面积达到 30万亩，整建制有机产品乡镇达到 4个，5大有机产品支柱产业全面发 展；提出建立有机产业支撑能力的 “1+6”工程，即建立1个中国（博山） 有机农业发展中心，配套建立与完善 组织管理、产业政策、人才培养、技术 集成、信息交流、产品营销6大体系。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.034858387799564274,
      0.9765591943809766,
      0.1549261679980634,
      0.9846830836929846
    ],
    "page": "newspaper_0b86dae4d8f328a0e79d9ac394000dec_1",
    "order": 83
  }
]
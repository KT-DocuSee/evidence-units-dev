  {
    "chunk_id": "mineru_yanbaor2_yanbaoPPT_2432_1",
    "text": "生态型商圈",
    "canon_role": "section_header",
    "bbox": [
      0.0951229343006852,
      0.2850220892119139,
      0.4111245465538089,
      0.3363260652700584

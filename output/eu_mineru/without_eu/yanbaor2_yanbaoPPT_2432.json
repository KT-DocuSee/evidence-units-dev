  {
    "chunk_id": "mineru_yanbaor2_yanbaoPPT_2432_8",
    "text": "立体化",
    "canon_role": "section_header",
    "bbox": [
      0.48125755743651755,
      0.6527005842952829,
      0.5828295042321644,
      0.678922616502779

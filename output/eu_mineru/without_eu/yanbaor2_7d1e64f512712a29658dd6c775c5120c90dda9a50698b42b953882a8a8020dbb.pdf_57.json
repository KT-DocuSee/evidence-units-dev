  {
    "chunk_id": "mineru_yanbaor2_7d1e64f512712a29658dd6c775c5120c90dda9a50698b42b953882a8a8020dbb.pdf_57_4",
    "text": "成时间：2018年4",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03749531308586427,
      0.3511111111111111,
      0.17747781527309087,

      0.38669301712779974,
      0.8854748603351955,
      0.44598155467720685
    ],
    "page": "notes_f7f010b78016aeebd76e56d9283eb67f_51",
    "order": 5
  },
  {
    "chunk_id": "mineru_notes_f7f010b78016aeebd76e56d9283eb67f_51_5",
    "text": "(3)表示某类人或事物中的任何一个.",
    "canon_role": "support_paragraph",
    "bbox": [

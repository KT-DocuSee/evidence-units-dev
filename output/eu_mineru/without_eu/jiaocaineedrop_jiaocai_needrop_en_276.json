[
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_276_0",
    "text": "蕉扇，幌一幌，一扇阴风，把行者扇得无影无形，莫想收留得住。这罗刹得胜回归。",
    "canon_role": "support_paragraph",
    "bbox": [

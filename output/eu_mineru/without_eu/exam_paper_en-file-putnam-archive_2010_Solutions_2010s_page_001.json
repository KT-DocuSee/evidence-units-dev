  {
    "chunk_id": "mineru_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_1",
    "text": "Kiran Kedlaya and Lenny Ng",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4,
      0.11393939393939394,
      0.6070588235294118,

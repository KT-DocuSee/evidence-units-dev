      0.8096969696969697,
      0.9192156862745098,
      0.8684848484848485
    ],
    "page": "exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001",
    "order": 23
  },
  {
    "chunk_id": "mineru_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_19",
    "text": "A-4 Put",

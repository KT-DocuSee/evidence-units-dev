    "order": 7
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2991_7",
    "text": "（麦秆） 现代 东",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6250285975749257,
      0.5143229166666666,
      0.8272706474490963,
      0.5286458333333334
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_2991",
    "order": 8
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2991_8",
    "text": "这是件完全麦秸秆编结 的，形态精准，简练概括， 动传神。作者抓住了这种动物 鲜明的特征：修颀而矫健的体 和弯弯的。尽管材料极端寻 常，然丝毫无损其超的艺术 水平。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6231983527796843,
      0.529296875,
      0.8730267673301304,
      0.6321614583333334

  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2002_3",
    "text": "23.阅读下的材料，根据要求写篇议论。(50分)",
    "canon_role": "support_paragraph",
    "bbox": [
      0.15155179363160015,
      0.3386062419837537,

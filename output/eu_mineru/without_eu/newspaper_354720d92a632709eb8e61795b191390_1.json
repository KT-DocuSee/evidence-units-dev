    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3887678528201404,
      0.18244901413218245,
      0.5219075284434762,
      0.1986967927561987
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 7
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_21",
    "text": "",
    "canon_role": "support_paragraph",

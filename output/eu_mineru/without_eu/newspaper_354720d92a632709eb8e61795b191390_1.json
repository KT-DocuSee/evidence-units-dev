      0.34086485571634084
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 8
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_24",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6855482933914306,
      0.18244901413218245,
      0.8182038247397725,
      0.3997630532283998
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 9
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_28",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8336964415395788,
      0.18244901413218245,
      0.9653836843379328,
      0.2156215621562156
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 10
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_17",
    "text": "全会认为，过去的一年，在党 中央、国务院坚强领导下，各级党 委、政府和纪检监察机关认真贯 彻落实党的十七届三中、四中、五 中全会以及第十七届中央纪委第 五次全会和国务院第三次廉政工 作会议精神，加强对中央重大决 策部署贯彻落实情况的监督检 查，坚决查处违纪违法案件，着力 解决反腐倡廉建设中人民群众反 映强烈的突出问题，加强党的作 风建设，纠正损害群众利益不正 之风，加大对领导干部的教育和 监督力度，深人推进反腐倡廉制 度建设和改革创新，进一步落实 《建立健全惩治和预防腐败体系 2008—2012年工作规划》，党风廉 政建设和反腐败工作取得新的明 显成效，为全面做好党和国家各 方面工作发挥了重要保障和促进 作用。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.38925199709513436,
      0.19937378353219937,
      0.5223916727184701,
      0.3736989083523737
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 11
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_29",
    "text": "第三，严肃组织人事工作纪 律，确保地方党委换届工作健康 顺利进。严格执党政领导 部选拔任用工作有关规定，规范 和强化对拟提拔干部的廉政考 察，加强对《党政领导干部选拔任 用工作责任追究办法（试行）》等4 项监督制度落实情况的监督检 查。今年，地方各级党委开始集 中换届，要严明换届纪律，加强对 选人用人情况的监督检查，坚决 惩治跑官要官、买官卖官、拉票贿 选和突击提拔干部等行为。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8332122972645849,
      0.21596005754421596,
      0.9663519728879206,
      0.3239400863163239
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 12
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_13",
    "text": "中央纪委常委会主持了会 议。会议全面贯彻党的七和 十七届三中、四中、五中全会精 神，高举中国特色社会主义伟大 旗帜，以邓小平理论和“三个代 表”重要思想为指导，深入贯彻落 实科学发展观，回顾总结了2010 年党风廉政建设和反腐败工作， 研究部署了2011年任务。全会审 议通过了贺国强同志代表中央纪 委常委会所作的《坚持改革创新， 狠抓工作落实，努力取得党风廉 政建设和反腐败斗争新成效》的 工作报告。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24158799322198016,
      0.2240839468562241,
      0.3747276688453159,
      0.34086485571634084
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 13
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_3",
    "text": "柯城区助农进京卖柑橘",
    "canon_role": "section_header",
    "bbox": [
      0.016945049624788187,
      0.28365913514428365,
      0.17041878479786976,
      0.2961834645002962
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 14
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_4",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.016945049624788187,
      0.3063383261403063,
      0.1830065359477124,
      0.38486925615638484
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 15
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_30",
    "text": "第四，加强基层党风廉政建 设，着力解决发生在群众身边的 腐败问题。深推进基层事务公 开和透明，认真落实《关于党的基 层组织实行党务公开的意见》， 加大政务公开、司法公开、厂务 公开、村务公开和公共企业事业 单位办事公开力度。加强对基 层干部的教育、管理和监督，严 肃查处少数基层干部滥用职权、 涉黑涉恶、侵吞国家和集体财产 等行为。加大对损害群众利益 行为的问责力度，坚决纠正对群 众疾苦漠不关、对群众呼声置 若罔闻、对群众利益麻木不仁， 甚至与民争利、以权谋私的行 为。畅通群众反映问题、表达合 理诉求的渠道，充分发挥广大群 众的监督作用。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8332122972645849,
      0.324955572480325,
      0.9663519728879206,
      0.483032918676483
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 16
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_14",
    "text": "中共中央总书记、国家主席、 中央军委主席胡锦涛出席全会第 二次会并发表了重要讲话。吴 邦国、温家宝、贾庆林、李长春、习 近平、贺国强、周永康等党和国家 领导人出席了会议。有关方面的 负责同志参加了会议。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24158799322198016,
      0.34154184649234154,
      0.37424352457032195,
      0.39942455784039943
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 17
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_22",
    "text": "第二，以保持党同人民群众 血肉联系为重点，扎实推进党的 作风建设。坚持以人为本、执政 为民，大力弘扬密切联系群众的 优良作风，认真落实中央关于加 强和改进群众工作的各项要求， 加强对党的群众路线执行情况的 监督检查，督促领导干部带头做 好群众工作，进一步密切党群干 群关系。大力弘扬求真务实和艰 苦奋斗的优良作风，坚决克服官 僚主义、形式主义、弄虚作假、铺 张浪费等问题，认真落实中央有 关厉行节约的规定。大力弘扬批 评和自我批评的优良作风，坚决 反对上下级和干部之间逢迎讨 好、互相吹捧等庸俗作风，始终保 持共产党人的蓬勃朝、昂扬锐 气、浩然正气。认真落实农村基 层干部廉洁履行职责的有关规 定，加强农村集体资金、资产、资 源管理。加强对国有企业“三重 ”决策制度执情况的监督 检查，严格执行《国有企业领导人 员廉洁从业若干规定》。扎实推 进高等学校和城市社区党风廉政 建设。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5369160009682885,
      0.34221883726834224,
      0.6715081094166061,
      0.5666412795125666
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 18
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_18",
    "text": "全会提出，全党必须深刻认 识反腐败斗争的长期性、复杂性、 艰巨性，以更加坚定的信心、更加 坚决的态度、更加有力的措施，扎 实推进反腐倡廉各项工作，不断 取得党风廉政建设和反腐败争 的新成效。2011年，要全面贯彻 党的十七大和十七届三中、四中、 五中全会精神，高举中国特色社 会主义伟大旗帜，以邓小平理论 和“三个代表”重要思想为指导， 深入贯彻落实科学发展观，坚持 标本兼治、综合治理、惩防并举、 注重预防的方针，认真执行党风 廉政建设责任制，加强以保持党 同人民群众血肉联系为重点的 作风建设，加强以完善惩治和预 防腐败体系为重点的反腐倡廉 建设，着力解决反腐倡廉建设中 人民群众反映强烈的突出问题， 围绕中心、服务大局，突出重点、 整体推进，改革创新、狠抓落实， 不断提高反腐倡廉建设科学化 水平，为顺利实施“十二五”规 划、促进经济社会又好又快发展 提供有力保证，以党风廉政建设 和反腐败斗争的新成效迎接建党 90周年。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.38925199709513436,
      0.3757298806803757,
      0.524328249818446,
      0.6086147076246086
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 19
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_15",
    "text": "全会认真学习了胡锦涛同志 的重要讲话，一致认为，讲话从党 和国家事业发展全局和战略的高 度，全面总结了党风廉政建设和 反腐败斗争取得的成效和经验， 科学分析了当前的反腐倡廉形 势，明确提出了今年党风廉政建 设和反腐败工作的主要任务，深 刻阐述了切实把以人为本、执政 为民贯彻落实到党风廉政建设和 反腐败斗争之中的重要性、紧迫 性以及总体要求、工作重点，强调 要把实现好、维护好、发展好最广 大人民根本利益作为一切工作的 出发点和落脚点，坚持权为民所 用、情为民所系、利为民所谋，着 力加强以人为本、执政为民教育， 着力建立健全体现以人为本、执 政为民要求的决策机制，着力按 照法律法规和政策开展工作，着 力维护人民群众权益，着力查处 损害群众切身利益的案件，着力 加强基层干部队伍作风建设，以 党风廉政建设和反腐败争的实 际成效取信于民。胡锦涛同志的 重要讲话，是指导当前和今后一 个时期党风廉政建设和反腐败 争的纲领性文献，对于深入推进 党的作风建设和反腐倡廉建设， 推动全面做好党和国家各项工 作、顺利完成“十二五”时期经济 社会发展目标任务具有重大而深 远的意义。全党同志特别是广大 纪检监察干部一定要认真学习领 会，坚决贯彻落实。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2411038489469862,
      0.3997630532283998,
      0.3747276688453159,
      0.675975289836676
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 20
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_26",
    "text": "全会指出，要抓住热点、破解 难点，集中力量解决反腐倡廉建 设中人民群众反映强烈的突出问 题，着重在以下四个方面下功夫：",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6855482933914306,
      0.4004400440044004,
      0.8177196804647785,
      0.43327409664043326
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 21
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_5",
    "text": "近日，浙江省衢州市柯城区区长等人 来到北京新发地农产品批发市场调研“衢 州碰柑”市场销售情况。同时，还帮助销售 商解决市场行为当中遇到的疑难问题。图 为柯城区澳林奇柑橘专业合作社负责人卢 志成(右一)在向区领导介绍精品碰柑的推 广和销售情况。本报记者徐华摄",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01646090534979424,
      0.40077853939240077,
      0.18349068022270637,
      0.4596767369044597
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 22
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_25",
    "text": "第一，深人推进专项治理工 作，努力遏制消极腐败现象和不 正之风在一些领域易发多发的 势头。深化工程建设领域突出 问题专项治理，严肃查处违规项 目审批、规划调整以及规避招 标、虚假招标、转包、违法分包等 问题，严肃查办在土地矿产资源 审批、项目实施、工程质量、资金 使用、政府采购及执纪执法中的 案件。深化“小金库”专项治理， 巩固治理成果，建立长效机制。 认真开展庆典、研讨会、论坛过多 过滥问题专项治理和公务用车问 题专项治理。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6850641491164366,
      0.4329356012524329,
      0.8182038247397725,
      0.5578403994245579
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 23
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_6",
    "text": "宁夏将举办 型休闲化贺岁活动",
    "canon_role": "section_header",
    "bbox": [
      0.016945049624788187,
      0.4755860201404756,
      0.16993464052287582,
      0.5009731742405009
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 24
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_31",
    "text": "全会要求，各级党委、政府要 认真落实党风廉政建设责任制，坚 持和完善反腐败领导体制和工作 机制，进一步形成全党动手抓党风 廉政建设和反腐败工作的合力。 各级纪检监察机关要全面履行纪 检监察两项职能，加大改革创新力 度，努力提高反腐倡廉建设科学化 水平，大力加强自身建设，统一思 想、振奋精神，兢兢业业、尽职尽 责，真抓实干、务求实效，认真抓好 反腐倡廉各项任务的落实。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8332122972645849,
      0.4837099094524837,
      0.9658678286129266,
      0.5828890581365829
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 25
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_7",
    "text": "本报讯(记者张国凤)为丰富卯春 节节日休闲旅游文化商业活动，由宁夏自 治区文明办公室、财政厅、旅游局主办的 “我们的节日·辛卯春节—宁夏旅游休 闲贺岁嘉年华活动”，活动将于1月26日 至217在银川市宁夏农博园举办。 据了解，这是宁夏首次举办大型综合性新 春贺岁休闲活动。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.5165439620885165,
      0.18349068022270637,
      0.5828890581365829
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 26
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_27",
    "text": "第二，认真落实《中国共产党 党员领导干部廉洁从政若干准 则》，着力解决党员领导干部在廉 洁自律方面存在的突出问题。全 面落实《关于领导干部报告个人 有关事项的规定》和《关于对配偶 子女均已移居国（境）外的国家工 作人员加强管理的暂行规定》。 坚决整治领导干部违规收受礼金 问题。巩固党政机关厉节约、 制止奢侈浪费工作成果，建立健 全禁止公款出国(境）旅游长效机 制，认真执行关于党政机关国内 公务接待的管理规定，继续严格 控制党政机关办公楼等楼堂馆所 建设。继续认真治理违反规定多 占住房、买卖经济适用房或租赁 廉租住房等问题。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6850641491164366,
      0.5588558855885588,
      0.8182038247397725,
      0.6756367944486756
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 27
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_23",
    "text": "第三，以完善惩治和预防腐 败体系为重点，整体推进反腐倡 廉各项工作。加强对领导干部的 教育和监督，深入开展示范教育、 警示教育和岗位廉政教育，推进 廉政文化建设；认真贯彻执行党 内监督条例，深入推进巡视工作， 坚持党内监督与党外监督、专门 机关监督与群众监督相结合，重 视发挥新闻舆论的监督作用，全 面推行廉政风险防控管理及行政 权力、公共服务公开透明运行，积 极推广“制度+科技”等预防腐败 经验，加强纪检监察派驻机构对 驻在部门领导班子及其成员的监 督。加大查办违纪违法案件工作 力度，严肃查办发生在领导机关 和领导干部中贪污贿赂、失职渎 职案件，重点领域和关键环节中 的违纪违法案件，严重违反政治 纪律和组织人事纪律的案件，重 大责任事故和群体性事件涉及的 失职渎职及背后的腐败案件；严 肃查办商业贿赂案件，发生在基 层政权组织和重点岗位以权谋 私、滥用职权的案件，以案谋私、 贪赃枉法和为黑恶势力充当“保 护伞”等案件。坚决纠正损害群 众利益的不正之风，重点解决征 地拆迁、住房保障、食品药品安 全、环境保护、安全生产等方面损 害群众利益的突出问题。深入推 进改革和制度创新，深化行政管 理体制、干部人事制度、司法体制 和工作机制改革，深化财税管理 体制、投资体制、金融体制和国有 资产管理体制改革，建立健全防 止利益冲突制度，推进公共资源 交易统一规范管理。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5374001452432825,
      0.566979774900567,
      0.6700556765916243,
      0.6756367944486756
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 28
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_8",
    "text": "据介绍，活动主题是“玉兔临塞上、欢 乐闹新春”，具体内容包括6大主题展区， 分别是：贺岁祈福馆、欢乐嘉年华游乐馆、 民俗年货馆、品质生活大卖场、迎春花市和 绿色食品馆、辛卯春节迎喜大庙会。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.5839045443005839,
      0.1839748244977003,
      0.6255394770246255
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 29
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_32",
    "text": "全会增选吴玉良同志为中央 纪委副书记。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8336964415395788,
      0.5842430396885843,
      0.9648995400629388,
      0.5998138275365998
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 30
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_33",
    "text": "全会号召，全党同志要更加 紧密地团结在以胡锦涛同志为总 书记的党中央周围，开拓进取，狠 抓落实，不断取得党风廉政建设 和反腐败斗争新成效，为夺取全 面建设小康社会新胜利、开创中 国特色社会主义事业新局面作出 应有贡献！",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8332122972645849,
      0.6004908183126005,
      0.9663519728879206,
      0.6668359143606668
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 31
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_19",
    "text": "全会强调，要统筹兼顾，整体 推进党风廉政建设和反腐败斗争 各项长期性、基础性工作，着力抓 好以下三个方面：",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3897361413701283,
      0.6089532030126089,
      0.5219075284434762,
      0.6417872556486418
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 32
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_9",
    "text": "张北县招商再唱“京戏” 引进投资8.25亿元",
    "canon_role": "section_header",
    "bbox": [
      0.01888162672476398,
      0.6421257510366422,
      0.17041878479786976,
      0.6671744097486672
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 33
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_20",
    "text": "第一，严明党的政治纪律，加 强监督检查，保证党的十七届五 中全会精神和中央重大决策部署 的贯彻落实。紧紧围绕科学发展 这个主题和加快转变经济发展方 式这条主线，对中央关于加强和 改善宏观调控、做好“三农”工作、 推进经济结构战略性调整以及市 场价格调控、房地产调控、规范和 节约用地、资源节约和环境保护、 保障和改善民生等重大决策部署 执行情况开展监督检查，继续抓 好对玉树、舟曲灾后恢复重建政 策落实情况的监督检查，加强对 中央关于西藏、新疆工作以及维 护民族团结和社会稳定决策部署 贯彻落实情况的监督检查，坚决 纠正有令不行、有禁不止的现象， 保证中央政令畅通，维护中央权 威。坚持把维护党的政治纪律摆 在首位，加强对政治纪律执行情 况的监督检查，坚决维护党的集 中统一。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.38925199709513436,
      0.6424642464246425,
      0.5214233841684822,
      0.6756367944486756
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 34
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_34",
    "text": "新华社北京1月11日电",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8530622125393367,
      0.6675129051366675,
      0.9474703461631566,
      0.6752982990606753
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 35
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_35",
    "text": "本报讯近日，“2011张北·北京项目推 介暨经济合作恳谈会”在北京市举。本次 招商会主题为“以会为媒，促进沟通，增进了 解，推动合作，实现共赢”，这是继广东招商 会后，该县招商再次对接北京唱“京戏”，共 签订投资项目9个，投资总额达8.25亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.6861301514766861,
      0.1839748244977003,
      0.7358889735127359
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 36
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_40",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.22367465504720407,
      0.7094863332487095,
      0.6642459452916969,
      0.9146145383769146
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 37
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_44",
    "text": "阜宁县现代农业看“三宝”",
    "canon_role": "section_header",
    "bbox": [
      0.692326313241346,
      0.7105018194127105,
      0.9784555797627693,
      0.7311500380807312
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 38
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_36",
    "text": "近年来，河北省张北县以“大招商、大开 放、大发展”的思路，不断拓展招商视野，创 新招商理念，转变项目招商方式，大力实施 请进来、走出去战略，掀起招商引资热潮。 此次签订的项目包括投资1.2亿元的建材产 品生产项目、投资1亿元的张北风光电影拍 摄及影视城建设项目、投资1亿元的北京食 品批发项目、投资1亿元的食用菌基地项 目、投资8500万元的薰衣草种植加工和旅 游项目。 单晓亮郭伟张扬",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.7365659642887366,
      0.1839748244977003,
      0.8201743251248201
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 39
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_45",
    "text": "本报讯（记者沈建华通讯员 邓正彬施玉森）养殖生态猪，连创 江苏生猪养殖第一县；种植有机稻， 让“阜宁大米”成为全国第二例以县 域命名的集体注册商标；种植绿色 西瓜，让农民成倍增收，创造出现代 农业发展新模式。这是记者近日在 苏北阜宁县采访时，对阜宁农产品 的“生态三宝”的深刻印象。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6894214475913822,
      0.741981890496742,
      0.8283708545146453,
      0.8171278666328171
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 40
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_48",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8433793270394577,
      0.741981890496742,
      0.981360445412733,
      0.7917407125327918
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 41
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_49",
    "text": "阜宁具有优越的自然条件，是 国家级一类生态示范区。该县坚持 把设施栽培作为高效农业的主体工 程。目前，全县高效农业面积50.51 万亩，其中设施农业面积12.3万 亩。2010年一季度全县新增设施农 业面积居全省第一。在农民专业合 作组织的带动下，阜宁县的西瓜生 产，实行统一推广优质品种，统一使 用无公害有机肥料，统一栽培技术 措施，统一西瓜品牌和包装，全县现 有西瓜栽培规模基地21个。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8428951827644638,
      0.7924177033087925,
      0.9818445896877269,
      0.891935347380892
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 42
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_46",
    "text": "前不久，记者来到阜宁县板湖 镇农民张光耀的万头猪场养殖小 区，一栏栏发酵床猪舍，不见粪便， 没有异味，干净清爽。张光耀告诉 记者，由于猪在这种接近自然生态 的发酵床上生活，自由拱食和运动， 可增强体质和免疫力。县林牧渔业 局副局长刘满昌介绍说，阜宁已成 为全国生态养猪规模最大的县，建 成发酵床40多万平方米，年出栏生 态猪60万头，现已形成发酵床益生 菌菌种扩繁基地、生态猪养殖基地、 生态猪加工基地、生态猪肉专营窗 口等一体化经营体系，连续14年卫 冕江苏省“猪第一县”。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6894214475913822,
      0.8174663620208175,
      0.8283708545146453,
      0.9420326648049421
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 43
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_37",
    "text": "(上接第一版)",
    "canon_role": "section_header",
    "bbox": [
      0.017429193899782137,
      0.8428535161208428,
      0.07116920842411038,
      0.8506389100448506
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 44
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_38",
    "text": "李长春在批示中指出，2010年，全国新 闻出版系统认真贯彻落实中央决策部署，高 举旗帜，服务大局，以改革创新精神全力推进 改革、发展、服务、管理等各项工作，新闻出版 体制改革取得重大成果，新闻出版产业继续 保持强劲发展势头，公共服务体系建设全面 提速，行政管理工作扎实高效，出版产品出口 和版权贸易实现新突破，在“十一五”收官之 年交出了一份优秀答卷。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01646090534979424,
      0.8516543962088516,
      0.1839748244977003,
      0.9257848861809258
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 45
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_50",
    "text": "为进一步加快农民增收致富步 伐，阜宁县不断加大农业产业招商、 农业龙头企业发展、农产品市场建 设和农产品品牌创建的激励扶持力 度和组织化水平。全县5个农产品 加工集中区已初具规模，新建、扩建 农产品专业批发市场13个，注册农 民经纪人724人。目前，阜宁农产 品“生态三宝”生产有基地，管理有 标准，销售有品牌，产销两旺，农民 增收致富的路子越走越宽广。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8428951827644638,
      0.8926123381568926,
      0.9818445896877269,
      0.9846830836929846
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 46
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_41",
    "text": "少林寺弟子施送“腊八粥”",
    "canon_role": "section_header",
    "bbox": [
      0.22561123214717985,
      0.9251078954049251,
      0.4720406681190995,
      0.943048150968943
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 47
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_39",
    "text": "李长春希望新闻出版系统坚持以科学 发展为主题，以转变发展方式为主线，开好 头、起好步，在深化改革方面继续走在文化 体制改革的前列，在加快发展方面继续当 好文化产业的主力军，坚持一手抓繁荣、一 手抓管理，为把我国建设成为新闻出版强 国而不懈奋斗。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01597676107480029,
      0.9264618769569265,
      0.18445896877269427,
      0.985021579080985
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 48
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_47",
    "text": "阜宁是农业大县，也是全国重 要的优质商品粮基地县。近年来， 阜宁县与农业高等院校和农业科技 企业合作，联手共建“超有机大米基 地”10万亩。所产的阜宁有机大米 家族的几个品牌，均通过中国绿色 食品发展中心验收，获得国家级绿 色食品标志。阜宁大米销售网点遍 布11个省的近百个县（市），年销售 额5亿元以上，农民种植有机水稻， 效益是普通水稻的两倍多。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6894214475913822,
      0.9427096555809427,
      0.8278867102396514,
      0.9846830836929846
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 49
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_42",
    "text": "1月11日，少林寺僧人向游客施送腊八粥。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.243040426046962,
      0.9521875264449522,
      0.4037763253449528,
      0.95997292036896
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 50
  },
  {
    "chunk_id": "mineru_newspaper_354720d92a632709eb8e61795b191390_1_43",
    "text": "当日是农历腊初，俗称“腊八节”。“腊八”还是佛祖释迦牟尼成道之日。佛教传我国后，寺院盛行“腊八” 煮粥敬佛。从2009年起，少林寺恢复这一传统佛事活动，开始向游客和登封的敬老院老人及孤儿院孤儿施粥。这 次向游客布施的“腊八粥”是少林药局的师父严格按照禅医古例熬出的，名为“少林五行腊八粥”。 新华社发",
    "canon_role": "support_paragraph",
    "bbox": [
      0.22464294359719197,
      0.9606499111449607,
      0.6647300895666909,
      0.986037065244986
    ],
    "page": "newspaper_354720d92a632709eb8e61795b191390_1",
    "order": 51
  }
]
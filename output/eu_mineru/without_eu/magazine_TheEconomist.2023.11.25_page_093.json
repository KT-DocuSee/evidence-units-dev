  {
    "chunk_id": "mineru_magazine_TheEconomist.2023.11.25_page_093_2",
    "text": "Top five",
    "canon_role": "section_header",
    "bbox": [
      0.056,
      0.5048445188454319,
      0.116,
      0.5182366965961548

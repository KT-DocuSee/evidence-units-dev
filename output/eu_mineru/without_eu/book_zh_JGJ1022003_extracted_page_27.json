  {
    "chunk_id": "mineru_book_zh_JGJ1022003_extracted_page_27_2",
    "text": "7.4.2全玻幕墙胶缝承载力应符合下列要求：",
    "canon_role": "support_paragraph",
    "bbox": [
      0.06959272439699486,
      0.18568232662192394,
      0.3368920521945433,

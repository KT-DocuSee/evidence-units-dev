  {
    "chunk_id": "mineru_yanbaopptmerge_SE17.pdf_10_1",
    "text": "Anticipation—A WebApp should be designed so that it anticipates the use's next move.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.09533333333333334,
      0.23644444444444446,
      0.9,
      0.31377777777777777

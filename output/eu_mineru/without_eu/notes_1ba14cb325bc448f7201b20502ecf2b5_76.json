  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_76_4",
    "text": "3.积极发展高新技术产业",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1087866108786611,
      0.44027640671273444,
      0.37656903765690375,
      0.4633102994406055

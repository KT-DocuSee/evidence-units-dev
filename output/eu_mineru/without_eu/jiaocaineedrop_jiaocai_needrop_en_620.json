      0.43870350436550654,
      0.858,
      0.45401267790934097
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_620",
    "order": 14
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_20",
    "text": "黎凝畅瞬猎 nàng = liè shùn",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7386666666666667,
      0.4597536179882789,
      0.888,
      0.5621337160626719
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_620",
    "order": 15
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_9",
    "text": "三、我喜欢连一连，还想把这些词语写下来。",

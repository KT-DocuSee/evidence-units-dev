[
  {
    "chunk_id": "mineru_newspaper_c9147e07a59fdd1194da22f2ec07dd1c_1_0",
    "text": "创新工作方法谋求突破发展",
    "canon_role": "section_header",
    "bbox": [
      0.02662793512466715,
      0.046035372768046035,
      0.7886710239651417,

      0.16112380468816112
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 7
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_9",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.46187363834422657,
      0.11982736735211982,
      0.6061486322924231,
      0.14453753067614453
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 8
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_1",
    "text": "本报记者李海涛",
    "canon_role": "section_header",
    "bbox": [
      0.08036794964899541,
      0.12422780739612423,
      0.1486322924231421,
      0.13235169670813235
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 9
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_17",
    "text": "在孝感，对符合农信社准入条件的客户，贷款额度 很宽松。目前，孝感市农信社共发放千万元以上贷款31 笔，金额7.79亿元，单户最高贷款额度2亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7823771483902203,
      0.132013201320132,
      0.9992737835875091,
      0.15604637386815604
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 10
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_2",
    "text": "银监会副主席蒋定之1219 日在“中国县域经济发展高层论 坛”上表示，银监会将引导更多信 贷资金流向县域经济、拓宽县域资 金来源渠道，加大扶持力度以提升 县域金融服务。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009682885499878963,
      0.13675213675213677,
      0.15298959089808764,
      0.18617246340018617
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 11
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_10",
    "text": "然而，与县域经济发展的现实需 要相比，县域金融服务仍存在较大的 差距。突出表现在：县域金融业务比 较效益低下，金融机构支持“三农”的 内生动力严重不足；县域金融组织体 系存在缺陷，金融市场竞争还不够充 分；县域金融机构自身建设滞后，支 农服务能力还难以满足多元化的县 域金融服务需求；县域金融监管资源 配置严重不足，差异化的监管制度安 排还有待完善；县域金融外部支持体 系不够健全，对县域金融机构正向激 励手段还需要进一步完善。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.46138949406923263,
      0.14521452145214522,
      0.6066327765674171,
      0.2531945502242532
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 12
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_18",
    "text": "今年，孝感市农信社的新增贷款时间最短为3个月 到期，最长为7年。贷款时间根据客户的需求可长可短， 随还随贷，周转使用，彻底改变了农信社“春放秋收冬不 贷”的习惯。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7828612926652142,
      0.15706186003215705,
      0.9992737835875091,
      0.18955741728018954
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 13
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_8",
    "text": "此外，在提高金融服务覆盖面 方面，银监会也进行了积极探索。 在全面调查的基础上，发布金融服 务地图集，锁定了金融服务的薄弱 区域，提出了用三年左右时间实现 基础金融服务全覆盖的工作目 标。各地银业金融机构因地制 宜，采取标准化网点与简易便民服 务相结合的方式，大力新增机构网 点，广泛布设POS机和ATM机，实 行流动或定时定点服务，有效扩展 了金融服务的覆盖面，使偏远地区 农村金融服务面貌发生了历史性 变化。截至2010年11月末，全国 已有10个省份实现了乡镇融服 务机构全覆盖，30个省份实现了乡 镇基础金融服务全覆盖，共计减少 服务空白乡镇732个，减少机构空 白乡镇579个。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3103364802711208,
      0.1618007954641618,
      0.45557976276930523,
      0.2955064737242955
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 14
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_13",
    "text": "蒋定之还指出，要适应县域经济 发展多层次、多元化服务需求，建立县 域金融协调服务机制，增强支持县域 经济发展的合力。引导大中型银行延 伸县域服务网络，创新适应县域经济 发展的信贷模式；大力发展农业保险 和农村小额保险，加强涉农信贷与涉 农保险合作；发展多种形式的融资担 保公司、基金和共同体，鼓励银行业金 融机构与各类担保公司合作，为县域 企业提供担保增信服务，促进县域信 贷投放增长；加快发展县域资本市场 和农产品期货交易；同时，还要规范发 展小额贷款公司和民间信用互助组 织，发挥其有益的补充作用。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6124425078673444,
      0.16958618938816958,
      0.757201646090535,
      0.2955064737242955
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 15
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_3",
    "text": "县域经济一头联着农村，肩负着 带动农业转型、农民转移和农村经济 结构转变的历史重任，一头联着城 市，为城市发展提供了丰厚的资源和 阔的市场。县域集中了我国3/4的 人口，吸纳了65%的农村劳动。“加 快县域经济发展，无疑是破解城乡二 元经济结构最具现实性意义的路径 选择，也是统筹推进城乡协调发展的 实质举措。”蒋定之说。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009198741224885015,
      0.18684945417618684,
      0.15347373517308158,
      0.2701193196242701
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 16
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_19",
    "text": "孝感市农信社为了满足城乡居民和中小企业信贷 需求，先后推出了农户保证贷款、商户保证贷款、中小企 业联保贷款、中小企业抵质押贷款等。目前已发放信用 类贷款2.59亿元，保证类贷款5亿元，联保类贷款3.8亿 元，抵押贷款18.36亿元，质押贷款1.63亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7814088598402323,
      0.1898959126681899,
      0.9997579278625031,
      0.2311923500042312
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 17
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_6",
    "text": "据蒋定之介绍，在确保银行业稳 健运行的前提下，银监会稳步推进农 村金融市场开放。在机构设立上，调 整放宽农村地区银行业金融机构准 入政策，鼓励引导各类资本设立村镇 银行等三类新型农村金融机构；在股 权投资上，放宽了投资金融机构的资 本地域限制，鼓励引进国内外战略投 资者，支持异地股东投资农村中小金 融机构；在经营地域上，允许股份制 商业银行和城市商业银行在县域设 立分支机构，支持符合条件的农村中 小金融机构跨区域设立县域分支机 构和新型农村金融机构；在持股比例 上，适当提高了自然人和法人对县域 金融机构的持股比例。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.15976761074800291,
      0.20377422357620378,
      0.3045267489711934,
      0.2955064737242955
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 18
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_20",
    "text": "眼下，孝感农信社准备变身农村商业银行，正大力推 行阳光信贷，服务质量不断提高，贷款方式更加灵活。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7828612926652142,
      0.23186934078023186,
      0.9983054950375212,
      0.24845561479224845
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 19
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_21",
    "text": "彭海清黎明",
    "canon_role": "support_paragraph",
    "bbox": [
      0.9300411522633745,
      0.2487941101802488,
      0.9823287339627209,
      0.25657950410425656
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 20
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_11",
    "text": "蒋定之表示，下一步，要不断拓 展县域资金来源渠道，大力提升县域 直接融资比例，支持优质企业通过发 行债券和上市融资等方式获得资金； 积极引导城市金融机构到县域设立 网点，出资组建贷款公司等贷款专营 机构，加大对县域信贷投放；鼓励设 立新型农村金融机构，建立大型银行 与县域法人银行的资金批发运用机 制，引导城市富余资金用于支持县域 经济发展。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.46187363834422657,
      0.25421003638825423,
      0.6066327765674171,
      0.2955064737242955
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 21
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_22",
    "text": "农行漯河分行全方位服务“万村千乡”",
    "canon_role": "section_header",
    "bbox": [
      0.7891551682401355,
      0.2670728611322671,
      0.9924957637375939,
      0.2907675382922908
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 22
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_4",
    "text": "记者了解到，预计到今年末，全国 银行业金融机构县域服务网点将达到 13万家左右，约占全国银行业金融机 构网点的2/3;县域贷款余额12.3万亿 元，在全国金融机构各项贷款余额的 占比超过25%。截至2010年9月末， 全国银行业涉农贷款余额11.1万亿 元，占全国金融机构各项贷款余额的 22%，其中农户贷款余额2.6万亿元， 占涉农贷款余额的23.1%。其中，作为 支农服务主力军的农村合作金融机 构，涉农贷款增量、增速和占比均高于 上年，全面实现“三个高于”目标。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009198741224885015,
      0.27045781501227045,
      0.15298959089808764,
      0.29584496911229585
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 23
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_35",
    "text": "自年初以来，农行河南漯河分行把“万村千乡”超市 作为支持农村商品流通的切入点，全方位推进金融服 务，取得了较好的经济效益和社会效益。截至目前，该 行共向“万村千乡”市场工程龙头企业投放贷款2000万 元，有力助推了农村商品流通网络建设。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7828612926652142,
      0.3009223999323009,
      0.9987896393125151,
      0.3428958280443429
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 24
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_34",
    "text": "网上卖菜 致富路宽",
    "canon_role": "section_header",
    "bbox": [
      0.3422900024207214,
      0.31446221545231445,
      0.6753812636165577,
      0.34086485571634084
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 25
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_23",
    "text": "刘香全的养牛“新”账",
    "canon_role": "section_header",
    "bbox": [
      0.011619462599854757,
      0.324955572480325,
      0.2270636649721617,
      0.3493272404163493
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 26
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_41",
    "text": "该积极与市商务局沟通，对“万村千乡”点进 全面走访，了解掌握其网点布局、金融机具布放、信贷资 金需求等情况，着力支持“万村千乡”龙头企业，充分发 挥其带动、保障作用，解决企业发展过程中配送资金周 转不足等问题。目前，支持的3家“万村千乡”市场工程 龙头企业已实现销售收入近2亿元，同比增加9%，实现 利税1560万元，同比增加12%，增设各类连锁网点290 个，总点已达到1600余家，解决员就业3300多。 同时，该行通过对“万村千乡”连锁超市进行全方位服 务，先后发放贷款近1000万元，向超市的商品供应农户 发放农户小额贷款近300万元，安装POS机、转账电话 200多部。 程小丽",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7823771483902203,
      0.3432343234323432,
      0.9997579278625031,
      0.4430904628924431
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 27
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_36",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.2541757443718228,
      0.34831175425234834,
      0.6661825223916727,
      0.5517474824405517
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 28
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_24",
    "text": "早听说山东齐河县焦庙镇小寨村的刘香全是周围 十里八乡出了名的养牛大户。12月17日，到他家一看， 果真名不虚传，奶牛是不少，但牛棚边却没有一堆堆的 牛粪。老刘看出我的心思，往地上一指：“沼气池。牲畜 的粪便都顺着流到沼气池里面了。”",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009682885499878963,
      0.35914360666835915,
      0.2270636649721617,
      0.4004400440044004
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 29
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_37",
    "text": "河南省社旗县 朱集镇王老庄村大 学生“村官”侯占磊 注重收集市场信息， 把蔬菜的品种、价格 等在网上发布，吸引 了南阳、驻马店等周 边10多个县市的客 商，让村民们足不出 村就把无公害蔬菜 销售出去。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6753812636165577,
      0.3726834221883727,
      0.7542967804405712,
      0.46407717694846407
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 30
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_25",
    "text": "他接着乐呵呵地说道：“早些年，养奶牛让俺发了牛财， 但牛粪处理成了问题，别说家里人闻不惯，邻居也有意见。 直接撒在地里吧，效果转化慢，见不了啥成效。近几年，镇里 推广沼气池，修这一个池子前前后后上级给了不少补贴，多 好的事啊。你瞧，这池子用了一年多了，可没少给我省钱。” 他把笔者领到厨房里，“啪”，蓝色的火苗窜出一筷子高。老 周用手往房顶上一指：“看上边，沼气灯，晚上比灯泡都亮。” 他接着说，“原来一直发愁的牛粪，也成宝贝了。除了自家的 沼气池用一部分外，剩下的都卖给邻村的用。这牛粪经过发 酵，就变成了优良的有机肥料，直接就能用在地里，这粮食不 但产量提高了，病虫害发病率也降低了不少。里里外外一 算，我这建沼气池的成本早就收回来了。”",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009682885499878963,
      0.4011170347804011,
      0.22657952069716775,
      0.5002961834645003
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 31
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_42",
    "text": "农发行瑞安市支行支持中小企业",
    "canon_role": "section_header",
    "bbox": [
      0.7993221980150085,
      0.45392231530845395,
      0.981360445412733,
      0.47727849708047726
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 32
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_38",
    "text": "图为12月20 日，侯占磊（右二）在 地头帮助村民在互 联网上发布蔬菜销 售信息。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6758654078915517,
      0.4644156723364644,
      0.7547809247155652,
      0.5053736142845053
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 33
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_43",
    "text": "中国农业发展银行浙江瑞安市支行顺应中小企业 发展的需要，创新支持方式，强化金融服务。截至11月 末，该行贷款余额23537万元，支持企业30多家，下半年 累计发放中小企业贷款19137万元，比6月底增加10837 万元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7814088598402323,
      0.4870948633324871,
      0.9987896393125151,
      0.5287297960565287
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 34
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_26",
    "text": "看着老刘兴奋的样子，笔者说：“老刘啊，其实你还没 算咱县的大账呢？现在咱齐河县通过推广一池三改'，全 县已有很多村的群众都用上了沼气，村庄卫生面貌大有改 善不说，据测算，仅此一项全县农民一年就可节约燃料费、 电费、化肥600余万元。”老刘一听，一拍大腿：“是啊，看来 这沼气池可真不啊！” 侯刚郑军宋宜",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009682885499878963,
      0.5013116696285013,
      0.22657952069716775,
      0.5514089870525514
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 35
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_39",
    "text": "宋同杰常林摄",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6811909949164852,
      0.5063891004485064,
      0.747518760590656,
      0.5145129897605145
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 36
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_44",
    "text": "针对中小企业资金来源短缺、需求紧急的特点，该 行创新信贷品种，主动与当地其他商业银行协调、沟通， 加强业务合作，进一步拓宽了信贷服务对象，满足了不 同客户贷款需求。抓重点工作发展新客户，重点发展产 业化龙头企业，并根据当地实际，着重发展水产加工行 业的龙头企业。做好老客户续贷工作的无缝衔接，明确 各客户经理的职责，努力提高基层行贷款调查、材料申 报的速度，对建立信贷关系一年以上的符合农发行要求 的龙头企业，尽可能办理公开授信，对贷款续贷企业提 前1-2个督促做好申报。 林智秀",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7814088598402323,
      0.5294067868325294,
      0.9992737835875091,
      0.6123381568926123
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 37
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_27",
    "text": "新闻故事",
    "canon_role": "section_header",
    "bbox": [
      0.08763011377390463,
      0.5585173902005586,
      0.1466957153231663,
      0.5686722518405687
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 38
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_40",
    "text": "全国首家地市村镇银行开业",
    "canon_role": "section_header",
    "bbox": [
      0.29484386347131447,
      0.5700262333925701,
      0.7247639796659404,
      0.6008293137006008
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 39
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_28",
    "text": "老张贷款买车了",
    "canon_role": "section_header",
    "bbox": [
      0.030985233599612683,
      0.5761191503765761,
      0.2038247397724522,
      0.5998138275365998
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 40
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_29",
    "text": "“老张，说买车就真的买了啊，是有钱啊!”",
    "canon_role": "support_paragraph",
    "bbox": [
      0.026143790849673203,
      0.607937716848608,
      0.1849431130476882,
      0.6160616061606161
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 41
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_48",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4245945291696926,
      0.6150461199966151,
      0.5906560154926168,
      0.6563425573326563
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 42
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_50",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.59840232389252,
      0.6150461199966151,
      0.7668845315904139,
      0.6312938986206313
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 43
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_30",
    "text": "“买啦，这不多亏了信用社的汽车消费贷款嘛，我那点 钱，刚够交首付的！”山东蒙阴县蒙阴镇下庄村村民张家山拍 着新接来的大解放牌汽车高兴得合不拢嘴。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009198741224885015,
      0.6167385969366167,
      0.22851609779714355,
      0.6407717694846408
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 44
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_45",
    "text": "本报记者李海涛",
    "canon_role": "section_header",
    "bbox": [
      0.3442265795206972,
      0.6187695692646188,
      0.4129750665698378,
      0.6275704493526276
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 45
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_53",
    "text": "农发行平阴县支行助力农科企业",
    "canon_role": "section_header",
    "bbox": [
      0.8002904865649964,
      0.6231700093086232,
      0.9828128782377148,
      0.6465261910806466
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 46
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_46",
    "text": "12月16，全国首家地市村镇银 湖南湘西长行村镇银行开业。该村镇 银行由长沙银行发起设立，注册资本2亿 元，其中民间资本投资入股0.98亿元，占比 49%。该村镇银行设后，将为辖内8个县 (市、区)提供专业化的农村金融服务，其中 国定贫困县7个，省定贫困县1个。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24981844589687727,
      0.6316323940086316,
      0.41830065359477125,
      0.6901920961326902
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 47
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_51",
    "text": "截至目前，银监会已先后批准湖南湘 西自治州、四川自贡市、广西桂林市等10个 地区先行开展地市村镇银行试点。预计到 年底，全国将有7家左右地市村镇银行开 业。首批地市村镇银行全部开业后，将可 以解决92个县（市、区）农村金融服务问题， 其中国定贫困县27个，省定贫困县10个， 农业种养殖大县37个。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.59840232389252,
      0.6319708893966319,
      0.7668845315904139,
      0.6983159854446983
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 48
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_31",
    "text": "张家山多年来一直给别人开车打工，看运输行业前景 很好，自己也想当老板，可一下子拿40多万元，让他作了 难。这不，信用社开办的个人汽车消费贷款让他实现了多年 的愿望。像他这样受益的农民在蒙阴县已有500多人。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.009682885499878963,
      0.6414487602606415,
      0.22900024207213748,
      0.6742828128966742
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 49
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_54",
    "text": "为支持有发展前景的农业特色产业、高科技企业的 发展壮大，2009年以来，农发行山东省平阴县支行累计注 资3300万元，为产包膜复合肥的“济南乐喜施复合 肥有限公司”发放农业科技短期贷款，使该企业由贷款前 的1条小型生产线(5万吨产能）扩展到现在的2条生产线 （20万吨缓控释肥的生产能力），产能较2006年增幅 300%，产品由贷款前的生产第一代缓控释肥到目前的第 三代缓控释肥，年销售达到2亿元，净利润近千万元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7823771483902203,
      0.657019548108657,
      0.9992737835875091,
      0.7237031395447237
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 50
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_49",
    "text": "然而，受经济发展水平和金融总量的制 约，中西部地区新型农村金融机构培育发展难 度较大。为促进解决这一问题，2010年4月， 银监会印发了《关于加快发展新型农村金融 机构有关事宜的通知》，允许银行业金融机 构主发起人到西部地区（除省会城市外）和 中部老、少、边、穷地区以地（市）为单位组建 总分行制的村镇银行。通知明确规定，地（市） 总行吸收的存款除上缴存款准备金和留足备 付金外，应主要用于县（市）支行发放贷款，支 行吸收的存款要全部用于当地。这是新型农 村金融机构培育模式的适应性创新发展，有利 于探索规模化解决落后地区金融服务方式，把 吸收的城市资金更好地运用和反哺“三农”。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4241103848946986,
      0.6573580434966574,
      0.5921084483175987,
      0.7572141829567572
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 51
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_32",
    "text": "笔者了解到，蒙阴县农村信用合作联社采用“经销商 担保+保证金保证+保险金保证+汽车抵押+信用社”的信 贷模式，向借款人发放用于购买以营利为目的汽车贷 款。借款人向信用社提出借款申请，提供相应资料，提供 有效身份证件，首付30%的付款凭证，同时提供营运证明 材料。贷款采用“保证+所购汽车抵押”的担保方式，除经 销商作为保证人之一外，借款人还至少提供一名符合条 件的保证人，所购车必须购买全额车辆商业保险，且第一 受益人为农村信用社，如发生意外事故，损失由保险公司 赔付，规避了风险。抵押登记也是以该车的价值全额抵 押，也可以土地使用权、房屋使用权作为抵押担保，抵押 贷款金额不得超过抵押物评估价值的70%，也可以借款人 或第三人质押物提供担保，质押比例不得超过90%。贷款 采用按月还款的方式。 张婕",
    "canon_role": "support_paragraph",
    "bbox": [
      0.00823045267489712,
      0.6746213082846746,
      0.22996853062212538,
      0.7914022171447914
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 52
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_47",
    "text": "记者了解到，自2006年底银监会调整放 宽农村地区银行业金融机构准入政策以来， 新型农村金融机构培育发展成效明显。截 至2010年11月末，全国共组建新型农村金 融机构425家，资本总额150亿元，吸收存款 607亿元，发放贷款536亿元，其中农户贷款 185亿元，占比35%，中小企业贷款277亿元， 占比52%，当年实现利润8.6亿元。通过培 育发展新型农村金融机构，机构设立地的县 域资金用于当地的比例明显提高，金融产品 和服务方式创新出现积极变化，适度竞争的 农村金融市场建设扎实起步，农村金融服务 质量和水平明显改善。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24981844589687727,
      0.6905305915206905,
      0.4178165093197773,
      0.7572141829567572
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 53
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_52",
    "text": "银监会有关负责人表示，下一步，银监 会将重点结合中西部农村地区的金融服务 需求特点，继续组织探索新型农村金融机 构的培育发展模式，切实强化战略定位监 管和微观风险监管，推动中西部地区新型 农村金融机构培育和发展，促进改善当地 “三农”和小企业金融服务。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.597918179617526,
      0.6986544808326987,
      0.7673686758654079,
      0.7575526783447576
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 54
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_55",
    "text": "如今，这家当年名不见经传的小企业，已经一跃成 为集科研开发、技术推广和生产销售为一体，具有较高 科技含量的“高新技术企业”，产品广泛用于各种农作物 与经济作物，畅销全国16个省市。 韩旭杰",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7833454369402082,
      0.724041634932724,
      0.9992737835875091,
      0.7572141829567572
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 55
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_56",
    "text": "到今年底，安徽省农村信用社走完6年改 革历程。近日，安徽省农村信用社联合社主任 陈鹏告诉笔者，该社农村合作金融机构存贷款 规模已跃居安徽全省第一，该社已成为全省营 业网点最多、存贷款规模最大、服务“三农”和 中小企业能力最强的地方金融机构。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.25659646574679257,
      0.7697385123127697,
      0.4308884047446139,
      0.8201743251248201
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 56
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_58",
    "text": "为了江淮大地的丰收",
    "canon_role": "section_header",
    "bbox": [
      0.46381021544420237,
      0.7751544385207751,
      0.9557007988380537,
      0.809003977320809
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 57
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_33",
    "text": "农发行武川县支行破解龙头企业“融资难”",
    "canon_role": "section_header",
    "bbox": [
      0.0019365770999757927,
      0.8076499957688077,
      0.23384168482207698,
      0.8313446729288313
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 58
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_59",
    "text": "安徽省深化农村信用社改革纪实",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5625756475429678,
      0.813065921976813,
      0.8540305010893247,
      0.8276212236608276
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 59
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_57",
    "text": "锐意改迎来“脱胎换”新契机",
    "canon_role": "section_header",
    "bbox": [
      0.2657952069716776,
      0.8238977743928239,
      0.42168966351972886,
      0.8333756452568334
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 60
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_78",
    "text": "12月18，安徽农张银卡——“农 卡”正式发行，全省广大农民终于有了属于 自己的银行卡。随后，安徽农金加快ATM 布放步伐，强力推广POS商户收单业务， ATM在全省布放量达1128台，位居各银行 之首，POS商户3600家，全省农村地区居民 刷卡消费渐成时尚。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.812394093439845,
      0.8364221037488364,
      0.9915274751876059,
      0.894981805872895
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 61
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_69",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4429920116194626,
      0.8367605991368368,
      0.6206729605422416,
      0.8614707624608615
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 62
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_74",
    "text": "象进步提升。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6284192689421447,
      0.8367605991368368,
      0.6870007262164125,
      0.8445459930608445
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 63
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_64",
    "text": "2004年12月18日，安徽省农村信用社联 合社成立，成为国家第二批农信社改革试点省 中首个挂牌的省级联社。以此为标志，安徽省 深化农信社改革正式拉开帷幕，全省农村合作 融机构迎来了“脱胎换骨”的新契机。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2580488985717744,
      0.8370990945248371,
      0.4366981360445413,
      0.8783955318608784
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 64
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_60",
    "text": "近年来，农发行内蒙古武川县支行坚持在支持“三农”和 新农村建设中唱主角、挑大梁，不仅实现银企共赢，而且显著 拉动农民增收。截至2010年10月，在该行累计40909万元信 贷资金支持下，武川县农业产业化龙头企业“好戏连台”，产 生了“支持一项产业，致富一方百姓”的良好效益，为促进地 方农村经济平衡较快发展做出了积极贡献。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.0,
      0.8404840484048405,
      0.23529411764705882,
      0.8902428704408902
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 65
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_75",
    "text": "在金融产品方面，省联社针对“三农” 金融服务新需求，创新推出农家乐、商家 乐、创业乐、绿之源、创业金桥、成长金桥、 金土地等七大信贷产品，业务范围覆盖各 行各业，尽可能满足各类群体及经济主体 的融需求。在此基础上，又指导各社 结合自身及本地实际，积极探索开发，陆续 推出了林权、土地流转权、收费权、商标权 以及仓单的质押贷款等一系列具有较强 命力的新型金融产品。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6269668361171629,
      0.8455614792248456,
      0.8056160735899298,
      0.9281543538969281
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 66
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_70",
    "text": "2005年12月20日，全省首家农村银行 马鞍农村合作银开业;2006年12 29，首家农村商业银行—芜湖扬子农村 商业银行成立…截至目前，全系统已经挂牌 开业41家农村银行（其中9家农村商业银行、 32家农村合作银行），占行社总数的一半以 上，组建进度居全国前三、中西部第一。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4420237230694747,
      0.8621477532368621,
      0.6206729605422416,
      0.92003046458492
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 67
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_65",
    "text": "6年来，安徽农村合作金融机构全方位开展 产权制度改革，积极组建农村银行，破除发展制 度瓶颈；转换经营机制，调动员工积极性，增强发 展内在动力；开展标准基层行社创建和合规建 设，规范内部管理，强化风险防控；推进信息化建 设，加大科技投入，硬、软件设施进一步完善。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.25756475429678044,
      0.8787340272488787,
      0.43621399176954734,
      0.9284928492849285
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 68
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_61",
    "text": "武川县坐落于大青山北部，由于海拔高，风大冷凉，传毒媒 介少，昼夜温差较大，非常适合马铃薯种植和脱毒种薯的生长繁 育。该支行抓住这一自然资源优势，积极同地方政府有关部门 联系，认真研究破解龙头企业“融资难”问题，从产品、担保、授 权、定价、审批等方面，努力完善信贷服务机制，全力支持特色支 柱产业发展和基地基础设施建设，力促加快产业结构调整，带动 农民脱贫致富。内蒙古三联淀粉制品有限责任公司是一家马铃 薯精深加工企业，在农发行武川县支行的金融支持下，目前已发 展成为武川县农产品（马铃薯）深加工的核心企业。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.0,
      0.8909198612168909,
      0.23480997337206488,
      0.9653888465769654
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 69
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_79",
    "text": "2009年，“安徽农金短信服务平台”顺利 上线，96669电话银行业务开通，使客户足不 出户便能了解账户信息。今年1216，安 徽农金网上银行业务正式上线，业务阵地扩展 至互联网络，服务能力再次取得战略突破。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.813362381989833,
      0.8956587966488957,
      0.9915274751876059,
      0.9366167385969366
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 70
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_71",
    "text": "安徽农信社的股份制改造，也从更高层次 满足了全省“三农”和中小企业发展的有效金 融需求，新组建的农村银行比传统的农村信用 社具备更强的业务经营能力，可以为农民朋友 和中小企业提供更便捷、更贴心的金融服务。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.44347615589445655,
      0.9207074553609207,
      0.6201888162672476,
      0.9623423880849623
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 71
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_66",
    "text": "截至目前，全省农村合作金融机构存贷款 余额从2004年末的711.6亿元和513.4亿元，发 展到目前的2547亿元和1852亿元，存贷款余额 实现年均增长25%以上，存贷款占全省金融业 的份额从改革之初的第三位跃升至第一位。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2580488985717744,
      0.9291698400609292,
      0.43621399176954734,
      0.9704662773969704
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 72
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_76",
    "text": "在金融服务方面，2009年，安徽省联社创 新推出了金融服务“家家到”活动，要求各行社 “沉下身子”，走出营业厅和办公楼，深入企业、 农户，全面了解社会各界金融需求，及时调整 优化信贷结构，提供更优质、更高效的服务。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6274509803921569,
      0.9295083354489295,
      0.8046477850399419,
      0.9704662773969704
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 73
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_80",
    "text": "6年来，安徽农金始终把根深深扎在“三 农”的土壤里，始终坚持服务“三农”、中小企业 以及县域经济的市场定位，加大信贷投放。截 至今年10月末，全省农村合作金融机构涉农 贷款余额为1254.2亿元，以15%左右的存款市 场份额，发放了全省90%以上的涉农贷款。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.812394093439845,
      0.9372937293729373,
      0.991043330912612,
      0.9870525514089871
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 74
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_72",
    "text": "创新服务“沉下身子”为“三农”",
    "canon_role": "section_header",
    "bbox": [
      0.46042120551924476,
      0.9657273419649657,
      0.6027596223674655,
      0.9748667174409749
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 75
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_62",
    "text": "支持地方经济和龙头企业发展，也为农发行武川县支行 赢得了丰硕回报。几年来，该行各项业务连年上台阶，步人 了增长速度较快、发展质量较高、经营效益较好的时期。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.0009682885499878964,
      0.966065837352966,

[
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_14",
    "text": "孝感市农信社贷款“真灵活”",
    "canon_role": "section_header",
    "bbox": [
      0.7877027354151537,
      0.055513243632055516,
      0.9929799080125877,
      0.07954641618007954
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 1
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_0",
    "text": "更多信贷资金有望流向“县域",
    "canon_role": "section_header",
    "bbox": [
      0.03727910917453401,
      0.0676990776000677,
      0.7247639796659404,
      0.10696454260810696
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 2
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_15",
    "text": "“农信社贷款如今真灵活’。”在湖北省孝感市的街 头村尾走访，时常能听到这样的评价。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7838295812152021,
      0.08936278243208937,
      0.9987896393125151,
      0.10594905644410595
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 3
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_16",
    "text": "孝感市农信社采取灵活多样的形式做好贷款的投 放工作。截至目前，全市农信社今年累计投放贷款40亿 元，其中“三农”贷款突破30亿元。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7823771483902203,
      0.10662604722010663,
      0.9983054950375212,
      0.13133621054413133
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 4
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_12",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6124425078673444,
      0.11948887196411949,
      0.757201646090535,
      0.16958618938816958
    ],
    "page": "newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1",
    "order": 5
  },
  {
    "chunk_id": "mineru_newspaper_73fc8720a9b2798307ba43a8b8e47b5e_1_5",
    "text": "",
    "canon_role": "support_paragraph",

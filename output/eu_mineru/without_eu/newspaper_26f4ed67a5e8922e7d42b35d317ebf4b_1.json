    "order": 36
  },
  {
    "chunk_id": "mineru_newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1_49",
    "text": "美丽乡村",
    "canon_role": "section_header",
    "bbox": [
      0.448317598644396,
      0.4908183126004908,
      0.5102880658436214,
      0.5013116696285013
    ],
    "page": "newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1",
    "order": 37
  },
  {
    "chunk_id": "mineru_newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1_35",
    "text": "商机的诞生和环境的退化",
    "canon_role": "section_header",
    "bbox": [
      0.01888162672476398,
      0.4945417618684945,
      0.41975308641975306,
      0.5226368790725227
    ],
    "page": "newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1",
    "order": 38
  },
  {
    "chunk_id": "mineru_newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1_62",
    "text": "2010年12月15日，延庆县刘斌堡乡 大观头村“首届旅游服务中专班毕业典礼” 在村委会举行。这个日子标志着，全村56 名农村学员经过三年的学习，正式从中央 农业广播电视学校毕业，取得国家承认学 历的中专毕业证书。这些农民不离乡土， 不离农事，在广阔田园边务农边读书，破天 荒地成为“文凭农民”。 范长瑜",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8182038247397725,
      0.5009731742405009,
      0.9837811667877028,
      0.567995261064568
    ],
    "page": "newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1",
    "order": 39
  },
  {
    "chunk_id": "mineru_newspaper_26f4ed67a5e8922e7d42b35d317ebf4b_1_50",
    "text": "",
    "canon_role": "picture",
    "bbox": [

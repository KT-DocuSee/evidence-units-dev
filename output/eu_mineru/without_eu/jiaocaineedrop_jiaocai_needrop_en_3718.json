    "order": 1
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_1",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.07450980392156863,
      0.0890909090909091,
      0.4470588235294118,
      0.2696969696969697
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 2
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_2",
    "text": "FLUENCY is when a child can see a word and instantly recognize it.",
    "canon_role": "section_header",
    "bbox": [
      0.48470588235294115,
      0.11333333333333333,
      0.8666666666666667,
      0.19818181818181818
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 3
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_3",
    "text": "A child may need to see a word twenty, thirty or forty times before it becomes“automatic\". If a child has a learning disability, the number of exposures needed to automatically remember a word may go up to well over a hundred.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3043137254901961,
      0.22848484848484849,
      0.8901960784313725,
      0.3496969696969697
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 4
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_5",
    "text": "10seconds",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6627450980392157,
      0.36363636363636365,
      0.8870588235294118,
      0.49272727272727274
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 5
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_4",
    "text": "Tests have shown that children have about ten seconds of \"working memory\"– if a child can read a sentence in ten or less seconds, he/she can \"get\"(comprehend) the \"big idea\" of the sentence.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07137254901960784,
      0.3696969696969697,
      0.6282352941176471,
      0.4903030303030303
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 6
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_6",
    "text": "A NNi m",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10431372549019607,
      0.5066666666666667,
      0.27058823529411763,
      0.6557575757575758
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 7
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_7",
    "text": "If a child has to struggle to read each word in a sentence, by the time the child reaches the end of the sentence, he/she has forgotten the words at the beginning of the sentence = zero comprehension.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.34352941176470586,
      0.5345454545454545,
      0.9098039215686274,
      0.6545454545454545
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 8
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_9",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.6329411764705882,
      0.656969696969697,
      0.9333333333333333,
      0.8096969696969697
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 9
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_8",
    "text": "There are 220“high frequency\"words that make up 50 - 70% of almost all written sentences.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07372549019607844,
      0.7012121212121212,
      0.6039215686274509,
      0.7727272727272727
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 10
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_10",
    "text": "M W",
    "canon_role": "support_paragraph",
    "bbox": [
      0.11843137254901961,
      0.7787878787878788,
      0.2768627450980392,
      0.9345454545454546
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 11
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_11",
    "text": "If a child can automatically read these words, then a child has a better chance of reading a sentence in ten seconds or less- and this leads to a happier, less frustrated reader",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3427450980392157,
      0.8327272727272728,
      0.9011764705882352,
      0.9303030303030303
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3718",
    "order": 12
  }
]
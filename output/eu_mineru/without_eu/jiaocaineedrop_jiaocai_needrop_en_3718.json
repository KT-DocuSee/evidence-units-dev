[
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_0",
    "text": "High-Frequency-Words Memory Game",
    "canon_role": "section_header",
    "bbox": [
      0.07215686274509804,
      0.04666666666666667,
      0.6564705882352941,
      0.07454545454545454

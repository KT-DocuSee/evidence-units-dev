      0.15219721329046088
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_3713",
    "order": 4
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3713_12",
    "text": "3.渔船靠岸了，原来()的码头下喧闹起来。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5389326334208224,

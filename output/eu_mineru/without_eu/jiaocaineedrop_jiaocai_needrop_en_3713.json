[
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3713_9",
    "text": "五氣調意區，主経受團填上創底項優的源支領。（8 分)",
    "canon_role": "section_header",
    "bbox": [

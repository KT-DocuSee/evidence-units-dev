    "order": 6
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3713_13",
    "text": "4.沟渠的积雪北边化得(卖），南边化得慢。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5399325084364455,

    "order": 3
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3713_11",
    "text": "2.树枝叶稠的是南，(）的是北。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5409323834520685,
      0.13004644515898536,

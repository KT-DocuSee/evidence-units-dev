  },
  {
    "chunk_id": "mineru_newspaper_5a8b7563a3262beecbecd7ddd3ef8827_1_0",
    "text": "2011年全国“三下乡”活动在福建启动",
    "canon_role": "section_header",
    "bbox": [
      0.04938271604938271,
      0.066006600660066,
      0.6424594529169693,
      0.0985021579080985
    ],

  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3341_20",
    "text": "名著推荐：《小巴掌童话百篇》",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6960643148548116,
      0.5028811777076762,
      0.894528437724982,
      0.5294637223974763
    ],

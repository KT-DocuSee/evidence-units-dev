[
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2884_0",
    "text": "What can we do to solve these problems?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.08368200836820083,
      0.0737448559670782,
      0.42305904230590424,
      0.09020576131687243
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_2884",
    "order": 1
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2884_1",
    "text": "If we eat more vegetables and less meat, we willeasily get more food. Land that is used to grow crops can feed five times more people than land where animals are kept.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.05764760576476058,
      0.09481481481481481,
      0.9418874941887494,
      0.1336625514403292
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_2884",
    "order": 2
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2884_2",
    "text": "The world population will not rise so quickly if people use modern methods of birth control.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.07345420734542074,
      0.13695473251028806,
      0.8470478847047884,
      0.15539094650205762
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_2884",
    "order": 3
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2884_3",
    "text": "Finally, if we educate people to think about the problems, we shall have a beter and cleaner living place n the future.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.058577405857740586,
      0.15868312757201647,
      0.9446768944676894,
      0.19621399176954732
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_2884",
    "order": 4

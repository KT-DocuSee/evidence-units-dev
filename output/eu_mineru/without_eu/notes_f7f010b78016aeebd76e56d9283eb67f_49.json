    "order": 7
  },
  {
    "chunk_id": "mineru_notes_f7f010b78016aeebd76e56d9283eb67f_49_7",
    "text": "They sat there without talking to one another /each other. (他们坐在那1，互相都不说话。)",
    "canon_role": "support_paragraph",

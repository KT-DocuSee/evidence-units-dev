    "order": 2
  },
  {
    "chunk_id": "mineru_notes_f7f010b78016aeebd76e56d9283eb67f_49_2",
    "text": "如：Who is (are) in that playhouse?(谁在游戏房里？) What is that?(那是什么?)",
    "canon_role": "support_paragraph",
    "bbox": [
      0.14990689013035383,
      0.26613965744400525,
      0.8035381750465549,
      0.3241106719367589

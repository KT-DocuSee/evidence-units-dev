  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_31_2",
    "text": "1、多火山、地震的岛国",
    "canon_role": "support_paragraph",
    "bbox": [
      0.11064621106462111,
      0.2516469038208169,

    "order": 36
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_26",
    "text": "16 Birch St., Roslindale, 617-833- 6950, wrww.russandmimis.com. Dishes",

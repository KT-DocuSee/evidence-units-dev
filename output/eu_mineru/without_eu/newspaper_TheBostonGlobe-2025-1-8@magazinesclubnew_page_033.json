    "order": 31
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_10",
    "text": "McGonagle's Pub",
    "canon_role": "section_header",
    "bbox": [
      0.014480646059593427,
      0.4652233993551359,
      0.09913673071567808,
      0.4719791186857055
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033",
    "order": 32
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_23",
    "text": "Russ & Mimi's",
    "canon_role": "section_header",
    "bbox": [
      0.4076858813700919,
      0.46553047750652543,
      0.4756335282651072,
      0.4719791186857055
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033",
    "order": 33
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_11",
    "text": "If you appreciate the Dubliner, bringing excellent fish and chips and Irish hospitality to downtown Boston, you will ikely feel the same about McG onagle's in Dorchester. Pigs in a blanket made with sausage from Adams Village",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.4725932749884846,
      0.19771651350598718,
      0.5140488254260709
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033",
    "order": 34
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_24",
    "text": "Named for the parents of owner Kel- ly Walsh (Sweet Cheeks, Tiger Mama), this Roslindale market offers wine (it's in the former Solera space), olive oil, hot sauce, and other must-haves. But it's the food that has the neighborhood most excited. Start the morning with egg wraps, overnight oats, cheesy grits, and cumin-spiced black beans with fried egg, salsa, and avocado; then segue into the \"Cubano, veggie grinder, muffuletta, charred broccoli Caesar\" part of the day. Chef Stephen Marcaurelle (the Nautilus Pier 4, Tres Gatos) helped design the menu.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.4071289334447229,
      0.4725932749884846,
      0.5914786967418546,
      0.5143559035774604
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033",
    "order": 35
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_37",
    "text": "Devra First can be reached at devra.first@globe.com. Follore her @devrafirst.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8042328042328042,
      0.49286043298019344,
      0.960735171261487,
      0.5137417472746814
    ],

    "order": 30
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_033_36",
    "text": "26 Charles St., Beacon Hill, Boston, 857-305-3177, erwre.zuritoboston.com. Pintxos $4.50-$12, raciones $9-$19, platos especiales $17-$125.",
    "canon_role": "support_paragraph",

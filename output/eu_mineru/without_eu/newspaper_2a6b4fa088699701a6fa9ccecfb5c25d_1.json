    "chunk_id": "mineru_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_16",
    "text": "Dated: September 26, 2016. Stephen Guertin, Acting Director, U.S. Fish and Wildlife Service. [FR Doc.2016-24138 Filed10-5-16; 8:45 am] BILLING CODE 4333-15-P",
    "canon_role": "support_paragraph",

  {
    "chunk_id": "mineru_newspaper_2a6b4fa088699701a6fa9ccecfb5c25d_1_22",
    "text": "AcTIon: Notice of 12-month petition findings.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3623529411764706,
      0.5218181818181818,
      0.6062745098039216,
      0.5478787878787879
    ],

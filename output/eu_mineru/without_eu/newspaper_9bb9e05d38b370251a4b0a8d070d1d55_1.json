    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6850641491164366,
      0.30735381230430736,
      0.8177196804647785,
      0.34865024964034863
    ],
    "page": "newspaper_9bb9e05d38b370251a4b0a8d070d1d55_1",
    "order": 26

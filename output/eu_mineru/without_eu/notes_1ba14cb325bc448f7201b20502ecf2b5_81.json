  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_81_4",
    "text": "2.现代都市建设中，北京所做的工作",
    "canon_role": "support_paragraph",
    "bbox": [
      0.100418410041841,
      0.696969696969697,

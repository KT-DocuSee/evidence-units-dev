    "text": "资料来源：中证指数公司、开源证券研究所",
    "canon_role": "support_paragraph",
    "bbox": [
      0.062071745264006446,
      0.23884851075958385,
      0.35066505441354295,
      0.2519595268633319
    ],
    "page": "eastmoney_8f87670d793f4415afca95380e8e46cc8517d6f97fa65a6680308bfc34fa7b5e.pdf_4",

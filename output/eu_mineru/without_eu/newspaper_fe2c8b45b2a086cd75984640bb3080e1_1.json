      0.24507066091224508
    ],
    "page": "newspaper_fe2c8b45b2a086cd75984640bb3080e1_1",
    "order": 21
  },
  {
    "chunk_id": "mineru_newspaper_fe2c8b45b2a086cd75984640bb3080e1_1_20",
    "text": "海丰种业坚持创新求发展",
    "canon_role": "section_header",

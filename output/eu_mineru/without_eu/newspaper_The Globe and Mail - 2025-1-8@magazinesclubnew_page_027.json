  {
    "chunk_id": "mineru_newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_027_27",
    "text": "dam Scott made it back to Kapa- lua and returned to the top 20 in the world ranking, and it's a won- der how he managed with so much on his plate. This coincided with his first full year on the PGA Tour board, and it was a lot.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.034166666666666665,
      0.7892537313432836,
      0.25833333333333336,
      0.8350248756218905

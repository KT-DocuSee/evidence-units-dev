    "order": 14
  },
  {
    "chunk_id": "mineru_newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_027_22",
    "text": "Visiting cities across North America this year gives the league a chance to test out future mar- kets, Hefford said.",

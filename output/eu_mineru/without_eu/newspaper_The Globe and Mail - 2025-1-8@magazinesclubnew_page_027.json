    "order": 17
  },
  {
    "chunk_id": "mineru_newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_027_23",
    "text": "Each stop will be evaluated on a number of factors, including eco- nomic potential, partnerships and facilities. Travel logistics will also be weighed, she said, as teams currently use commercial flights to get from one game to an- other.",
    "canon_role": "support_paragraph",
    "bbox": [

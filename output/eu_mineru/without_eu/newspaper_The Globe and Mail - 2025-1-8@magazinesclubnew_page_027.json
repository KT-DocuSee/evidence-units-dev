    "order": 18
  },
  {
    "chunk_id": "mineru_newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_027_6",
    "text": "\"I think I'm getting old. I think Im getting a little softer,\" Poulin said with a grin. \"No, I think it's al- ways very awesome. It's always such a privilege to be able to be in these buildings and big crowds. So I don't take it for granted.\"",
    "canon_role": "support_paragraph",
    "bbox": [
      0.03333333333333333,
      0.6722388059701493,
      0.21,
      0.7180099502487562
    ],
    "page": "newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_027",
    "order": 19
  },
  {
    "chunk_id": "mineru_newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_027_11",
    "text": "More than 12,ooo fans took in the game. Merchandise was so popular it had to be stripped off mannequins before employees put up a \"sold out\" sign.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.22166666666666668,

  },
  {
    "chunk_id": "mineru_PPT_MMAT5390Lecture1_page_023_2",
    "text": "A 2D (grayscale) digital image is a 2D function defined on a 2D domain (usually rectangular domain):",
    "canon_role": "support_paragraph",
    "bbox": [
      0.088,
      0.19733333333333333,
      0.95,
      0.2782222222222222

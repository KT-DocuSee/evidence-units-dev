    "order": 3
  },
  {
    "chunk_id": "mineru_PPT_MMAT5390Lecture1_page_023_3",
    "text": "f(x, y) is called the brightness/intensity/grey level; (x,y) is the spatial coordinates of the image.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10133333333333333,
      0.3804444444444444,
      0.7266666666666667,
      0.4711111111111111

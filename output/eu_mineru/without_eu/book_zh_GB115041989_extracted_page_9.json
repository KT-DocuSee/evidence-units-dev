    "order": 13
  },
  {
    "chunk_id": "mineru_book_zh_GB115041989_extracted_page_9_13",
    "text": "E5.6以吸光度（扣除空白吸光度)为纵坐标，δ-ALA量为横坐标，在坐标纸上绘制标准曲线。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13194444444444445,
      0.5525491313016234,
      0.8242521367521367,
      0.5692585208392671
    ],

  },
  {
    "chunk_id": "mineru_book_zh_GB115041989_extracted_page_9_16",
    "text": "E7说明",
    "canon_role": "section_header",
    "bbox": [
      0.13247863247863248,
      0.6816671413652331,
      0.20833333333333334,
      0.6964777366372353

    "order": 2
  },
  {
    "chunk_id": "mineru_book_zh_GB115041989_extracted_page_9_2",
    "text": "E4尿样分析步骤",
    "canon_role": "section_header",
    "bbox": [
      0.125,
      0.18456280262033609,
      0.2702991452991453,

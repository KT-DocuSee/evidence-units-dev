    "order": 12
  },
  {
    "chunk_id": "mineru_book_zh_GB115041989_extracted_page_9_12",
    "text": "E5.5用比色皿在波长553nm（或绿色滤光片）下，以乙酸乙酯作参比，测得各标准管吸光度。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12980769230769232,
      0.5343207063514668,
      0.8269230769230769,
      0.5498908193297256

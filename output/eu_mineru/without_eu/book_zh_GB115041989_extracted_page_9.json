  {
    "chunk_id": "mineru_book_zh_GB115041989_extracted_page_9_1",
    "text": "应用液：取贮备液10mL于100mL容量瓶中，并稀释至刻度，此液浓度约等于59.7μmol/L（1mL =10μg)δ-ALA。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12179487179487179,
      0.1344346340074053,
      0.9006410256410257,
      0.17165100161397512

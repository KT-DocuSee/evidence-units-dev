  {
    "chunk_id": "mineru_newspaper_bd75af5f4791aa56ef05ce2443e8a7e0_1_2",
    "text": "九江县：产业小区 建设成候",
    "canon_role": "support_paragraph",
    "bbox": [
      0.016945049624788187,
      0.08800880088008801,
      0.13168724279835392,
      0.11441144114411442
    ],

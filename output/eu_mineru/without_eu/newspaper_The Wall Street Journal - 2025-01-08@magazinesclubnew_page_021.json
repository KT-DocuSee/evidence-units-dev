[
  {
    "chunk_id": "mineru_newspaper_The Wall Street Journal - 2025-01-08@magazinesclubnew_page_021_12",
    "text": "Sixth Street Strikes a Deal To Manage Insurer's Assets",
    "canon_role": "section_header",
    "bbox": [
      0.3403441682600382,
      0.05029044322431766,
      0.9840662842574889,

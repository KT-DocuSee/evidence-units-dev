[
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_17",
    "text": "Population rise in Mass. is largest in 60 years",
    "canon_role": "section_header",
    "bbox": [
      0.7502088554720133,
      0.11146936895439889,
      0.985240879977722,
      0.23276523875326272
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 1
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_0",
    "text": "Norovirus cases in Mass. surged in 2024",
    "canon_role": "section_header",
    "bbox": [
      0.013366750208855471,
      0.11208352525717795,
      0.6727930938457254,
      0.13542146476278213
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 2
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_5",
    "text": "Officials say 66% jump in a year reflects US trend; call handwashing best defense",
    "canon_role": "support_paragraph",
    "bbox": [
      0.19548872180451127,
      0.14064179333640411,
      0.5385686438318017,
      0.16551512359895593
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 3
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_1",
    "text": "By Camilo Fonseca GLOBE STAFF",
    "canon_role": "section_header",
    "bbox": [
      0.04399888610414926,
      0.14309841854752034,
      0.14870509607351712,
      0.15630277905727008
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 4
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_12",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.55583402951824,
      0.1437125748502994,
      0.6588693957115009,
      0.15046829418086904
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 5
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_13",
    "text": "Ilness caused by norovirus typi- cally starts suddenly, with symp- toms developing 12 to 48 hours fol- lowing exposure to the virus. Most people get better within one to three days and recover fully.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.55583402951824,
      0.14985413787808996,
      0.7229184071289334,
      0.19253800092123446
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 6
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_2",
    "text": "Mirroring a national trend, cases of the norovirus stomach bug are surging in Massachusetts this win- ter, according to state data.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.013366750208855471,
      0.1575310916628282,
      0.18045112781954886,
      0.1854752034392753
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 7
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_6",
    "text": "Public health officials say they have been monitoring the increase in cases.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.19381787802840433,
      0.17104253032396746,
      0.3620161514898357,
      0.19223092276984494
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 8
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_10",
    "text": "Norovirus symptoms include nausea, vomiting, diarrhea, and ab- dominal cramps, according to state health officials. Despite being one of the most common causes of food- borne illness, the virus is difficult to detect in a laboratory, and special- ized norovirus tests are usually con- ducted only in certain circumstanc- es.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.37538290169869115,
      0.171349608475357,
      0.5430242272347535,
      0.24105634884077998
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 9
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_3",
    "text": "The state reported 2,080 labora- tory-confirmed cases of the virus in 2024 in preliminary data released last week by the Massachusetts De- partment of Public Health. That represents a jump of roughly 66 percent from the previous year, when the state reported 1,252 cas- es.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.18578228159066482,
      0.18156502367028682,
      0.24750499001996007
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 10
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_7",
    "text": "Nationally, cases of the virus are surging in parts of the United States this winter, according to govern- ment data.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1943748259537733,
      0.19253800092123446,
      0.3614592035644667,
      0.22017503454629203
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 11
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_14",
    "text": "People of all ages can get infect- ed and fall sick from norovirus. Young children, older people, and those with weakened immune sys- tems are most at risk, with dehydra- tion from vomiting and diarrhea the top concern.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.556390977443609,
      0.192845079072624,
      0.7229184071289334,
      0.24105634884077998
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 12
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_8",
    "text": "The most recent numbers from the Centers for Disease Control and Prevention show there were 91 out- breaks of norovirus reported during the week of Dec. 5, up from 69 out- breaks the last week of November.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1949317738791423,
      0.2207891908490711,
      0.3614592035644667,
      0.26193766313526795
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 13
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_18",
    "text": "Census figures show increase largely driven by infl ux of immigrants",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7507658033973823,
      0.23829264547827422,
      0.9590643274853801,
      0.27698449255335483
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 14
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_11",
    "text": "A spokesperson for the DPH said the uptick in cases may be attribut- ed in part to more modern testing methods which can detect multiple pathogens at once. They also noted that certain test devices were re- cently found to be prone to false positives of norovirus.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.37593984962406013,
      0.2413634269921695,
      0.5424672793093845,
      0.2904959312144941
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 15
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_15",
    "text": "There is no medication to treat norovirus. Rehydration is recom- mended by drinking water and oth- er liquids, with the exception of cof- fee, tea, and alcohol.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.555277081592871,
      0.24167050514355903,
      0.7223614592035644,
      0.27606325809918625
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 16
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_4",
    "text": "Cases over the winter have so far outpaced the previous year, with 134 cases reported in November and 279 reported in December. In 2023, there were 52 cases reported in November and 112 in December.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.24873330262551818,
      0.18045112781954886,
      0.289881774911715
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 17
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_9",
    "text": "Numbers from the past few years show a maximum of 65 outbreaks reported during that first week of December.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1949317738791423,
      0.2622447412866575,
      0.36257309941520466,
      0.29018885306310455
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 18
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_16",
    "text": "Health officials also recommend NOROVIRUS, Page B3",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5669729880256196,
      0.2763703362505758,
      0.7262600946811473,
      0.2904959312144941
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 19
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_19",
    "text": "By Sam Drysdale",
    "canon_role": "section_header",
    "bbox": [
      0.8209412419938735,
      0.28281897742975587,
      0.9156223893065998,
      0.2908030093658836
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 20
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_43",
    "text": "Fueled by the highest immigration levels in decades, Massachusetts saw its largest popula- tion increase in 60 years between 2023 and 2024, and the rate of domestic outmigration has signifi - cantly slowed, according to Us Census data re- leased last month.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7518796992481203,
      0.2975587286964532,
      0.986911723753829,
      0.3393213572854291
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 21
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_20",
    "text": "CHILLIN' OUT",
    "canon_role": "section_header",
    "bbox": [
      0.020050125313283207,
      0.30830646399508677,
      0.20384294068504594,
      0.3236603715645632
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 22
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_21",
    "text": "",
    "canon_role": "picture",
    "bbox": [
      0.021164021164021163,
      0.33655765392292336,
      0.7179058758006126,
      0.6175341624443421
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 23
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_42",
    "text": "Between July 1, 2023 and July 1, 2024, the state's population increased 69,603 from 7,066,568 to 7, 136,171 — an increase of just un- der 1 percent (0.985 percent).",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7513227513227513,
      0.3393213572854291,
      0.986911723753829,
      0.36726546906187624
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 24
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_44",
    "text": "That's the largest annual percentage increase that Massachusetts has experienced since be- tween 2012 and 2013, according to a UMass Do- nahue Institute analysis of the December Us Cen- sus population estimates.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7524366471734892,
      0.3678796253646553,
      0.986911723753829,
      0.401965300168893
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 25
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_45",
    "text": "Numbers-wise, it's the largest annual popula- tion increase since the end of the baby boom in 1964.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7513227513227513,
      0.4022723783202825,
      0.986911723753829,
      0.4222324581606019
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 26
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_48",
    "text": "90,217 The estimated number of immigrants that came to Massachusetts between 2023",
    "canon_role": "support_paragraph",
    "bbox": [
      0.9078251183514341,
      0.42161830185782284,
      0.9746588693957114,
      0.4762782128051589
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 27
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_46",
    "text": "Those gains made Massa- chusetts the fastest growing state in New England and the second-fastest growing state in the Northeast after New Jersey, according to the institute.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7513227513227513,
      0.42346077076616,
      0.8888888888888888,
      0.471672040534316
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 28
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_47",
    "text": "The largest driver: immi- and 2024 gration, estimated at 90,217 SOURCE: incoming immigrants be- Us Census data tween 2023 and 2024. The census estimates that's the highest immigration level since at least 1990.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7513227513227513,
      0.4725932749884846,
      0.98635477582846,
      0.5137417472746814
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 29
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_49",
    "text": "\"while immigration is the single largest driver of population change in Massachusetts ... other factors also play a role,\" according to the insti- tute's analysis. \"In 2024, Massachusetts saw more births (67,851) than deaths (61, 133), contribut- ing 6,718, on net, to the population growth in Massachusetts.\"",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7507658033973823,
      0.5140488254260709,
      0.98635477582846,
      0.5625671733456165
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 30
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_50",
    "text": "Massachusetts has seen an influx of thousands of refugees and migrants — seeking asylum from wars, political unrest, and environmental disas- ters — who have sought temporary housing in the state's emergency family shelter system, straining the physical and financial limits of the system. The census data does not delineate between im- migrants legally seeking asylum or refuge and those otherwise entering the country.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7507658033973823,
      0.5631813296483955,
      0.98635477582846,
      0.6258252725318594
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 31
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_22",
    "text": "DAVID L. RYAN/GLOBE STAFF",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6042884990253411,
      0.6172270842929526,
      0.7162350320245057,
      0.6224474128665746
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 32
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_23",
    "text": "Pedestrians donned an assortment of winter gear as they walked in downtown Boston Tuesday.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.023948760790866053,
      0.6252111162290803,
      0.5329991645781119,
      0.6335022263165976
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 33
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_51",
    "text": "Domestic outmigration, the term used to de- scribe people moving out of one state to another state, has been a contentious political topic for the past several years, as many young aduits and families left Massachusetts in the early days of the pandemic, settling in states with lower costs of living.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7507658033973823,
      0.6258252725318594,
      0.986911723753829,
      0.6746506986027944
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 34
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_26",
    "text": "Boston traffic ranked fourth worst in nation",
    "canon_role": "section_header",
    "bbox": [
      0.020607073238652185,
      0.6565330876708122,
      0.7112225006961849,
      0.6789497927222478
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 35
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_52",
    "text": "Conservatives point to high taxes as the reason for domestic outmigration, calling on Democrats to lower tax burdens to keep Bay Staters from moving. Progressives, on the other hand, have pointed to high housing and child care costs, and called for more state investment in programs to",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7507658033973823,
      0.6749577767541839,
      0.986911723753829,
      0.7170274834945494
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 36
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_32",
    "text": "Study finds drivers here spent an average 79 hours stuck in traffic last year",
    "canon_role": "section_header",
    "bbox": [
      0.19604566972988025,
      0.686012590204207,
      0.5329991645781119,
      0.7102717641639797
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 37
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_27",
    "text": "By Shannon Larson GLOBE STAFF",
    "canon_role": "section_header",
    "bbox": [
      0.04121414647730437,
      0.6884692154153232,
      0.15204678362573099,
      0.7010594196222939
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 38
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_39",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.555277081592871,
      0.6887762935667128,
      0.7229184071289334,
      0.7164133271917703
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 39
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_28",
    "text": "In what will come as no surprise to any Boston driver: We're still stuck in traffic. The city continues to rank in the top-five most con- gested cities in the United States and among the worst worldwide.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.013366750208855471,
      0.7025948103792415,
      0.17989417989417988,
      0.7446645171196069
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 40
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_33",
    "text": "Some key factors, according to the Mass. Department of Transpor- tation, include investments in infra- structure, such as optimized traffic signals and dedicated bus lines; public transit enhancements; more people choosing biking or walking; and folks adjusting their commut- ing schedules.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1943748259537733,
      0.7167204053431598,
      0.36257309941520466,
      0.7793643482266237
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 41
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_36",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.37538290169869115,
      0.7167204053431598,
      0.5419103313840156,
      0.7584830339321357
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 42
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_40",
    "text": "For another year running, New York was the most congested city in the US, according to the scorecard, with the average New York com- muter losing 102 hours, followed by Chicago drivers who also lost 102 hours, and Los Angeles motorists, who lost 88 hours. People behind the wheel in Boston came in fourth nationwide, the same position it was ranked by INRIX in 2023.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.556390977443609,
      0.7170274834945494,
      0.7240323029796714,
      0.793489943190542
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 43
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_53",
    "text": "POPULATION, Page B4",
    "canon_role": "support_paragraph",
    "bbox": [
      0.8877749930381509,
      0.7173345616459389,
      0.986911723753829,
      0.7234761246737295
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 44
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_54",
    "text": "INSIDE",
    "canon_role": "section_header",
    "bbox": [
      0.7518796992481203,
      0.7419008137571012,
      0.8075744917850181,
      0.7514202364501765
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 45
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_29",
    "text": "Still, Boston traffic is generally improving. Unless, that is, you're heading south on I-93 after work.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.7443574389682174,
      0.18100807574491784,
      0.7658529095654845
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 46
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_37",
    "text": "In the Us last year, the average worker lost 43 hours to traffic jams, the equivalent of a work week, IN- RIX found.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.37538290169869115,
      0.7594042683863043,
      0.5424672793093845,
      0.7864271457085829
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 47
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_55",
    "text": "Transgender youths",
    "canon_role": "section_header",
    "bbox": [
      0.7524366471734892,
      0.7637033625057578,
      0.9005847953216374,
      0.771994472593275
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 48
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_30",
    "text": "The average motorist traversing Boston spent 79 hours stuck in traf- fic in 2024, according to an annual study from INRIX, a transportation analytics company. In 2023, that av- erage driver lost 88 hours.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.7658529095654845,
      0.18045112781954886,
      0.8073084600030708
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 49
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_56",
    "text": "A medical journal report finds that the number of adolescents receiving gender-affirming drugs is fewer than 1 in 1,000. B2",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7513227513227513,
      0.7726086288960541,
      0.9752158173210804,
      0.792875786887763
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 50
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_34",
    "text": "\"We're encouraged by this prog- ress, but know there's still work to be done,\" said the state highway ad- ministrator, Jonathan Gulliver.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1943748259537733,
      0.7799785045294028,
      0.3614592035644667,
      0.8073084600030708
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 51
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_38",
    "text": "\"Traffic can be an indicator of economic boon, but ironically, it's a hamper on economies in of itself. Each minute spent waiting in traf- fic results in money and productivi- ty lost,\" said Bob Pishue, transpor- tation analyst at INRIX and author of the report, which determined that $74 billion was lost to conges- tion nationwide.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.3764967975494291,
      0.7870413020113619,
      0.5424672793093845,
      0.8288039306003377
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 52
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_41",
    "text": "In Boston, congestion resulted in the average speed of a downtown trip crawling along at 13 miles per hour — the second-slowest in the TRAFFIC, Page B4",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5580618212197159,
      0.7941040994933211,
      0.7229184071289334,
      0.8288039306003377
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 53
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_57",
    "text": "Broker fees",
    "canon_role": "section_header",
    "bbox": [
      0.7518796992481203,
      0.7956394902502687,
      0.8376496797549429,
      0.803930600337786
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 54
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_58",
    "text": "Governor Healey said that the state should abolish real estate broker fees that renters typically pay to secure a home or apartment. B2",
    "canon_role": "support_paragraph",
    "bbox": [
      0.7513227513227513,
      0.8042376784891755,
      0.9768866610971874,
      0.8254260709350529
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 55
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_31",
    "text": "That 10 percent drop is the larg- est for any of the top 25 most con- gested American cities.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.8079226163058498,
      0.17989417989417988,
      0.8288039306003377
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 56
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_35",
    "text": "Worldwide, congestion again edged closer to pre-pandemic levels as more than half of the urban ar- eas studied experienced an increase in traffic — a trend driven, in part, by workers returning to the office. Istanbul, Mexico City, London, and Paris were among the most congest- ed cities, according to the study.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1943748259537733,
      0.8079226163058498,
      0.3620161514898357,
      0.8288039306003377
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 57
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_59",
    "text": "ALISON FIELD 1966-2024",
    "canon_role": "section_header",
    "bbox": [
      0.23893065998329155,
      0.84692154153232,
      0.39766081871345027,
      0.8558268079226163
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 58
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_68",
    "text": "",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6388192703982177,
      0.8478427759864886,
      0.985240879977722,
      0.9663749424228466
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 59
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_60",
    "text": "Brown professor conducted groundbreaking research into eating disorders and obesity",
    "canon_role": "section_header",
    "bbox": [
      0.01949317738791423,
      0.8604329801934593,
      0.6204399888610415,
      0.9012743743282665
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 60
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_61",
    "text": "By Bryan Marquard",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10749094959621275,
      0.9049593121449409,
      0.21665274296853243,
      0.9135575003838476
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 61
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_65",
    "text": "\"There probably isn't one magic bullet for obesity,\" Dr. Field said in 2018, when she was lead author of a paper published in the journal Obesity that analyzed data from more than 2,400 patients who had undergone bariatric weight-loss surgery. \"If there is a magic bullet,\" she added, \"it's going to be differ- ent for different groups of people.\"",
    "canon_role": "support_paragraph",
    "bbox": [
      0.32470064049011416,
      0.9052663902963304,
      0.6260094681147312,
      0.9479502533394749
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 62
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_62",
    "text": "GLOBE STAFF",
    "canon_role": "support_paragraph",
    "bbox": [
      0.11584516847674742,
      0.9077230155074466,
      0.21052631578947367,
      0.9181636726546906
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 63
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_63",
    "text": "Alison Field traced her early insights into obesity and eating disorders to a job in the late 1980s that seemed far removed from the international reputation she would earn as a professor and researcher.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.01392369813422445,
      0.9193919852602487,
      0.31244778613199664,
      0.9473360970366959
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 64
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_64",
    "text": "While attending college in California, she was a consultant to a Jenny Craig weight loss clinic and began honing skills she would bring to decades of studies: listening to those trying to lose weight, and watching carefully and compassionately to see how nuanced differences among people could splinter a sweep- ing diagnosis into subcategories.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.012809802283486493,
      0.9476431751880854,
      0.3130047340573656,
      0.9894058037770612
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 65
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_66",
    "text": "Dr. Field, an epidemiology professor and associate dean for faculty affairs at the Brown University School of Public Health who formerly taught at Harvard Medical School, died Oct. 10 in her home in the Newton section of Chestnut Hill.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.32748538011695905,
      0.9479502533394749,
      0.6260094681147312,
      0.9752802088131429
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 66
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_24",
    "text": "ERIC SENUNAS",
    "canon_role": "support_paragraph",
    "bbox": [
      0.9289891395154553,
      0.9672961768770152,
      0.986911723753829,
      0.9728235836020267
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 67
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_25",
    "text": "Dr. Field, who also taught at Harvard Medical School, began honing her skills while consulting at a weight loss clinic.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.6432748538011696,
      0.9752802088131429,
      0.9523809523809523,
      0.9897128819284507
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 68
  },
  {
    "chunk_id": "mineru_newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011_67",
    "text": "She was 58 and had survived cancer three times during the FIELD, Page B3",
    "canon_role": "support_paragraph",
    "bbox": [
      0.33751044277360065,
      0.9755872869645325,
      0.6254525201893623,
      0.9897128819284507
    ],
    "page": "newspaper_TheBostonGlobe-2025-1-8@magazinesclubnew_page_011",
    "order": 69
  }
]
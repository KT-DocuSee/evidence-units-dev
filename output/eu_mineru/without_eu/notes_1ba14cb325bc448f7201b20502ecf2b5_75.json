    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_75_0",
    "text": "④建立稳定的商品粮基地。",
    "canon_role": "support_paragraph",
    "bbox": [
      0.18503021850302184,
      0.16666666666666666,
      0.4602510460251046,

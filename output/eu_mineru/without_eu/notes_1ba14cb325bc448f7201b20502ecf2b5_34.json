    "order": 3
  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_34_3",
    "text": "③水运通道",
    "canon_role": "support_paragraph",
    "bbox": [
      0.17108321710832172,

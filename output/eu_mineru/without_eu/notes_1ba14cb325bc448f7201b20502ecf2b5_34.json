    "page": "notes_1ba14cb325bc448f7201b20502ecf2b5_34",
    "order": 6
  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_34_6",
    "text": "4.华人.华侨集中的地区 (1)华人与华侨的涵义",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10227801022780102,
      0.4652846331029944,
      0.3263598326359833,

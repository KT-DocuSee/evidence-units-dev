    "order": 1
  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_34_1",
    "text": "①提供大量城市建设用地：",
    "canon_role": "support_paragraph",
    "bbox": [
      0.16922361692236168,
      0.21520236920039487,
      0.42677824267782427,

    ],
    "page": "notes_1ba14cb325bc448f7201b20502ecf2b5_34",
    "order": 2
  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_34_2",
    "text": "②为城市生产、生活提供充定的水源",
    "canon_role": "support_paragraph",
    "bbox": [
      0.16922361692236168,
      0.2474498190194143,

[
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_34_0",
    "text": "(4)城市分布在河流沿岸的利与费 有利条件：",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13575081357508137,

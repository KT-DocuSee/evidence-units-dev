  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_237_5",
    "text": "【理解体育内涵】",
    "canon_role": "section_header",
    "bbox": [
      0.0650347972162227,
      0.31291650749182903,
      0.2174226061915047,

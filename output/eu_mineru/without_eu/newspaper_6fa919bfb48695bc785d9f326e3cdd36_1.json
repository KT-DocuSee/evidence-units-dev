  },
  {
    "chunk_id": "mineru_newspaper_6fa919bfb48695bc785d9f326e3cdd36_1_15",
    "text": "“一元公寓”折射怎样的万般无奈",
    "canon_role": "section_header",
    "bbox": [
      0.24449285887194383,
      0.28738258441228737,
      0.8864681675139191,
      0.3225861047643226
    ],
    "page": "newspaper_6fa919bfb48695bc785d9f326e3cdd36_1",
    "order": 15
  },
  {
    "chunk_id": "mineru_newspaper_6fa919bfb48695bc785d9f326e3cdd36_1_1",
    "text": "打击侵权假冒专项动 典型案例公布",
    "canon_role": "section_header",
    "bbox": [
      0.017913338174776083,
      0.3225861047643226,
      0.17090292907286372,
      0.3496657358043497
    ],
    "page": "newspaper_6fa919bfb48695bc785d9f326e3cdd36_1",
    "order": 16
  },
  {
    "chunk_id": "mineru_newspaper_6fa919bfb48695bc785d9f326e3cdd36_1_16",
    "text": "农民工说这毕竟比蹲马路边强得多",
    "canon_role": "support_paragraph",
    "bbox": [
      0.24546114742193173,
      0.326986544808327,
      0.6124425078673444,
      0.3466192773123466
    ],
    "page": "newspaper_6fa919bfb48695bc785d9f326e3cdd36_1",
    "order": 17
  },
  {
    "chunk_id": "mineru_newspaper_6fa919bfb48695bc785d9f326e3cdd36_1_24",
    "text": "提供了怎样的住宿环境?",
    "canon_role": "section_header",
    "bbox": [
      0.5378842895182765,
      0.35305068968435305,
      0.6347131445170661,
      0.3611745789963612
    ],

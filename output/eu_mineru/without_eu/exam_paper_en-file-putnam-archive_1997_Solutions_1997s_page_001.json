  {
    "chunk_id": "mineru_exam_paper_en-file-putnam-archive_1997_Solutions_1997s_page_001_12",
    "text": "A-3 Note that the series on the left is simply xexp(−x2/2). By integration by parts,",
    "canon_role": "support_paragraph",

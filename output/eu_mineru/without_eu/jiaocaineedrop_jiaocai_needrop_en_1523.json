  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_1523_8",
    "text": "图 3-5",
    "canon_role": "support_paragraph",
    "bbox": [
      0.31377293809235735,
      0.8242838820008551,
      0.38878806210929623,

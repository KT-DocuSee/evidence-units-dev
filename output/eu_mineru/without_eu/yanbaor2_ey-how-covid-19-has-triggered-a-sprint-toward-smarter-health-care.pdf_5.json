  {
    "chunk_id": "mineru_yanbaor2_ey-how-covid-19-has-triggered-a-sprint-toward-smarter-health-care.pdf_5_0",
    "text": "Building on the momentum of telehealth",
    "canon_role": "section_header",
    "bbox": [
      0.06588235294117648,
      0.05818181818181818,
      0.3333333333333333,
      0.07272727272727272

  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_11",
    "text": "Peter: Hi, Amy! What's the weather like in Shanghai today?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.127936031984008,
      0.45276292335115864,
      0.6626686656671664,
      0.471301247771836
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 12
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_12",
    "text": "Amy: Hello,Peter! It's sunny and warm here. I'm going to the zoo this afternoon.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.127936031984008,
      0.4819964349376114,
      0.8555722138930535,
      0.5005347593582887
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 13
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_13",
    "text": "Peter: That's cool!",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12993503248375812,
      0.5119429590017825,
      0.29985007496251875,
      0.5276292335115864
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 14
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_14",
    "text": "Amy: Peter,how is the weather in Beijing now?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13093453273363317,
      0.5397504456327986,
      0.5427286356821589,
      0.558288770053476
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 15
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_15",
    "text": "Peter: It's cloudy. It's going to rain. So I can't fly a kite in the park.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13093453273363317,
      0.5689839572192513,
      0.7556221889055472,
      0.5875222816399287
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 16
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_16",
    "text": "Amy: Oh,I see.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.13093453273363317,
      0.5989304812834224,
      0.26786606696651677,
      0.6160427807486631
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 17
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_17",
    "text": "Peter: Do you know the weather in Guangzhou?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12893553223388307,
      0.6267379679144385,
      0.5467266366816592,
      0.6452762923351159
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 18
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_18",
    "text": "Amy: It's very hot there. The children there usually go swimming in the sea. It's going to rain this afternoon.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12993503248375812,
      0.6566844919786097,
      0.9085457271364318,
      0.703030303030303
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_715",
    "order": 19
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_715_19",
    "text": "Peter: Oh,I like swimming too. But I can't swim now. It's a little cold.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.12893553223388307,
      0.7137254901960784,

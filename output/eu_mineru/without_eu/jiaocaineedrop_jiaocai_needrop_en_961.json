[
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_0",
    "text": "Let's try",
    "canon_role": "section_header",
    "bbox": [
      0.25151148730350664,
      0.1516317514607382,
      0.3675937122128174,
      0.17500356277611515
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 1
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_1",
    "text": "It's seven o'clock in the morning, and it's time to get up. Listen and circle.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.25070536074163646,
      0.17956391620350576,
      0.7787182587666264,
      0.2126264785520878
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 2
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_2",
    "text": "1. Who are the people talking?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2539298669891173,
      0.21604674362263077,
      0.5022168480451431,
      0.23200798061849792
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 3
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_3",
    "text": "A. Doctors. B. Parents.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.27166465135026197,
      0.23257802479692177,
      0.5352680370818218,
      0.24682912925751746
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 4
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_4",
    "text": "2. What are they talking about?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.25151148730350664,
      0.2519595268633319,
      0.5086658605401048,
      0.2673507196807753
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 5
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_5",
    "text": "A. Going to the zoo. B. Going to school.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.26924627166465137,
      0.26849080803762293,
      0.5981459089076985,
      0.28388200085506626
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 6
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_14",
    "text": "日",
    "canon_role": "support_paragraph",
    "bbox": [
      0.5449415558242644,
      0.2787516032492518,
      0.8246674727932285,
      0.5386917486105173
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 7
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_6",
    "text": "Let's talk",
    "canon_role": "section_header",
    "bbox": [
      0.25151148730350664,
      0.29357275188827137,
      0.3837162434502217,
      0.31637451902522445
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 8
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_7",
    "text": "Mum: Sarah, Sam, come here, please.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21604191858121724,
      0.3232150491663104,
      0.5167271261588069,
      0.3386062419837537
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 9
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_8",
    "text": "Sarah: What's wrong?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2079806529625151,
      0.3420265070542967,
      0.38694074969770254,
      0.35741769987174005
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 10
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_9",
    "text": "Mum: Your father is ill. He should see a doctor this morning, so we can't go to the zoo today.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21523579201934703,
      0.36083796494228304,
      0.5376864167674325,
      0.4149921618925467
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 11
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_10",
    "text": "Sam: Oh, no!",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2192664248286981,
      0.4178423827846658,
      0.32406287787182586,
      0.4332335756021092
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 12
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_11",
    "text": "Mum: Don't be sad. We can go next time.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21604191858121724,
      0.4366538406726521,
      0.5457476823861346,
      0.45318512184694315
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 13
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_12",
    "text": "Sam: How does Dad feel now?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.2192664248286981,
      0.45603534273906227,
      0.4651350261991133,
      0.47142653555650565
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 14
  },
  {
    "chunk_id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_13",
    "text": "Mum: Not well. Let's go to the hospital. How does Sam feel? What should he do?",
    "canon_role": "support_paragraph",
    "bbox": [
      0.21604191858121724,
      0.47427675644862477,
      0.5304312777106006,
      0.5261507766851931
    ],
    "page": "jiaocaineedrop_jiaocai_needrop_en_961",
    "order": 15
  },

  {
    "chunk_id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_1",
    "text": "Improving Access to Services for Persons with Limited English Proficiency (LEP)",
    "canon_role": "support_paragraph",
    "bbox": [
      0.08333333333333333,
      0.12088888888888889,
      0.9126666666666666,
      0.2604444444444444
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 2
  },
  {
    "chunk_id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_2",
    "text": "August 11, 2000: President Bill Clinton issued the Executive Order 13166.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10733333333333334,
      0.29333333333333333,
      0.9133333333333333,
      0.38666666666666666
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 3
  },
  {
    "chunk_id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_3",
    "text": "Designed to improve access to federally conducted and federally assisted programs/activities for LEP persons",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10933333333333334,
      0.4017777777777778,
      0.8686666666666667,
      0.496
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 4
  },
  {
    "chunk_id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_4",
    "text": "Federal agencies were asked to develop and implement a system to provide LEP persons access to services.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10866666666666666,
      0.5084444444444445,
      0.896,
      0.6017777777777777
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 5
  },
  {
    "chunk_id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_5",
    "text": "Each federal agency was asked to prepare a plan to improve access to LEP persons, and submit plans to the U.S. Department of Justice.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.10866666666666666,
      0.6151111111111112,
      0.9253333333333333,
      0.7564444444444445
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",
    "order": 6
  },
  {
    "chunk_id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_6",
    "text": "Executive Order charged the Department of Justice with the responsibility of providing LEP guidance to federal agencies.",
    "canon_role": "support_paragraph",
    "bbox": [
      0.108,
      0.7688888888888888,
      0.876,
      0.9111111111111111
    ],
    "page": "PPT_LEP power point presentation-English-FINAL-10-31-07_page_004",

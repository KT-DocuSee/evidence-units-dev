  },
  {
    "chunk_id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_37_4",
    "text": "(2)自然环境特征",
    "canon_role": "support_paragraph",
    "bbox": [
      0.1515574151557415,
      0.44466403162055335,
      0.33751743375174337,

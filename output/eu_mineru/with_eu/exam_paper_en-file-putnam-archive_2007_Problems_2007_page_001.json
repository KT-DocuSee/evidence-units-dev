      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2007_Problems_2007_page_001_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A–4 A repunit is a positive integer whose digits in base 10 are all ones. Find all polynomials f with real coeff - cients such that if n is a repunit, then so is f(n).",
        "bbox": [

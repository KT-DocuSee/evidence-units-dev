  {
    "eu_id": "EU-0004",
    "kind": "visual_panel",
    "page": "docstructbench_dianzishu_zhongwenzaixian-o.O-61510863.pdf_73",
    "primary_id": "mineru_docstructbench_dianzishu_zhongwenzaixian-o.O-61510863.pdf_73_2",

      },
      {
        "id": "mineru_jiaocai_jiaocai_en_932_2",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "袁宏道(15681610)，明代学家,字中郎,湖公安(今湖北省公安县),与兄宗道、弟中道 ，并称 “公安三袁”，为“公安派”的创始者。他主张学创作要“独抒性灵，不拘格套”，他性酷爱 然,写下了很多著名的游记。作品语清新流利,俊美潇洒,如云流般舒徐如 。",
        "bbox": [
          0.14590890769850867,
          0.2092062134815448,
          0.8512696493349455,
          0.2890123984608807
        ],
        "order": 3

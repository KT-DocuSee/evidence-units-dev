    "elements": [
      {
        "id": "mineru_docstructbench_llm-raw-scihub-o.O-j.ergon.2003.12.002.pdf_5_1",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "2.4.1. Electrogoniometry",
        "bbox": [
          0.08083480196933464,
          0.21958184932607838,
          0.27373603394161045,
          0.23440025633581374
        ],
        "order": 4
      },
      {
        "id": "mineru_docstructbench_llm-raw-scihub-o.O-j.ergon.2003.12.002.pdf_5_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Bilateral twin axis electrogoniometers (XM65 sensors) were used to measure wrist flexion/ extension and ulnar/radial deviation. The goni- ometers were taped to the forearm using double- sided medical tape and adhesive tape. The goniometers were positioned while the participants were sitting, elbows at 90° with their wrist in neutral and forearms in pronation resting on the desk surface. Reference lines were drawn over anatomical landmarks to enable accurate position- ing of the goniometers (Bucholz and Wellman, 1997; Biometrics, 1999). Left and right electro- goniometers were calibrated in a neutral position. Reference position (O° flexion and deviation) was defined as the wrist angles when the forearms were supported on the tabletop, elbows at 90°, forearms in pronation.",
        "bbox": [
          0.07899764737912249,
          0.23574738424578967,
          0.47582303886494703,
          0.5078672220609297
        ],
        "order": 5
      }
    ]
  },
  {
    "eu_id": "EU-0004",
    "kind": "section_text_panel",

      {
        "id": "mineru_newspaper_0ce88e1e131aef7a59d0533be36870de_1_8",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "家隆重彰 彰业先",
        "bbox": [
          0.010167029774872912,
          0.16755521706016754,
          0.0823045267489712,

        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "陈晓颖女士 德勤中国税务总监",
        "bbox": [
          0.054816606207174524,
          0.5204503349009548,
          0.18621523579201935,
          0.5518027647142654

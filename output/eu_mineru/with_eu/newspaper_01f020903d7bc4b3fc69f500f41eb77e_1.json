          0.07891551682401356,
          0.059236692900059236
        ],
        "order": 1
      },
      {
        "id": "mineru_newspaper_01f020903d7bc4b3fc69f500f41eb77e_1_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "“五”重庆新品种 引进筛选成绩突出",
        "bbox": [
          0.8206245461147422,
          0.0897012778200897,
          0.9581215202130234,
          0.11644241347211644
        ],
        "order": 4
      },
      {
        "id": "mineru_newspaper_01f020903d7bc4b3fc69f500f41eb77e_1_8",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "点在提高质量上下工夫。 我们不妨看看今年的种子供应 结构。",
        "bbox": [
          0.1718712176228516,
          0.12253533045612254,
          0.3113047688211087,
          0.14758398916814758
        ],
        "order": 5
      },
      {

    "member_count": 2,
    "elements": [
      {
        "id": "mineru_yanbaor2_07331c0c18a9d47c7318a99860c8ccf95726fefa629d6e446677b30938f2f14f.pdf_18_11",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "品牌展望",
        "bbox": [
          0.6626360338573156,
          0.28103177996294715,
          0.7295445384925433,
          0.294712840245119
        ],
        "order": 6
      },
      {
        "id": "mineru_yanbaor2_07331c0c18a9d47c7318a99860c8ccf95726fefa629d6e446677b30938f2f14f.pdf_18_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "茶百道通过推出中国特色茶饮与熊猫IP 成功塑造品牌，同时在定价模式上补了 新式茶饮业中端市场的空白。在蜜雪冰城 霸占10元以下低消市场，奈雪的茶、喜茶 等抢占20元以上高端赛道的情况下，腰部 消费区尚未出现统治力量，我们认为茶百 道强势入局，有望跻身腰部前列。",
        "bbox": [
          0.6610237807335752,
          0.2969930169588143,
          0.9431680773881499,
          0.4070115433946131
        ],
        "order": 7
      }
    ]
  },
  {
    "eu_id": "EU-0005",
    "kind": "section_text_panel",
    "page": "yanbaor2_07331c0c18a9d47c7318a99860c8ccf95726fefa629d6e446677b30938f2f14f.pdf_18",
    "primary_id": "mineru_yanbaor2_07331c0c18a9d47c7318a99860c8ccf95726fefa629d6e446677b30938f2f14f.pdf_18_3",

  {
    "eu_id": "EU-0004",
    "kind": "section_text_panel",
    "page": "newspaper_14b9d21f7fed39fb42849e9cde233930_1",
    "primary_id": "mineru_newspaper_14b9d21f7fed39fb42849e9cde233930_1_43",

          0.22002635046113306
        ],
        "order": 2
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_103_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(1) 自然原因：山区面积广大.岩石破碎.风化严重；干湿季分明、暴雨集中：地 壳运动强烈山体中断层发育。",
        "bbox": [
          0.10320781032078104,
          0.22924901185770752,
          0.9344490934449093,
          0.2839262187088274
        ],
        "order": 3
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_103_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(2)人为原因：对植被的破坏 治理措施：恢复植被",
        "bbox": [
          0.13482101348210135,
          0.29117259552042163,
          0.4583914458391446,
          0.3458498023715415
        ],
        "order": 4
      }
    ]

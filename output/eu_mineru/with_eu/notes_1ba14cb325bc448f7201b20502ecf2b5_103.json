      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_103_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "形成原因：",
        "bbox": [
          0.13575081357508137,
          0.19894598155467721,

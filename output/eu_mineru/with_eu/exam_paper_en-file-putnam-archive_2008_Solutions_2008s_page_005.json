      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2008_Solutions_2008s_page_005_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "By precomposing with a suitable rotation that fixes eh for h ≠ i, j, we can vary |wil, |wj| without varying |wi|2 + |wj|2 or |wh| for h ≠ i, j. We can thus choose such a rotation to force one of |wi|2, |wj|2 to become equal to n (|w1|2 + . .· + |wn|2). Repeating at most n − 1 times gives the desired configuration.",
        "bbox": [
          0.12627450980392158,
          0.14545454545454545,
          0.49019607843137253,
          0.2381818181818182
        ],

    "elements": [
      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2008_Solutions_2008s_page_005_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Remark: After showing that f' (q) is an integer for each q, one can instead argue that f' is a continuous function from the rationals to the integers, so must be constant. One can then write f (x) = ax + b and check that b ∈ Z by evaluation at a = 0, and that a = ±1 by evaluation at x = 1/a.",
        "bbox": [
          0.556078431372549,
          0.28424242424242424,
          0.9192156862745098,
          0.3715151515151515
        ],
        "order": 6
      }
    ]
  },
  {
    "eu_id": "EU-0006",
    "kind": "text_cluster_panel",
    "page": "exam_paper_en-file-putnam-archive_2008_Solutions_2008s_page_005",
    "primary_id": "mineru_exam_paper_en-file-putnam-archive_2008_Solutions_2008s_page_005_3",

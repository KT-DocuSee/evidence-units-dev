    "source": "visual_seed",
    "member_count": 13,
    "elements": [
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_0",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "的组成条件是什么？",
        "bbox": [
          0.05018450184501845,
          0.028925619834710745,
          0.24305043050430505,
          0.049586776859504134
        ],
        "order": 1
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "化学电池的反应本质是氧化还原反应",
        "bbox": [
          0.09348093480934809,
          0.07782369146005509,
          0.46051660516605164,
          0.09986225895316804
        ],
        "order": 2
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_9",
        "observed_type": "image_body",
        "canon_role": "picture",
        "text": "",
        "bbox": [
          0.6691266912669127,
          0.08057851239669421,
          0.9505535055350554,
          0.2128099173553719
        ],
        "order": 3
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_8",
        "observed_type": "image_caption",
        "canon_role": "support_paragraph",
        "text": "图2-10水果电池",
        "bbox": [
          0.7389913899138991,
          0.22589531680440772,
          0.8816728167281673,
          0.24449035812672176
        ],
        "order": 6
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "利用水果如苹果、柑橘、柠檬或番茄等制作原电池",
        "bbox": [
          0.09249692496924969,
          0.23071625344352617,
          0.5943419434194342,
          0.2513774104683196
        ],
        "order": 7
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_7",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "最早使用的化学电池是锌锰电池，也是最普通的干电池， 构造如图2-11所示。它是一种一次性电池，放完电之后不能 再使用（内部的氧化还原反应是不可逆的）。电池在使用过程 中，锌会逐渐溶解：",
        "bbox": [
          0.046248462484624844,
          0.3464187327823691,
          0.6573185731857318,
          0.44214876033057854
        ],
        "order": 10
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_15",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "化学电源chemical power source 干电池 dry cell",
        "bbox": [
          0.6848708487084871,
          0.37052341597796146,
          0.9121771217712177,
          0.4380165289256198
        ],
        "order": 11
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "锌外壳逐渐变薄，最后内部糊状的电解质会泄漏出来，使 电器腐蚀。为了防止泄漏，后来在外壳套上金属筒或塑料筒制 成了防漏电池。",
        "bbox": [
          0.04920049200492005,
          0.49793388429752067,
          0.6514145141451414,
          0.5695592286501377
        ],
        "order": 13
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "锌锰干电池即使不用，放置过久，也可能会漏液失效（作 为电解质的NHCI的水溶液显酸性）使用和保存时应注意 什么？",
        "bbox": [
          0.04920049200492005,
          0.6342975206611571,
          0.6484624846248462,
          0.7038567493112947
        ],
        "order": 16
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_17",
        "observed_type": "image_caption",
        "canon_role": "support_paragraph",
        "text": "图2-11干电池构造示意图",
        "bbox": [
          0.7242312423124231,
          0.7293388429752066,
          0.9328413284132842,
          0.7472451790633609
        ],
        "order": 17
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "为了延长电池寿命和提高其性能，人们将电池内的电解 质NHCI换成湿的KOH，并在构造上作了改进，制成了碱 性锌锰电池。现在各类碱性电池已经占有了越来越大的市场 份额，广泛用于卡式录音机、闪光灯、电动玩具、袖珍电视 机等。",
        "bbox": [
          0.04920049200492005,
          0.7327823691460055,
          0.6494464944649446,
          0.8533057851239669
        ],
        "order": 18
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "充电电池又称二次电池，它在放电时所进行的氧化还原反",
        "bbox": [
          0.0954489544895449,
          0.8822314049586777,
          0.6455104551045511,
          0.9042699724517906
        ],
        "order": 20
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_250_20",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "蓄电池storage battery",
        "bbox": [
          0.6868388683886839,
          0.8836088154269972,
          0.9062730627306274,
          0.9028925619834711
        ],
        "order": 21
      }
    ]
  },

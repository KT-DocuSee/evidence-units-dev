  {
    "eu_id": "EU-0006",
    "kind": "section_text_panel",
    "page": "newspaper_d7fe1132386670993aae3dabc6247bc9_1",
    "primary_id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_15",
    "source": "header_anchor",
    "member_count": 9,
    "elements": [
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_15",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "Submission for OMB Review; Comment Request",
        "bbox": [
          0.3631372549019608,
          0.3472727272727273,
          0.5686274509803921,
          0.37333333333333335
        ],
        "order": 15
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_7",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Notice is hereby given, pursuant to the provisions of the rules and regulations of the U.S. Commission on Civil Rights (Commission) and the Federal Advisory Committee Act (FACA) that the Oregon Advisory Committee (Committee) will meet on Thursday, August 22, 2013. The meeting will convene at 2:00 p.m. and adjourn at approximately 4:00 p.m. The meeting l eeaeHile 1525 SW Sunset Boulevard, Portland, OR 97329. The purpose of the meeting is for the Committee to plan future activities.",
        "bbox": [
          0.07215686274509804,
          0.3490909090909091,
          0.34509803921568627,
          0.5375757575757576
        ],
        "order": 16
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_16",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The Department of Commerce will submit to the Office of Management and Budget (OMB) for clearance the following proposal for collection of information under the provisions of the Paperwork Reduction Act (44 U.S.C. Chapter 35).",
        "bbox": [
          0.3607843137254902,
          0.38303030303030305,
          0.6329411764705882,
          0.4703030303030303
        ],
        "order": 17
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_17",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Agency: National Oceanic and Atmospheric Administration (NOAA). Title: Alaska American Fisheries Act (AFA): Permits. OMB Control Number: 0648–0393. Form Number(s): NA. Type of Request: Regular submission (revision and extension of a current information collection).",
        "bbox": [
          0.36,
          0.4715151515151515,
          0.6274509803921569,
          0.583030303030303
        ],
        "order": 18
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The meeting is open to the public, and members of the public are entitled to submit written comments. Written comments may be mailed to the Western Regional Office, U.S. Commission on Civil Rights, 300 N Los Angeles St., Suite 2010, Los Angeles, CA, 90012. They may also be faxed to the Commission at (213) 894–0507 or emailed to the Commission at atrevino@usccr.gov.Submitted comments must be received by September 30, 2013. Persons who desire additional information may contact the Western Regional Office at (213) 894– 3437.",
        "bbox": [
          0.07215686274509804,
          0.5406060606060606,
          0.3474509803921569,
          0.7412121212121212
        ],
        "order": 19
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_26",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Revision: The notary signature requirements have been removed from the Application for Replacement Vessel and the Application for Inshore Catcher Vessel Cooperative Permit.",
        "bbox": [
          0.6501960784313725,
          0.5654545454545454,
          0.9207843137254902,
          0.6290909090909091
        ],
        "order": 20
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_18",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Number of Respondents: 27.",
        "bbox": [
          0.3756862745098039,
          0.583030303030303,
          0.5701960784313725,
          0.5963636363636363
        ],
        "order": 21
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Average Hours per Response: Application for AFA Permit for Replacement Vessel, 30 minutes; Application for AFA Cooperative Permit, 2 hours; Vessel Contract Fishing Notification, 4 hours; Approval as an Entity Eligible to Receive Transferable Chinook Salmon Prohibited Species Quota (PSC) Allocation, 8 hours; Application to Transfer Bering Sea Chinook Salmon PSC Allocation, 15 minutes.",
        "bbox": [
          0.3607843137254902,
          0.5963636363636363,
          0.6337254901960784,
          0.7454545454545455
        ],
        "order": 22
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_27",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Affected Public: Business or other for- profit organizations.",
        "bbox": [
          0.6494117647058824,
          0.6333333333333333,
          0.9231372549019607,
          0.6587878787878788
        ],
        "order": 23
      }
    ]
  },
  {
    "eu_id": "EU-0007",
    "kind": "text_cluster_panel",
    "page": "newspaper_d7fe1132386670993aae3dabc6247bc9_1",
    "primary_id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_28",

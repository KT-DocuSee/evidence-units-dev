      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Tuesday, August 6, 2013",
        "bbox": [
          0.6517647058823529,
          0.11333333333333333,
          0.8094117647058824,
          0.12484848484848485
        ],
        "order": 4
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "This section of the FEDERAL REGISTER contains documents other than rules or proposed rules that are applicable to the public. Notices of hearings and investigations, committee meetings, agency decisions and rulings, delegations of authority, filing of petitions and applications and agency statements of organization and functions are examples of documents appearing in this section.",
        "bbox": [
          0.07294117647058823,
          0.15272727272727274,
          0.3411764705882353,
          0.26666666666666666
        ],
        "order": 5
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Western Regional Office at the above email or street address.",
        "bbox": [
          0.3623529411764706,
          0.15272727272727274,
          0.6125490196078431,
          0.17757575757575758
        ],
        "order": 6
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_23",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.6509803921568628,
          0.15272727272727274,
          0.912156862745098,
          0.19151515151515153
        ],
        "order": 7
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The meeting will be conducted pursuant to the rules and regulations of the Commission and FACA.",
        "bbox": [
          0.3615686274509804,
          0.17757575757575758,
          0.6298039215686274,
          0.21515151515151515
        ],
        "order": 8
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_24",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "With the exceptions of the inshore vessel cooperatives, replacement vessel, and inshore vessel contract fshing applications, the AFA permit program had a one-time application deadline of December 1, 2000. All permitted participants in the AFA pollock fishery are already established and are issued with an indefinite expiration date.",
        "bbox": [
          0.6509803921568628,
          0.19515151515151516,
          0.9215686274509803,
          0.31212121212121213
        ],
        "order": 9
      },
      {
        "id": "mineru_newspaper_d7fe1132386670993aae3dabc6247bc9_1_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Dated in Chicago, IL, July 31, 2013. David Mussatt, Acting Chief, Regional Programs Coordination Unit. [FRDoc.2013–18836 Filed8-5–13;8:45 am] BILLING C0DE 6335-01-P",
        "bbox": [
          0.3607843137254902,
          0.22,
          0.5992156862745098,
          0.29818181818181816
        ],
        "order": 10
      }
    ]
  },

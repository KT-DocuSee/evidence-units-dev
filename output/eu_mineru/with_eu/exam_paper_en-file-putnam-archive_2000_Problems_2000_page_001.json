      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2000_Problems_2000_page_001_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A–5 Three distinct points with integer coordinates lie in the plane on a circle of radius r > 0. Show that two of these points are separated by a distance of at least r1/3.",

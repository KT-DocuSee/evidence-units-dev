      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3361_12",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "地理位置：埃及首都开罗郊升的沙漠中。 外观：近权汉字“全”，气势伟 功用：古填及法老胡夫的陵基。 特点：高、占地面积大、体积大、使用石料多 石块贴合紧密、设计巧节 评价：现存规模最大的全宇塔，古续及人民 劳动和智慧的结晶。",
        "bbox": [
          0.5537459283387622,
          0.12808641975308643,
          0.9011943539630836,
          0.27314814814814814
        ],
        "order": 6
      }
    ]
  },

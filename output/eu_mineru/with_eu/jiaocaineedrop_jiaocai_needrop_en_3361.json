        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "3.(1)澄(chèng) 橙（dèng) (2)哗（huā） 哗(huá）",
        "bbox": [
          0.5168295331161781,
          0.7391975308641975,

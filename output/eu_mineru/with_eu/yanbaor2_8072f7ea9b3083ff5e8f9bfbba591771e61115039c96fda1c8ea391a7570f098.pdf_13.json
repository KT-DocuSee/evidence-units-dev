    "elements": [
      {
        "id": "mineru_yanbaor2_8072f7ea9b3083ff5e8f9bfbba591771e61115039c96fda1c8ea391a7570f098.pdf_13_5",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "正是渠道。",
        "bbox": [
          0.05642885933091495,
          0.5312811742910075,
          0.12817412333736397,
          0.546102322930027

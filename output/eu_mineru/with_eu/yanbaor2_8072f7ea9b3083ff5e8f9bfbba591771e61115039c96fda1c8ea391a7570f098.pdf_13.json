        "id": "mineru_yanbaor2_8072f7ea9b3083ff5e8f9bfbba591771e61115039c96fda1c8ea391a7570f098.pdf_13_8",
        "observed_type": "image_caption",
        "canon_role": "support_paragraph",
        "text": "近2年间银营业机构平均退出比例",

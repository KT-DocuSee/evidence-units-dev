    "elements": [
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_0",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "四、典题导引",
        "bbox": [
          0.02799650043744532,
          0.059555555555555556,
          0.25746781652293466,
          0.136
        ],
        "order": 1
      },
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "高加林一直低着头，像一个受审的犯人一样。",
        "bbox": [
          0.05849268841394826,
          0.21688888888888888,
          0.5334333208348956,
          0.2728888888888889
        ],
        "order": 2
      },
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "老半天，他才抬起头，叹了一口气说，“你们说得也许都对，但我已经上了这钩杆，下 不来了。再说，你们有你们的活法，我有我的活法！我不愿意再像你们一样，就在咱高家村的 土里刨挖一生.我给你们买饭去. 1 两个老人看他们再说什么也不顶事了一 -这个人已经 有了他自己的一套，用他们的生活哲学已经不能说服他了。于是他们就起身告别。",
        "bbox": [
          0.005999250093738283,
          0.2773333333333333,
          0.9948756405449319,
          0.52
        ],
        "order": 3
      },
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "两位老人心情相当沉重地走了。",
        "bbox": [
          0.06399200099987501,
          0.5253333333333333,
          0.38995125609298836,
          0.5795555555555556
        ],
        "order": 4
      },
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "高加林自己也很难过。德顺爷和他爸说的话，听起来道理很一般，但却像铅一样，沉甸 甸地灌在了他的心里..",
        "bbox": [
          0.0029996250468691415,
          0.5857777777777777,
          0.9803774528183977,
          0.7013333333333334
        ],
        "order": 5
      },
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "不久，一个新的消息突然又使高加林欣喜若狂了：省报要办一个短期新闻培训班，让各 县去一个人学习，时间是一个月。县委宣传部已决定让他去。",
        "bbox": [
          0.009998750156230472,
          0.7084444444444444,
          0.9853768278965129,
          0.8248888888888889
        ],
        "order": 6
      },
      {
        "id": "mineru_yanbaopptmerge_yanbaoPPT_2950_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "他一晚上高兴得没睡着觉——这可是他有生以来第一次出远门，进省会，去逛大城市呀",
        "bbox": [
          0.017497812773403325,
          0.8302222222222222,
          0.9868766404199475,
          0.9466666666666667
        ],
        "order": 7
      }
    ]
  }
]
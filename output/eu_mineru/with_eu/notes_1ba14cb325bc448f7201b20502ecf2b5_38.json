          0.5909838762750905,
          0.9409576940957695,
          0.6456071076011846
        ],
        "order": 10
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_38_10",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "②分布：欧洲部分(非常密集，以莫斯科为中心呈放射状)和亚洲部分(比较稀疏。 但有一条非常重要的铁路—亚欧大陆桥)的分市不平衡。",
        "bbox": [
          0.10413761041376104,
          0.6541625534715367,
          0.9381682938168294,
          0.7087857847976308
        ],
        "order": 11
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_38_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "③河运：伏尔加河",
        "bbox": [
          0.17387261738726173,
          0.7193155643303718,
          0.34774523477452346,
          0.7397170121750576
        ],
        "order": 12

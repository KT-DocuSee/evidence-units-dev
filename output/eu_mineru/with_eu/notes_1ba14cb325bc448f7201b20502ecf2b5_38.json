      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_38_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "海运：圣彼得堡(波罗的海)、摩尔曼斯克(北冰洋）、答拉迪沃斯托克(太平洋） ④西伯利亚大铁路沿着南部山区修建的原因：有普丰富的矿产资源：北部地区冻 土层很深、难度大。",
        "bbox": [
          0.14504881450488144,
          0.7469562356038171,
          0.9381682938168294,
          0.8338269167489306
        ],
        "order": 13
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_38_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(2)重要的城市",
        "bbox": [
          0.14597861459786146,
          0.8423823626192827,

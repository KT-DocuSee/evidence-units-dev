        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "7.4.2全玻幕墙胶缝承载力应符合下列要求：",
        "bbox": [
          0.06959272439699486,
          0.18568232662192394,
          0.3368920521945433,
          0.21252796420581654
        ],

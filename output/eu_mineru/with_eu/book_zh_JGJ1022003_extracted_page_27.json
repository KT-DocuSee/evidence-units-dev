    "elements": [
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_9",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "8.1玻璃面板",
        "bbox": [
          0.6737841043890866,
          0.19910514541387025,
          0.7844998022933966,
          0.22371364653243847
        ],
        "order": 5
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1与玻璃面板平齐或突出的玻璃助：",
        "bbox": [
          0.09489916963226572,
          0.21700223713646533,
          0.3147489126136813,
          0.23937360178970918
        ],
        "order": 6
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_10",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "8.1.1四边形玻璃面板可采用四点支承，有据时也可采用六 点支承；三角形玻璃面板可采用三点支承。玻璃面板支承孔边与 板边的距离不宜小于70mm。",
        "bbox": [
          0.5393436140767102,
          0.24161073825503357,
          0.918940292605773,
          0.3243847874720358
        ],
        "order": 7
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "2后置或骑缝的玻璃助：",
        "bbox": [
          0.09648082245947015,
          0.2975391498881432,
          0.24990114669829971,
          0.319910514541387
        ],
        "order": 8
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "8.1.2采用浮头式连接件的幕墙玻璃厚度不应小于6mm；果用 沉头式连接件的幕墙玻璃厚度不应小于8mm。",
        "bbox": [
          0.5377619612495057,
          0.3288590604026846,
          0.918940292605773,
          0.38031319910514544
        ],
        "order": 9
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "式中 9 垂直于玻璃面板的分布荷载设计值（N/mm），抗震 设计时应包含地震作用计算的分布荷载设计值： I- 两肋之间的玻璃面板跨度（mm）； 1 胶建宽度，取表璃面板截面厚度（mm）： ——胶缝宽度，取玻璃肋截面厚度（mm)； f——硅酮结构密封胶在风荷载作用下的强度设计值， 取0.2N/mm²。",
        "bbox": [
          0.06959272439699486,
          0.37360178970917224,
          0.44918940292605775,
          0.5749440715883669
        ],
        "order": 10
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "安装连接件的夹层玻璃和中空玻璃，其单片厚度也应符合上 述要求。",
        "bbox": [
          0.5393436140767102,
          0.3870246085011186,
          0.9173586397785686,
          0.436241610738255
        ],
        "order": 11
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "8.1.3玻璃之间的空隙宽度不应小于10mm，且应果用硅酮建筑 密封胶嵌缝。",
        "bbox": [
          0.5377619612495057,
          0.4429530201342282,
          0.9173586397785686,
          0.49217002237136465
        ],
        "order": 12
      },
      {
        "id": "mineru_book_zh_JGJ1022003_extracted_page_27_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "8.1.4点支承玻璃支承孔周边应进行可靠的密封。当点支承玻 璃为中空玻璃时，其支承孔周边应采取多道密封措施。",
        "bbox": [
          0.5377619612495057,
          0.4988814317673378,
          0.918940292605773,
          0.5525727069351231
        ],
        "order": 13
      }
    ]
  },

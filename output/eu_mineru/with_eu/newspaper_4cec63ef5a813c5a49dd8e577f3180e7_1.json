    ]
  },
  {
    "eu_id": "EU-0016",
    "kind": "section_text_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_45",
    "source": "header_anchor",
    "member_count": 5,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_45",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "注意事项",
        "bbox": [
          0.6230936819172114,
          0.7084708470847084,
          0.6613410796417333,
          0.7155792502327156
        ],
        "order": 51
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_41",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "温室：采用退行水平喷撒 法，即从温室的里端开始，操作 人员站在过道上，背向温室北 墙，面向南边，一边对空喷撒，一 边退行，直到退出门口，把门关 上。如有余药可从上部放风口 把喷粉管伸入室内进行喷撒，直 到把余粉喷完。",
        "bbox": [
          0.4337932703945776,
          0.7165947363967166,
          0.5693536673928831,
          0.7826013370567826
        ],
        "order": 52
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_46",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "喷粉时必须把粉剂均匀地 喷到棚室的空间，不宜把喷粉管 对准植株逐行喷撒，否则沉积不 均匀。",
        "bbox": [
          0.5751633986928104,
          0.7165947363967166,
          0.709755507141128,
          0.7487517982567488
        ],
        "order": 53
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_37",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "喷粉前棚室的准备：喷粉前 把棚室的通风口和门关闭，把棚 室的塑料布盖严，尽量达到密闭 状态，如果棚布有小块破损对粉 尘无影响。",
        "bbox": [
          0.29387557492132654,
          0.7416433951087417,
          0.42846768336964414,
          0.7829398324447829
        ],
        "order": 54
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_47",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "操作时应遵守农药安全操作 规程，要求穿长袖工作服，配戴风 镜、口罩及防护帽，工作结束后必 须清洗手脸及其他裸露体肤。",
        "bbox": [
          0.5751633986928104,
          0.7497672844207498,
          0.710239651416122,
          0.7829398324447829
        ],
        "order": 55
      }
    ]
  },
  {
    "eu_id": "EU-0017",
    "kind": "section_text_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_33",
    "source": "header_anchor",
    "member_count": 7,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_33",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "喷药准备",
        "bbox": [
          0.2018881626724764,
          0.7585681645087585,
          0.23965141612200436,
          0.7656765676567657
        ],
        "order": 56
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_34",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "选择适宜的粉尘剂：防治黄 瓜霜霉病、番茄晚疫病，选用10% 的防霉灵或5%的百菌清粉尘剂；",
        "bbox": [
          0.1539578794480755,
          0.7666920538207667,
          0.2861292665214234,
          0.7917407125327918
        ],
        "order": 57
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_60",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(中化化肥公司高级顾问、中国农业大学教授王兴仁）",
        "bbox": [
          0.7630113773904623,
          0.7748159431327748,
          0.971677559912854,
          0.7829398324447829
        ],
        "order": 58
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_38",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "喷药时间：喷粉的最佳时间 是早晨或傍晚，趁尚未揭棚或刚 刚闭棚后进行，这样药粉在作物 上的沉积率较高。晴天的中午 应避免喷粉，阴天则任何时间均 可喷粉。喷粉后2小时左右即 可打开通风。第1次喷药在发 病初期，根据病情每隔7~10天 喷1次。",
        "bbox": [
          0.3117889130961026,
          0.7832783278327833,
          0.4279835390946502,
          0.7917407125327918
        ],
        "order": 59
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_42",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "大棚：采用左右对空摆动喷 撒法，即从北端开始，操作人员站 在过道上摆动喷粉管向左右两侧 喷粉，一边喷，一边退行，直到退 出南端的门口，把门关上。",
        "bbox": [
          0.44880174291938996,
          0.7832783278327833,
          0.5683853788428952,
          0.7917407125327918
        ],
        "order": 60
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_48",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "冯国明",
        "bbox": [
          0.6608569353667393,
          0.7832783278327833,
          0.6899055918663762,
          0.7907252263687907
        ],
        "order": 61
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_61",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1",
        "bbox": [
          0.002904865649963689,
          0.8035880511128036,
          0.34325829097070926,
          0.9965304222729965
        ],
        "order": 62
      }
    ]
  },
  {
    "eu_id": "EU-0018",
    "kind": "section_text_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_63",
    "source": "header_anchor",
    "member_count": 9,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_63",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "果树休眠期防治病害功效高",
        "bbox": [
          0.47978697651900265,
          0.8238977743928239,
          0.9818445896877269,
          0.858085808580858
        ],
        "order": 63
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_62",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "江苏省徐州市铜 山区大彭镇果农加强 果树秋冬季科学管 理，比如他们剪去果 树表层根须，有利于 根系深入下层土壤和 提高抗旱能力。图为 周棚村葡萄科技种植 示范户黄曙光把鸡 蛋、牛奶和溶磷菌等 发酵成的营养液肥用 注射枪为葡萄树补充 营养，既不伤根系、保 持水分，又促进枝条 老熟和明年树体芽率 整齐。黄全智摄",
        "bbox": [
          0.3495521665456306,
          0.856054836252856,
          0.4366981360445413,
          0.9914529914529915
        ],
        "order": 64
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_64",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "冬季休眠期的病害防治是 果树生产中的重要环节，尤其是 北方果树如苹果、梨等主要病害 干腐病、轮纹病的病菌主要在树 干或枝条上休眠越冬，待春季萌 动时开始侵染，因此，在冬季防 治病害，是防止来年发病的最佳 时机，冬季树叶已落，树干和枝 条暴露在外，此时用药少、效果 好。",
        "bbox": [
          0.4609053497942387,
          0.8638402301768638,
          0.5901718712176228,
          0.9471100956249471
        ],
        "order": 65
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_67",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.5959816025175503,
          0.8638402301768638,
          0.7262164124909223,
          0.9552339849369552
        ],
        "order": 66
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_72",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.869523117889131,
          0.8638402301768638,
          0.9987896393125151,
          0.9220614369129221
        ],
        "order": 67
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_69",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.7334785766158315,
          0.8641787255648642,
          0.8617768094892277,
          0.8973512735888973
        ],
        "order": 68
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_70",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "修剪和清园果树主要病 害如轮纹病、干腐病、炭疽病、斑 点落叶病以及螨类等害虫大都 在枯枝、落叶及僵果上越冬，待 来年春天再侵染发病。因此，冬 季修剪结合清园，剪除病枝僵 果，清除枯枝落叶，集中烧毁或 深埋，能大大降低病虫的越冬基 数，可有效降低来年的发病 率。",
        "bbox": [
          0.7329944323408376,
          0.8976897689768977,
          0.8627450980392157,
          0.9802826436489803
        ],
        "order": 69
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_73",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "刮皮涂白刮除果树枝干上 的粗皮、翘皮，然后对刮白部分 喷施绿亨6号2000倍液，对防治 干腐病、轮纹病和腐烂病是非常 有效的。",
        "bbox": [
          0.8704914064391188,
          0.9234154184649234,
          0.9978213507625272,
          0.964034865024964
        ],
        "order": 70
      },
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_65",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "症状识别干腐病和轮纹病是 由两种不同真菌引起的重要病害。 危害苹果、梨树的树干、枝条和果 实，造成树皮坏死和果实腐烂。",
        "bbox": [
          0.4609053497942387,
          0.9477870864009478,
          0.5896877269426289,
          0.9809596344249809
        ],
        "order": 71
      }
    ]
  },
  {
    "eu_id": "EU-0019",
    "kind": "text_cluster_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_68",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_68",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "保护伤口冬剪留在树上的 伤口，是苹果树腐烂病、轮纹病、 银叶病等病菌的侵入途径，同时 也是一些害虫的越冬场所。可 采用清漆加入适量的猪油调和， 涂抹保护伤口，阻止病菌的侵 。早春用40%胺硫磷100倍 封闭锯剪口，消灭其内越冬的苹 果小卷叶蛾等害虫。",
        "bbox": [
          0.5969498910675382,
          0.9562494711009563,
          0.7262164124909223,
          0.9992383853769993
        ],
        "order": 72
      }
    ]
  },
  {
    "eu_id": "EU-0020",
    "kind": "text_cluster_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_74",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_74",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "清除附近的杨树及其它树 种的溃疡病株，剪除刺槐和桧柏 上的冬孢子角，能有效地降低苹 果和梨树的锈病。 冯雪",
        "bbox": [
          0.8700072621641249,
          0.9650503511889651,
          0.9973372064875333,
          0.9978844038249979
        ],
        "order": 73
      }
    ]
  },
  {
    "eu_id": "EU-0021",
    "kind": "text_cluster_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_66",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_66",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "干腐病和轮纹病在症状上 明显不同。干腐病的症状是表 面湿润，呈现暗褐色外围轮廓不 整齐的斑块，常有茶褐色黏液溢 出，后期干缩下陷边缘裂开，灰 黑色的病皮表面密生隆起的小 黑点，造成枝条枯死；轮纹病的 症状起初形成暗褐色近圆形病 斑，在树皮浅层引起皮层坏死， 后期病部失水，边缘干裂翘起， 表面散生小黑点，发病严重时， 主干及枝条上病斑密布，生长停 止甚至枯死。",
        "bbox": [
          0.45993706124425077,
          0.9812981298129813,
          0.5896877269426289,
          0.9995768807649996
        ],
        "order": 74
      }
    ]
  },
  {
    "eu_id": "EU-0022",
    "kind": "text_cluster_panel",
    "page": "newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1",
    "primary_id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_71",
    "source": "text_cluster",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_4cec63ef5a813c5a49dd8e577f3180e7_1_71",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "喷施药剂在入冬至春季萌 芽前是集中防治越冬病虫的最 佳时期，此时喷药既安全又省 药，除常用的石硫合剂外，用绿 亨多·锰锌1500~2000倍液喷雾， 或用绿亨碱式硫酸铜500~800倍 液喷雾，苹果树用绿亨一号与绿 亨2号混合按比例1:9兑500 倍效果更佳。",
        "bbox": [
          0.7349310094408134,
          0.9812981298129813,
          0.8612926652142339,
          0.9995768807649996
        ],
        "order": 75
      }
    ]
  }
]
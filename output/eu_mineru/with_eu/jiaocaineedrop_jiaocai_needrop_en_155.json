        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_155_21",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A.孔子 B.孟子 C.荀子 D.韩非子",
        "bbox": [
          0.5281977441804656,
          0.7755710029791459,
          0.8960883129349652,
          0.7934458788480635
        ],

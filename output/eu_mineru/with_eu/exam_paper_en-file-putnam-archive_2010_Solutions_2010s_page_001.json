      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A-4 Put",
        "bbox": [
          0.09333333333333334,
          0.8393939393939394,
          0.15215686274509804,
          0.8527272727272728
        ],
        "order": 24
      },
      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2010_Solutions_2010s_page_001_20",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Write n = 2mk with m a nonnegative integer and k a positive odd integer. For any nonnegative integer j,",
        "bbox": [
          0.12705882352941175,
          0.8951515151515151,
          0.4894117647058824,
          0.9248484848484848
        ],
        "order": 25
      }
    ]

      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_7",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Sarah, Sam, come here, please.",
        "bbox": [
          0.21604191858121724,
          0.3232150491663104,
          0.5167271261588069,
          0.3386062419837537
        ],
        "order": 9
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sarah: What's wrong?",
        "bbox": [
          0.2079806529625151,
          0.3420265070542967,
          0.38694074969770254,
          0.35741769987174005
        ],
        "order": 10
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Your father is ill. He should see a doctor this morning, so we can't go to the zoo today.",
        "bbox": [
          0.21523579201934703,
          0.36083796494228304,
          0.5376864167674325,
          0.4149921618925467
        ],
        "order": 11
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_10",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sam: Oh, no!",
        "bbox": [
          0.2192664248286981,
          0.4178423827846658,
          0.32406287787182586,
          0.4332335756021092
        ],
        "order": 12
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Don't be sad. We can go next time.",
        "bbox": [
          0.21604191858121724,
          0.4366538406726521,
          0.5457476823861346,
          0.45318512184694315
        ],
        "order": 13
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Sam: How does Dad feel now?",
        "bbox": [
          0.2192664248286981,
          0.45603534273906227,
          0.4651350261991133,
          0.47142653555650565
        ],
        "order": 14
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_961_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Mum: Not well. Let's go to the hospital. How does Sam feel? What should he do?",
        "bbox": [
          0.21604191858121724,
          0.47427675644862477,
          0.5304312777106006,
          0.5261507766851931

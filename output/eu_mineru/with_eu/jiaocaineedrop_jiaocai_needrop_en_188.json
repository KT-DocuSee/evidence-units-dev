    "source": "header_anchor",
    "member_count": 5,
    "elements": [
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_188_13",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "登快阁",
        "bbox": [
          0.25650332728372655,
          0.5478124554652986,
          0.31054648114539224,
          0.5614935157474704
        ],
        "order": 28
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_188_31",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "冰姿琼骨净无瑕，竹外溪边处士②家。 若使牡丹开得早，有谁风雪看梅花?",
        "bbox": [
          0.5823754789272031,
          0.5478124554652986,
          0.8606573906029441,
          0.5780247969217615
        ],
        "order": 29
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_188_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "黄庭坚",
        "bbox": [
          0.2573099415204678,
          0.5637736924611657,
          0.30973986690865096,
          0.5780247969217615
        ],
        "order": 30
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_188_15",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "痴儿了却公家事，快阁东西倚晚晴。 落木千山天远大，澄江一道月分明。 朱弦已为佳人绝，青眼聊因美酒横。 万里归船弄长笛，此心吾与白鸥盟。",
        "bbox": [
          0.14922363379713652,
          0.5803049736354567,
          0.41782617463198224,
          0.6435798774405016
        ],
        "order": 31
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_188_32",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "【注】①这首诗是唱和萧冰崖的《梅花》诗而 作。②处士：指隐居的读书人。",
        "bbox": [
          0.5251058681185723,
          0.5803049736354567,
          0.9195402298850575,
          0.6110873592703434
        ],
        "order": 32
      }
    ]
  },
  {

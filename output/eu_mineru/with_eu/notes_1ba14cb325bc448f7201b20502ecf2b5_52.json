    "member_count": 8,
    "elements": [
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_0",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1992年6月，《21世纪议程》.破坏环境一可持续发展",
        "bbox": [
          0.16271501627150162,
          0.14544257979598552,
          0.7271036727103672,
          0.16847647252385653
        ],
        "order": 1
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "4.城市化问题",
        "bbox": [
          0.11622501162250116,
          0.20993747943402435,
          0.27615062761506276,
          0.23099703849950642
        ],
        "order": 2
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(1)人口和城市的分布",
        "bbox": [
          0.14783821478382148,
          0.24086870681145114,
          0.3774988377498838,
          0.26390259953932216
        ],
        "order": 3
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "①特点：人口分布极不平衡，90%的人口居生在东部沿海地带，而且大城市十分 集中。",
        "bbox": [
          0.1097164109716411,
          0.27179993418887793,
          0.9390980939098094,
          0.32379072063178677
        ],
        "order": 4
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "②带来许多“城市病：资源紧缺、交通拥挤、住房困难、就业紧张、污染严重犯。 罪增多.",
        "bbox": [
          0.10599721059972106,
          0.3343205001645278,
          0.9409576940957695,
          0.38565317538664035
        ],
        "order": 5
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "③解决措施：进行合理的城市规划、建立卫星城：城市中工业和人口向郊区分 散：加强城市管理.重视保护和治理城市环境。",
        "bbox": [
          0.10134821013482101,
          0.397499177360974,
          0.9502556950255695,
          0.4501480750246792
        ],
        "order": 6
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(2)主要城市：",
        "bbox": [
          0.1515574151557415,
          0.4600197433366239,
          0.2780102278010228,
          0.48042119118130966
        ],
        "order": 7
      },
      {
        "id": "mineru_notes_1ba14cb325bc448f7201b20502ecf2b5_52_7",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "圣保罗：经济中心.最大的城市和工业中心 里约热内户：商业和金融中心，第二大城市. 巴西利亚：政治中心、首都.是新建城市.",
        "bbox": [
          0.1803812180381218,
          0.4889766370516617,
          0.5913528591352859,
          0.5745310957551826
        ],
        "order": 8
      }
    ]
  },

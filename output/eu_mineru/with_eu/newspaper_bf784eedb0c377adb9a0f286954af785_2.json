        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "services to Native Hawaiians, and Part C provides caregiver services to any programs that have Part A/B.",
        "bbox": [
          0.6509803921568628,
          0.07454545454545454,
          0.9129411764705883,

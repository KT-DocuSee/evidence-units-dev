      {
        "id": "mineru_newspaper_bf784eedb0c377adb9a0f286954af785_2_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "The evaluation will consist of six data collection activities: (1) Tribal program staff interviews; (2) tribal program staff focus groups, (3) tribal elder focus groups, (4) tribal elder interviews, (5) tribal caregiver focus groups, and (6) follow-up tribal program staff interview.",
        "bbox": [

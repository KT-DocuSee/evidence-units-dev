        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(2)人为原因：过度放牧：过度樵采：过度开垦 治理措施：",
        "bbox": [
          0.16364481636448164,
          0.36920039486673245,
          0.6387726638772664,
          0.42250740375123397
        ],
        "order": 5

  {
    "eu_id": "EU-0003",
    "kind": "text_cluster_panel",
    "page": "jiaocaineedrop_chap02.pdf_16",
    "primary_id": "mineru_jiaocaineedrop_chap02.pdf_16_7",
    "source": "text_cluster",

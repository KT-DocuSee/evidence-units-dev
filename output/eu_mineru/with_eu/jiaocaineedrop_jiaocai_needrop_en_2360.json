      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2360_11",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "把七百多估成800 800+800+800=2400（名） 2400=2400够。",
        "bbox": [

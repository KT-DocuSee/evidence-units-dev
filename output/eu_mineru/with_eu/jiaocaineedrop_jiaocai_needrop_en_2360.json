          0.6084546084546084
        ],
        "order": 21
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2360_24",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(2）一台手机比一台平板电脑便宜多少钱?（3分)",
        "bbox": [
          0.5287356321839081,
          0.674982674982675,

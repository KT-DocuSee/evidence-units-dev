          0.5294525294525294,
          0.44677661169415295,
          0.5751905751905751
        ],
        "order": 18
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2360_22",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(1)一台笔记本电脑比一台平板电脑贵多少钱?（3分)",

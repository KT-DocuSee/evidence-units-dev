        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2360_23",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "5600-4300=1300（元）",
        "bbox": [
          0.5327336331834083,

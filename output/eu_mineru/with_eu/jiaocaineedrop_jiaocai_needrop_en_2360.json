        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2360_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "第一周约（2000）本 第二周约（3000）本 第三周约（2000）本 第四周约（4000）本",
        "bbox": [
          0.09295352323838081,

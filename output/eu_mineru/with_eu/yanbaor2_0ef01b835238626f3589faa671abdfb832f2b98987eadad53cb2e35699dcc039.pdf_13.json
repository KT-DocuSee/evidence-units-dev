        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "面对规模庞大的集体索赔诉讼，事件 对于航空公司的影响和后果不言 而喻。",
        "bbox": [
          0.36436920596533656,
          0.10602821718683197,
          0.6360338573155986,
          0.15619210488812882
        ],

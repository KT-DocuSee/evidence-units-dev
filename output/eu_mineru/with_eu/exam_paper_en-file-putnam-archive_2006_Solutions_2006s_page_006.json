        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "for n large, the right side is smaller than ε.",
        "bbox": [
          0.5576470588235294,
          0.8103030303030303,
          0.8345098039215686,
          0.8248484848484848
        ],
        "order": 18
      },
      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2006_Solutions_2006s_page_006_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "In our case, we deduce that",
        "bbox": [
          0.5576470588235294,
          0.8303030303030303,
          0.7380392156862745,
          0.8436363636363636
        ],
        "order": 19
      }
    ]
  },

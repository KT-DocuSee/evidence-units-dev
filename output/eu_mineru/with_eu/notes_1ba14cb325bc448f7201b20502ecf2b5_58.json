        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "(1)据2000年第五次人口普查，我国总人口为12.95亿，占世界人口总数的115以上。2005年1月6 日.为中国的3亿人口日.",
        "bbox": [
          0.11157601115760112,
          0.771964461994077,
          0.9409576940957695,
          0.8265876933201711
        ],
        "order": 10

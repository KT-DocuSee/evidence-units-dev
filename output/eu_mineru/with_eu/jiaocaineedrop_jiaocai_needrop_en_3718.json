        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "If a child has to struggle to read each word in a sentence, by the time the child reaches the end of the sentence, he/she has forgotten the words at the beginning of the sentence = zero comprehension.",
        "bbox": [
          0.34352941176470586,
          0.5345454545454545,
          0.9098039215686274,
          0.6545454545454545
        ],
        "order": 8
      },

        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_3718_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "There are 220“high frequency\"words that make up 50 - 70% of almost all written sentences.",
        "bbox": [
          0.07372549019607844,
          0.7012121212121212,
          0.6039215686274509,
          0.7727272727272727

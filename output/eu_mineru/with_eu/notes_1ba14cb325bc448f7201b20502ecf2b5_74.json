        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "3.发展农业要因地制宜",
        "bbox": [
          0.11529521152952116,
          0.5238565317538664,
          0.36448163644816367,
          0.5455742020401447
        ],
        "order": 7

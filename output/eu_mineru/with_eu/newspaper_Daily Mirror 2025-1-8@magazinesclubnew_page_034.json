        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.22012860774637355,
          0.7463844797178131,
          0.39958127710483027,
          0.7675485008818342
        ],
        "order": 20
      },
      {
        "id": "mineru_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_034_29",

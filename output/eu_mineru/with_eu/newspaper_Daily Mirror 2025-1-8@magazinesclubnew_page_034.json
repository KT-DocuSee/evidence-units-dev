      {
        "id": "mineru_newspaper_Daily Mirror 2025-1-8@magazinesclubnew_page_034_25",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "3 consi-er how want to be",
        "bbox": [
          0.22012860774637355,
          0.7731922398589065,
          0.360699865410498,
          0.8141093474426808
        ],

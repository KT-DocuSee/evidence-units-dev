[
  {
    "eu_id": "EU-0001",
    "kind": "visual_panel",
    "page": "newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1",
    "primary_id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_48",
    "source": "visual_seed",
    "member_count": 65,
    "elements": [
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_0",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "浙江省农作物病虫害 防治条例11实施",
        "bbox": [
          0.01888162672476398,
          0.052805280528052806,
          0.16509319777293632,
          0.07819243462807819
        ],
        "order": 1
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合寨村村民创造性地建立的农村 群众性自治组织——村民委员会，直 接影响了日后中国农村经济体制改 革，开辟了中国村民自治的新天地。",
        "bbox": [
          0.7625272331154684,
          0.08428535161208428,
          0.9571532316630356,
          0.12592028433612593
        ],
        "order": 4
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报讯国内首部有关农作物病虫害 防治工作的地方性法规《浙江省农作物病 虫害防治条例》，于2011年1月1日起在该 省实施。自此，农作物病虫害防治开始在 浙江走上法制化轨道。",
        "bbox": [
          0.017429193899782137,
          0.09444021325209444,
          0.18445896877269427,
          0.13573665058813575
        ],
        "order": 5
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "浙江地处东南沿海，是各类农作物病 虫害频繁发生的一个省份，尤其是近年来， 受气候、环境变化等影响，全省病虫害的发 生和危害已呈上升趋势。据有关部门统 计，全国1640多种农作物病虫害，在浙江 大部分都已出现。如何做好各类农作物病 虫害的防治，确保农业增效，农民增收，是 当前发展现代农业进程中必须重视的一个 重大课题。",
        "bbox": [
          0.017913338174776083,
          0.13641364136413642,
          0.18445896877269427,
          0.21088262672421088
        ],
        "order": 6
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_16",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.3887678528201404,
          0.14115257679614115,
          0.5025417574437182,
          0.14893797072014894
        ],
        "order": 8
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_30",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "就这样，千里之外的蒙超如愿地 投出了庄严的一票。",
        "bbox": [
          0.6840958605664488,
          0.14115257679614115,
          0.8167513919147906,
          0.1574003554201574
        ],
        "order": 9
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_37",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.8332122972645849,
          0.1414910721841415,
          0.9314935850883563,
          0.14893797072014894
        ],
        "order": 10
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_17",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "上任之初，合寨村偷盗赌博、 滥伐山林、打架斗殴等不良风气 盛行，4000多人的村子，参赌竞有 上千人，各种丑恶现象层出不穷。",
        "bbox": [
          0.3887678528201404,
          0.14995345688414996,
          0.5199709513435004,
          0.1827875095201828
        ],
        "order": 12
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_38",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "在首任村官蒙宝亮的言传身 教下，勇担责任，乐于奉献在合寨 村干部心中扎下了根，由此而建 立起来的威信使村干部手中的指 挥棒越来越灵验。",
        "bbox": [
          0.8327281529895909,
          0.14995345688414996,
          0.9639312515129509,
          0.19057290344419056
        ],
        "order": 13
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_11",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "30年前，广西宜州市屏南乡 合寨村通过“民主选举、民主决 策、民主管理、民主监督”，实行 “自我管理、自我教育、自我服 务”，成为以“村民自治”为标志的 中国农村体制变革的先行者。",
        "bbox": [
          0.2411038489469862,
          0.15773885080815775,
          0.3727910917453401,
          0.20783616823220782
        ],
        "order": 14
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_31",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "如今，合寨村外出务工人员 超过全村总人数的一半，但村民 的参选率达93%。",
        "bbox": [
          0.6840958605664488,
          0.15807734619615807,
          0.8167513919147906,
          0.18244901413218245
        ],
        "order": 15
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_25",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1984年撤社设乡后，合寨 队成立了村民委员会，合寨村果 作屯的党员韦焕能以出色的人品 和能力当选村委会主任。在他的 带领下，村里各项工作大有起色。",
        "bbox": [
          0.5369160009682885,
          0.16653973089616653,
          0.6690873880416364,
          0.20783616823220782
        ],
        "order": 16
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_32",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "30年来，村委会领导班子换了 九任，每一任都是村民用自己神圣 的选票选出。村委会领导班子在 财务收支、基础建设、生产发展等 关乎全村利益的大事上，也都广泛 征求意见，由村民说了算。",
        "bbox": [
          0.6845800048414428,
          0.18312600490818312,
          0.8167513919147906,
          0.23254633155623256
        ],
        "order": 17
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_18",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合寨村人把各种乱象概括为 “六多一少”，即赌博多、盗窃多、乱 砍滥伐多、唱痞山歌多、放浪牛浪 马多、搞封建迷信多，管事的人少。",
        "bbox": [
          0.3887678528201404,
          0.18346450029618347,
          0.5199709513435004,
          0.21596005754421596
        ],
        "order": 18
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_39",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "30年如一日，合寨村九届村 委会领导班子在实施村民自治的 过程中，以勇担责任、无私奉献精 神严格要求自己，并作为治村法 宝的“接力棒”一届届传承，使国 家的政策法令得到正确的贯彻执 行，《村规民约》成为了“村民意 志”，一个欣欣向荣的社会主义新 农村因此矗立在世人面前。",
        "bbox": [
          0.8327281529895909,
          0.19158838960819158,
          0.9648995400629388,
          0.2663958703562664
        ],
        "order": 19
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合寨村的“村民自治”，得到 了党和国家的肯定。1982年“村 民自治”写进了中国宪法，1997年 写人了党的十五大报告，成为了 1998年正式实施的《中华民共 和国村民委员会组织法》的具体 规定，“村民自治”从此走向全国。",
        "bbox": [
          0.24061970467199226,
          0.20851315900820852,
          0.373759380295328,
          0.2670728611322671
        ],
        "order": 20
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_26",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "事实让村民们深深体会到民 主选举的力量。因此，村委会的 每一次换届选举，村民们都表现 出强烈的民主意识，人人都十分 看重自己手中神圣的一票。",
        "bbox": [
          0.5369160009682885,
          0.20851315900820852,
          0.6695715323166304,
          0.24913260556824912
        ],
        "order": 21
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "新条列对浙江农作物病虫害防治 的工作主体、监测与预报制度、财政投 入机制及农药经营和农药废弃包装物 回收制度等各个方面均做了明确的规 定。 历宝仙",
        "bbox": [
          0.017913338174776083,
          0.2118981128882119,
          0.18445896877269427,
          0.25285605483625284
        ],
        "order": 22
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "这股歪风邪气刹不住，村民 难有宁日。",
        "bbox": [
          0.38925199709513436,
          0.21663704832021663,
          0.5204550956184943,
          0.23254633155623256
        ],
        "order": 23
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_20",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1979年底的一个晚上，蒙宝亮 召集党员、干部开会，决心要找出 个办法来。家你我语纷 纷出谋献计。最后，蒙宝亮归纳大 家的意见：“我们就订一个《村规民 约》，用来管住那些歪风邪气。”",
        "bbox": [
          0.3887678528201404,
          0.23322332233223322,
          0.5209392398934882,
          0.28264364898028266
        ],
        "order": 24
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_33",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "随着形势发展，思想活跃、富 有开拓精神、见多识广的新型带 头人成为了村民们选举的标准。",
        "bbox": [
          0.6850641491164366,
          0.23322332233223322,
          0.8167513919147906,
          0.25793348565625795
        ],
        "order": 25
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_27",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1999年9月25日，是合寨村 村民委员会的第六届选举日。已 离开本村10年的蒙桂北，在得知 自己的选民资格被遗漏后，放下 手中的工作立即从外地赶回村 里，向村民委员会申请选民资格， 投上自己神圣的一票。",
        "bbox": [
          0.5369160009682885,
          0.25014809173225017,
          0.6695715323166304,
          0.3076923076923077
        ],
        "order": 26
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_34",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "韦向生当选该村第七届村民委 员会主任后，带领合寨村建成了桑 蚕、甘蔗两大支柱产业；建起了3个 食用菌示范基地；涌现一批猪、牛、 鸽、兔、鱼专业养殖户。村民们的致 富路越走越宽，人均纯收入从1980 年的57.83元提高到2009年的4345 元；85%以上的农户建起了楼房，汽 车、电脑、冰箱等普及农家。",
        "bbox": [
          0.6845800048414428,
          0.2586104764322586,
          0.8172355361897845,
          0.33307946179233305
        ],
        "order": 27
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_40",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合寨村村民创造性地建立的 农村群众性自治组织——村民委员 会，直接影响了日后中国农村经济 体制改革，开辟了中国村民自治的 新天地。2010年8月18日，时值合 寨村“村民自治”30周年之际，全国 人大常委会委员长吴邦国欣然为 该村泼墨题词：“中国第一个村民 委员会”。与安徽小岗村“包产到 户”齐名，并称中国农民两个伟大创 举的“村民自治”，在中国农村政治 民主建设的突出地位和重要作用再 次得到了党和国家的肯定。",
        "bbox": [
          0.8322440087145969,
          0.26673436574426673,
          0.9648995400629388,
          0.3750528899043751
        ],
        "order": 28
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_21",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "回忆起当时的一幕，今年78 岁的蒙宝亮依然记忆犹新：“我的 话音一落，蒙成顺一拍大腿，兴奋 地说这个办法好！”两个小时后， 一个具有划时代意义的《村规民 约》初稿形成了。”",
        "bbox": [
          0.3887678528201404,
          0.2833206397562833,
          0.5204550956184943,
          0.33274096640433276
        ],
        "order": 31
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合寨村，一个只有在县级地 图上才能找到的穷乡僻壤。如果 不是30年前有一个人吹响了“集 结号”，它或许永远默默无闻，更 不可能影响中国农村法制体制建 设的进程。",
        "bbox": [
          0.2411038489469862,
          0.29144452906829144,
          0.3732752360203341,
          0.3412033511043412
        ],
        "order": 32
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_28",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "随着时代变迁，合寨村的投 票方式也在与时俱进。",
        "bbox": [
          0.5364318566932946,
          0.30836929846830835,
          0.6690873880416364,
          0.3246170770923246
        ],
        "order": 33
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报讯（记者何红卫通讯员尚祥 杰）近年来，湖北省农业厅把公开承诺作为 创建优秀基层党组织和争当优秀共产党员 的助推器，在基层党组织和党员中扎实开 展公开承诺、履职践诺活动，充分激发了基 层党组织和党员创先争优内在动力，取得 了实实在在的成效。",
        "bbox": [
          0.016945049624788187,
          0.3164931877803165,
          0.18349068022270637,
          0.3743758991283744
        ],
        "order": 34
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_29",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "2008年4月11日，合寨村进 行第九届换届选举，除通过电话 投票外，还开通了网络视频投 票。远在深圳打工的村民蒙超赶 到网吧，通过视频向记录员说出 心仪的候选者，请他代填选票。",
        "bbox": [
          0.5364318566932946,
          0.32597105864432596,
          0.6690873880416364,
          0.37539138529237537
        ],
        "order": 35
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_22",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "这是中国农村法制建设具有 里程碑意义的一个晚上。",
        "bbox": [
          0.3887678528201404,
          0.33375645256833375,
          0.5194868070685064,
          0.3496657358043497
        ],
        "order": 36
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_15",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "这个人就是蒙宝亮，一位退 伍军人。1975年担任合寨大队党 支书，一干10年，不但改变了合寨 村的命运，而且为中国农村法制 建设写下了浓墨重彩的一笔。",
        "bbox": [
          0.24061970467199226,
          0.34221883726834224,
          0.3732752360203341,
          0.37539138529237537
        ],
        "order": 38
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_23",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "《村规民约》让合寨村首开中 国“村民自治”之先河，成为新中国 农村体制改革当之无愧的发源地。",
        "bbox": [
          0.3887678528201404,
          0.3503427265803503,
          0.5194868070685064,
          0.3750528899043751
        ],
        "order": 39
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_36",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合寨村村民对民主权利的充 分运用，莫过于选到了敢于承担 责任、无私奉献的带头人。",
        "bbox": [
          0.6850641491164366,
          0.35846661589235845,
          0.8172355361897845,
          0.37539138529237537
        ],
        "order": 40
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "结合目标要求定诺。省经管局结合实 际提出了严格执行支农优惠政策等七项承 诺。省水产局从提升水产产业发展水平等 方面做出承诺。",
        "bbox": [
          0.016945049624788187,
          0.37539138529237537,
          0.18349068022270637,
          0.4082254379284082
        ],
        "order": 41
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_41",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "结合党务公开示诺。厅办公室设置了 “严之又严、细之又细”的提示牌挂在醒目 位置，省种子管理站贴出了“依法查处重大 种子案件，确保结案率100%”的承诺标语。",
        "bbox": [
          0.016945049624788187,
          0.4089024287044089,
          0.18349068022270637,
          0.4413979859524414
        ],
        "order": 42
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_48",
        "observed_type": "image_body",
        "canon_role": "picture",
        "text": "",
        "bbox": [
          0.224158799322198,
          0.4095794194804096,
          0.6584362139917695,
          0.610984175340611
        ],
        "order": 43
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_42",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "结合重点工作践诺。围绕粮食增产、 农民增收，狠抓各项增产增收措施落实。",
        "bbox": [
          0.017913338174776083,
          0.4420749767284421,
          0.18203824739772453,
          0.45798425996445796
        ],
        "order": 45
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_43",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "结合年度考核评诺。评诺采取个人自 评、党员互评等办法进行。",
        "bbox": [
          0.017429193899782137,
          0.458999746128459,
          0.18252239167271847,
          0.4752475247524752
        ],
        "order": 46
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_53",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报讯（记者夏树通讯员饶 东平）安徽省合肥市2010年以春、 夏、秋三季农资打假为抓手，强力推 进“种子执法年、农药监管年”为主题 的“为农护农”执法行动，取得明显成 效。据统计，全市共查获假冒伪劣农 资6万余公斤，货值90万元，为农民 挽回经济损失1100万元。年来全 市没有发生一起重大农资安全事件， 没有发生一起因农资安全而引发的 较大规模农民上访事件。合肥市农 委主任何杰介绍说：农资打假工作必 须以维护农民利益为根本出发点。",
        "bbox": [
          0.6884531590413944,
          0.46543115850046546,
          0.8278867102396514,
          0.5737496826605738
        ],
        "order": 47
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_56",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.8419268942144759,
          0.46543115850046546,
          0.9818445896877269,
          0.5818735719725818
        ],
        "order": 48
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_44",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "兰州市为农村五保户 发物价补贴",
        "bbox": [
          0.019849915274751877,
          0.4914953033764915,
          0.15734688937303318,
          0.5175594482525175
        ],
        "order": 49
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_45",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报讯(记者吴晓燕）甘肃省兰州市 从2010年11月至2011年3月，为城乡低 保、农村五保和重点优抚对象发放5个月 的临时物价补贴，一次性发放。城市低保 补贴标准为每人20元/月，共计100元；农 村低保补贴标准为每人10元/月，共计50 元；农村五保补贴标准为每人20元/月，共 计100元；优抚对象补贴标准为每人20元/ 月，共计100元。",
        "bbox": [
          0.016945049624788187,
          0.5338072268765338,
          0.1830065359477124,
          0.6082762122366083
        ],
        "order": 50
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_54",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "以市场检查为重点，紧跟农时 高峰，集中开展种子、农药、肥料市 场大检查，2010年全年检查经营户 2300余户次，检查品种6100余个， 收缴罚没款50余万元，查获伪劣种 子、肥料4.55万公斤，不合格农药 132件，立案查处违规经营行为49 起，收缴罚没款38.6万元。以农资 安全事故纠纷调解为重点，维护农 民和种子经营户合法权益。",
        "bbox": [
          0.6884531590413944,
          0.5744266734365744,
          0.8278867102396514,
          0.6573580434966574
        ],
        "order": 51
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_57",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "合肥市以打击假冒伪劣农资和 禁限用农业投入品为重点，确保农 产品质量安全和农业生产安全。农 业部门依法行政、服务意识和责任 意识、农资生产经营者的诚信守法 意识、农民的安全消费和维权意识 逐步提高。已受理举报案件和立案 查处数量同上年相比呈下降趋势， 涉及到的农资纠纷（事故）依法调查 处理到位。农资监管制度建设逐步 加强。坚持把好市场准入关，加大 日常监管力度，从源头上减少或杜 绝制假售假行为的发生。",
        "bbox": [
          0.8424110384894699,
          0.5828890581365829,
          0.9823287339627209,
          0.6915460776846916
        ],
        "order": 52
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_46",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "为稳定物价，兰州市建立了居民消费 价格总水平（CPI）上涨与城乡低保、农村 五保临时物价补贴联动机制。当兰州市 CPI连续三月增长超过3%（含3%）时，于 次月自动启动临时物价补贴调节机制。当 月度CPI增长低于3%（不含3%）时，于次 月自动取消临时物价调节补贴。",
        "bbox": [
          0.017429193899782137,
          0.6092916984006093,
          0.18349068022270637,
          0.6678514005246678
        ],
        "order": 53
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_50",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "日前，在山东省垦利县垦利街道二十一户村的文化大院里，该村庄户剧团的秧歌队正在排练秧歌。垦利街道 不断加强农村文化设施和队伍建设，鼓励有条件的村成立村级文艺演出队，既丰富了群众的文化生活，又引导健 康向上的生活方式。 闫汉廷张秀美摄",
        "bbox": [
          0.224158799322198,
          0.6532960988406533,
          0.6594045025417574,
          0.6786832529406787
        ],
        "order": 55
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_55",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "先后组织开展农业综合行政 执法人员、农资生产经营单位（户） 负责人参加的农业法律法规培训 班6期，培训各类人员1500余人 次，并随时对农业执法人员进行法 律法规考试。责任落实到位。市 农业执法支队与120家农资生产经 营者签订了农资经营质量安全承 诺书，建立了农资经营户基本信息 电子档案，做到打假工作底数清、 情况明、针对性强；监督考核到 位。完善了举报信访、市场检查、 质量抽检、案件查处等日常考核制 度，明确各县农业部门定期报送农 资打假工作情况、存在问题及推进 措施，及时掌握全市打假工作进 展，为进一步推动打击假冒伪劣农 资制定新的对策。",
        "bbox": [
          0.6879690147664004,
          0.6580350342726581,
          0.8283708545146453,
          0.6915460776846916
        ],
        "order": 56
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_58",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报讯（记者徐盘钢）记者从浙江省庆 元县人民政府日前在上海举行的新闻发布 会上获悉，由庆元县人民政府承办的第八届 中国（庆元）香菇文化节于日前在庆元举行。",
        "bbox": [
          0.016945049624788187,
          0.7270880934247271,
          0.1830065359477124,
          0.7602606414487603
        ],
        "order": 61
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_77",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.8428951827644638,
          0.7514597613607514,
          0.9823287339627209,
          0.8181433527968182
        ],
        "order": 62
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_59",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "庆元县素有“中国香菇之乡”、“中国香 菇城”之称。全县19万人口，半数以上从事 香菇生产及其相关行业，全县农民人均收入 和地方财政收中香菇效益占了50%以 上。据统计，2009年全县食用菌总产值达到 3.2亿元，共生产各类食用菌达1.25亿袋。",
        "bbox": [
          0.01646090534979424,
          0.7605991368367606,
          0.18349068022270637,
          0.8106964542608107
        ],
        "order": 64
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_72",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "总书记亲临打井施工现场并作 出重要指示的消息，如和煦春风迅 速传遍了永宁，给干部群众巨大的 鼓舞和激励。一场加快解决群众饮 水难问题的攻坚战打响了—",
        "bbox": [
          0.6894214475913822,
          0.7605991368367606,
          0.8288549987896393,
          0.8015570787848015
        ],
        "order": 65
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_67",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.3732752360203341,
          0.768046035372768,
          0.5093197772936335,
          0.9856985698569857
        ],
        "order": 66
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_68",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.5248123940934398,
          0.7683845307607684,
          0.6603727910917453,
          0.8848269442328849
        ],
        "order": 68
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_65",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "发展现代农业，离不开农药、 化肥等生产资料的大量使用。农 民用药水平的高低，农药使用的安 全与否，直接关系到农作物病虫害 的防治效果、施药人员身体健康、 农产品质量安全和生态环境安 全。但由于我国农业生产组织化 程度低，农户众多，对农药使用的 指导和监管是目前农药管理各环 节中难度最大、最薄弱的一环。",
        "bbox": [
          0.224158799322198,
          0.784970804772785,
          0.35923505204550954,
          0.8682406702208683
        ],
        "order": 69
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_73",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "经过紧张的前期准备，永宁县 南部农村饮水安全工程2010年8月 7日正式开工。",
        "bbox": [
          0.6894214475913822,
          0.8018955741728019,
          0.8283708545146453,
          0.8266057374968266
        ],
        "order": 70
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_78",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "经过3个多月的艰苦奋战， 2010年11月27日，永宁县规模最 大、受益人口最多的饮水安全工程 胜利竣,6个乡镇44个政村10 万人的饮水难问题彻底解决，全县 实现了农村饮水安全的全覆盖。乡 亲们拿着五颜六色的脸盆，提着叮 当作响的水桶，兴高采烈地从四面 八方涌向通水仪式现场，尽情欢庆 永宁人这个永远难忘的特殊节日。",
        "bbox": [
          0.8433793270394577,
          0.8191588389608192,
          0.9823287339627209,
          0.9017517136329017
        ],
        "order": 71
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_74",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "兰州军区部队官兵坚决贯彻总 书记指示，急缺水群众所急，解缺水 群众所难，迅速投人到帮助地方打 井的“战役”中。大家发扬不怕疲 劳、连续作战的精神，转战在条件艰 苦的荒郊野外，不辞辛苦地为群众 找水打井。",
        "bbox": [
          0.6889373033163882,
          0.826944232884827,
          0.8283708545146453,
          0.8848269442328849
        ],
        "order": 72
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_61",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报讯(潘兴祥记者陈兵）记者日前 从江苏省灌云县民政部门获悉，截至目前， 该县现有的2400多名五保老人中，有1900 多名实现了集中供养，农村五保老人集中 供养率达80%。",
        "bbox": [
          0.01646090534979424,
          0.8685791656088686,
          0.1839748244977003,
          0.9098756029449099
        ],
        "order": 74
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_66",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "为了切实解决农民防病治虫 难、减少农药使用对生态环境和农 产品质量安全的负面影响，提高病 虫防治效率，记者了解到，“十一 五”期间，农业部将帮助农民安全 用药列人为农民办实事的重点工 作，采取多种措施积极推进。建立 了一批安全用药示范区，按照不同 农业区划和作物布局，在28个省 （区、市）选择44县（市）作为农药 安全使用示范区，通过示范区集成 组装配套技术进行示范推广。推 广了一批环保农药和进口植保机 械，在大面积示范的基础上，分5 批推荐了50多种高毒农药替代产 品，100多种组合配套技术供各地 推广应用。加强了农药抗性监测 和治理，针对主要害虫、主要农药 品种，开展农药抗性监测，发布监 测公报、科学指导用药防治，减轻 或延缓病害抗性。规模推进 病虫害专业化统防统治，农业部从 2010年开始启动了病虫害专业化 统防统治“百千万”行动，在全国范 围内重点建设100个示范县，抓好 1000个示范区，扶持1万个示范组 织，力争通过若干年的努力，实现 主要作物、重点地区、重大病虫统 防统治全覆盖。加强了安全用药 培训，针对农民在农药使用的各个 环节中常常存在的不规范行为，近 年来，农业部组织专家深入田间地 头，结合用药实例开展农民培训，培 训方式多采用媒体演示与现场操作 以及问答互动相结合形式，与农民 互动问答，受到农民朋友的热烈欢 迎。辽宁省沈阳市东陵区李相镇 农民在培训结束后说：听专家讲课 就像看了两场电影似的，真解渴。 通过培训和示范推广，农民盲 目用药、滥用农药和盲目混配用药 现象大大减少，对轮换用药和合理 混配的概念有了较充分的理解，安 全用药意识得到增强。据湖南省 慈利县植保站对小溪峪村68户受 训茶农用药行为调查，受训前，没 有一户农民在购农药时看标签。 受训后，农民的用药行为得到了较 大改正，95%以上的农民都有了买 药看标签的行为，90%以上的农民 自觉到农技站或向农技人员询问 病虫防治技术和使用农药，80%以 上的农民懂得了施药应具备的防 护措施。",
        "bbox": [
          0.22367465504720407,
          0.8692561563848693,
          0.35923505204550954,
          0.986037065244986
        ],
        "order": 75
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_69",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "又据新疆吐鲁番培训点调查， 培训前，有33%的农民在中午喷 药，培训后，上午10点前下午3点 后用药达94.3%，比培训前的67% 增加了27.3个百分点。据对四川 省彭州市调查，培训前农民使用有 跑、冒、滴、漏现象的喷雾器占 85.61%，培训后有跑、冒、滴、漏现 象的占18.82%，下降了66.79%。农 民对处理盛装过农药的空瓶空袋， 培训前随便扔的占73.8%，培训后 随便扔的占3.32%，降低了70.48%。",
        "bbox": [
          0.524328249818446,
          0.8855039350088855,
          0.6598886468167514,
          0.9856985698569857
        ],
        "order": 76
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_75",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "当地的建设者们夜以继日地忘 我工作，许多人吃住在工地，3个多 月没有回一次家。为了不影响白天 施工，管材都集中在晚上发放。负 责库房管理的永宁县水务局工作人 员冯丽琴说：“当时为了赶工期，管 材经常发到凌晨两三点钟。有时候 一个人忙不过来，全局的职工都赶 来帮忙。”",
        "bbox": [
          0.6894214475913822,
          0.8855039350088855,
          0.8283708545146453,
          0.95997292036896
        ],
        "order": 77
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_79",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "饮水思源，倍感党亲。乡亲们 多想把喝上干净的好消息尽快告 诉总书记啊！",
        "bbox": [
          0.8433793270394577,
          0.9024287044089024,
          0.9828128782377148,
          0.9268003723449268
        ],
        "order": 78
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_62",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "据介绍，2010年以来，灌云县积极开展 五保户“关爱工程”项目建设，安排专项资 金用于改善敬老院住房条件。目前，全县 敬老院基本达到院内环境园林化、居住宾 馆化。在做好硬件建设的同时，灌云县民 政部门还通过配备专职工作人员，各项经 费落实到位等多种措施提高集中供养率， 目前，全县八成农村五保户实现了集中供 养，生活待遇明显改善。",
        "bbox": [
          0.01646090534979424,
          0.9105525937209106,
          0.1839748244977003,
          0.9856985698569857
        ],
        "order": 79
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_80",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "献上一碗八宝茶，是当地招待 贵客的礼节。家里刚通上自来 的回族村民吕忠明动情地说：“大 家都盼着胡总书记再来永宁县，我 们用自来水亲手泡一杯八宝茶，请 总书记品尝一下，这是我们最大的 心愿！”",
        "bbox": [
          0.8433793270394577,
          0.9274773631209274,
          0.9828128782377148,
          0.9856985698569857
        ],
        "order": 80
      },
      {
        "id": "mineru_newspaper_dd99f17cad0992a54fdf424b1c5e86ee_1_76",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "党和政府的惠民之举，温暖着 乡亲们的。家纷纷声的 动表达内心的感动：炎炎盛夏，常有 村民买上几个西瓜，送到施工人员 跟前；为了给铺设自来水管道提供 方便，许多村民早早就移开了地里 的柴堆、挪走了家中的鸡窝。宁夏 明昊水利建筑工程有限公司的王立 军感慨地说：“干了这么多年工程， 第一次碰上这种情况，让我们心里 暖洋洋的！”",
        "bbox": [
          0.6899055918663762,
          0.960988406532961,
          0.8283708545146453,
          0.9856985698569857
        ],
        "order": 81
      }
    ]
  },

  {
    "eu_id": "EU-0007",
    "kind": "section_text_panel",
    "page": "newspaper_USAToday-2025-01-08@magazinesclubnew_page_021",
    "primary_id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_7",
    "source": "header_anchor",
    "member_count": 3,
    "elements": [
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_7",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "MAKING WAVES ARIANA GRANDE",
        "bbox": [
          0.04424242424242424,
          0.28674509803921566,
          0.16303030303030303,
          0.30117647058823527
        ],
        "order": 10
      },
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Fans of Ariana Grande were up in arms after the actress and singer was asked on the Golden Globes red carpet whether her grandmother was \"still alive.\" An Access Hollywood reporter quizzed the \"Wicked\"star about whom she called first after her nomi- nation for the Jan. 5 awards cere- mony. When she said her mom, the reporter asked, \"grandmother still alive?\" Grande didn't appear offended by the question, but fans online called it \"risky\"and \"sick.\"",
        "bbox": [
          0.04363636363636364,
          0.30870588235294116,
          0.2515151515151515,
          0.40125490196078434
        ],
        "order": 11
      },
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_18",
        "observed_type": "image_caption",
        "canon_role": "support_paragraph",
        "text": "A role ike László Tóth is \"very meaningful and very rare,\" says \"The Brutalist\" star Adrien Brody. PRoViDED BY A2",
        "bbox": [
          0.28363636363636363,
          0.33003921568627453,
          0.8848484848484849,
          0.3375686274509804
        ],
        "order": 12
      }
    ]
  },
  {
    "eu_id": "EU-0008",
    "kind": "section_text_panel",
    "page": "newspaper_USAToday-2025-01-08@magazinesclubnew_page_021",
    "primary_id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_14",
    "source": "header_anchor",
    "member_count": 3,
    "elements": [
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_14",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "Adrien Brody draws on family's sacrifice to find truth in 'Brutalist'",
        "bbox": [
          0.2824242424242424,
          0.3463529411764706,
          0.9472727272727273,
          0.39215686274509803
        ],
        "order": 13
      },
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_15",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Patrick Ryan USA TODAY",
        "bbox": [
          0.283030303030303,
          0.40094117647058825,
          0.40969696969696967,
          0.40847058823529414
        ],
        "order": 14
      },
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_16",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "NEW YORK – At 29, Adrien Brody became the youngest man ever to win the best actor Oscar for the 2002 Holocaust drama \"The Pianist.\" ● More than two decades later, he could very well clinch his second gold statue for \"The Brutalist\" (in select theaters now), playing a Hun- garian-Jewish immigrant in Brady Corbet's 3½-hour epic. The charac- ter, a battered architect named László Tóth, is immensely personal to Brody, 51, whose father is Polish Jewish and mother is Hungarian. As a girl, she fled Budapest with her parents during the Hungarian Revolu- tion, settling in New York in 1958. ● \"Nothing really feels fictional about this flm, even though it is a fictional story,\" says Brody, sipping tea on a rainy December afternoon. \"It's inside me; it's deeply rooted in truth. Just last night, my mom sent me a whole slew of images: some from 'The Pianist, some from my grandfather, some with my father holding me as a boy. It's all there: all the lives that I've lived and chapters in my life.\"",
        "bbox": [
          0.2818181818181818,
          0.41474509803921566,
          0.7242424242424242,
          0.5722352941176471
        ],
        "order": 16
      }
    ]
  },
  {
    "eu_id": "EU-0009",
    "kind": "section_text_panel",
    "page": "newspaper_USAToday-2025-01-08@magazinesclubnew_page_021",
    "primary_id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_10",

        "observed_type": "title",
        "canon_role": "section_header",
        "text": "IT'S YOUR BIRTHDAY WHO'S CELEBRATING TODAY",
        "bbox": [
          0.04363636363636364,
          0.49913725490196076,
          0.24666666666666667,
          0.5145098039215686
        ],
        "order": 18
      },
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_11",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "Cynthia Erivo is 38. Noah Cyrus is 25. Sam Levinson is 40.",
        "bbox": [
          0.04363636363636364,
          0.5217254901960784,
          0.24606060606060606,
          0.535843137254902
        ],
        "order": 19
      },
      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_20",
        "observed_type": "image_caption",
        "canon_role": "support_paragraph",
        "text": "\"The Brutalist\" star is an Oscar front-runner after winning the best drama actor award at the Golden Globes. DAN MACMEDAN/USA TODAY",
        "bbox": [
          0.7369696969696969,
          0.5433725490196079,
          0.9351515151515152,
          0.5716078431372549
        ],
        "order": 20
      }
    ]
  },

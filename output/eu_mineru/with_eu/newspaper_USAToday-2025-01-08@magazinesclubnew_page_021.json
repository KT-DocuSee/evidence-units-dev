      {
        "id": "mineru_newspaper_USAToday-2025-01-08@magazinesclubnew_page_021_49",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "2 5 - 0 - - - - 福 福 2",
        "bbox": [
          0.5072727272727273,
          0.7429019607843137,

    "elements": [
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "1.亲突然站定，朝(cháo zhāo)幽深的树林望了又望。",
        "bbox": [
          0.122,
          0.23872742494916876,
          0.602,
          0.2569070685324722
        ],
        "order": 7
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_15",
        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "1.认识生字；会写生字。 2.默读课文，理解课文 内容。 3.积累优美词语，练习 用“我会读”中的词语 说句子。 4.体会“父亲”的爱鸟之 情和“我”的护鸟心愿。",
        "bbox": [
          0.7393333333333333,
          0.24351154168161704,
          0.9086666666666666,
          0.41095562731730656
        ],
        "order": 8
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "2.黎(ní lí)明时，所有的鸟抖(dǒu dòu)动着浑的羽翎。",
        "bbox": [
          0.12133333333333333,
          0.26312642028465494,
          0.6293333333333333,
          0.2832197105609377
        ],
        "order": 9
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "3.树林过夜的鸟总(zhǒng zǒng)是一群。",
        "bbox": [
          0.122,
          0.28800382729338597,
          0.504,
          0.30761870589642387
        ],
        "order": 10
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_7",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "二、看拼音，写词语。",
        "bbox": [
          0.09466666666666666,
          0.31288123430211695,
          0.2633333333333333,
          0.3310608778854204
        ],
        "order": 11
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_8",
        "observed_type": "image_body",
        "canon_role": "picture",
        "text": "",
        "bbox": [
          0.11866666666666667,
          0.33919387633058246,
          0.674,
          0.4721923214926444
        ],
        "order": 12
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_19",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "读一读，连一连。",
        "bbox": [
          0.7413333333333333,
          0.43870350436550654,
          0.858,
          0.45401267790934097
        ],
        "order": 14
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_20",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "黎凝畅瞬猎 nàng = liè shùn",
        "bbox": [
          0.7386666666666667,
          0.4597536179882789,
          0.888,
          0.5621337160626719
        ],
        "order": 15
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_9",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "三、我喜欢连一连，还想把这些词语写下来。",
        "bbox": [
          0.09333333333333334,
          0.47793326157158234,
          0.46066666666666667,
          0.49611290515488576
        ],
        "order": 16
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "并舒时喜 畅且欢刻 重轻过气 声夜要味 < > < > < ～ < > （ ) （ ) ( ） ( ）",
        "bbox": [
          0.12133333333333333,
          0.5023322569070685,
          0.668,
          0.6453773472072719
        ],
        "order": 17
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_620_22",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "比一比，再组词。 湿( ) 显（ ) 膀（ ) 旁（ ) 露( ) 雾（ ) 蒙( ) 家（ )",
        "bbox": [
          0.7393333333333333,

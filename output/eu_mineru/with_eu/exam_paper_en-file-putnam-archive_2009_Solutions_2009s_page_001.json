        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Kiran Kedlaya and Lenny Ng",
        "bbox": [
          0.40078431372549017,
          0.11393939393939394,
          0.6070588235294118,
          0.1290909090909091

      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2009_Solutions_2009s_page_001_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Since p and q are relatively prime, and p divides 5q2, we must have p|5, so p = 1 or p = 5. On the other hand, p − q and q are also relatively prime, so p − q divides 5 as well, and p − q must be ±1 or ±5. This leads to eight possibilities for (p, 9): (1, 0), (5,0), (5, 10), (1, −4), (1, 2), (1, 6), (5, 4), (5, 6). The fi rst three are impossible, while the fi nal five lead to 5n + 2 = 16, −20, −36, 16, −36 respectively, none of which holds for integral n.",
        "bbox": [
          0.5568627450980392,
          0.6024242424242424,
          0.92,
          0.7333333333333333
        ],
        "order": 12
      }
    ]
  },

        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "\".. a modular, deployable, and replaceable part of a system that encapsulates implementation and exposes a set of interfaces.\"",
        "bbox": [
          0.13066666666666665,
          0.33866666666666667,
          0.9153333333333333,
          0.4577777777777778

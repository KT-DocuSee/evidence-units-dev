      {
        "id": "mineru_yanbaopptmerge_SE14.pdf_1_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "OO view: a component contains a set of collaborating classes",
        "bbox": [
          0.12066666666666667,
          0.48533333333333334,
          0.926,
          0.5831111111111111
        ],
        "order": 4

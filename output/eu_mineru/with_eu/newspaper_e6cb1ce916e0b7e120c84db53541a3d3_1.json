  {
    "eu_id": "EU-0010",
    "kind": "text_cluster_panel",
    "page": "newspaper_e6cb1ce916e0b7e120c84db53541a3d3_1",
    "primary_id": "mineru_newspaper_e6cb1ce916e0b7e120c84db53541a3d3_1_7",

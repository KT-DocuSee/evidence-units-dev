      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2011_Problems_2011_page_001_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "[Picture omitted.] How many of the points (x, y) with integer coordinates 0 ≤ x ≤ 2011, 0 ≤ y ≤ 2011 cannot be the last point, Pn of any growing spiral?",

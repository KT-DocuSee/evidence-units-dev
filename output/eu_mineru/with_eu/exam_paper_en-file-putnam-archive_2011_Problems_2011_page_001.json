      },
      {
        "id": "mineru_exam_paper_en-file-putnam-archive_2011_Problems_2011_page_001_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "− the directed line segments P0P1, P1P2, .., Pn−1Pn are in the successive coordinate directions east (for PoP1), north, west, south, east, etc.; – the lengths of these line segments are positive and strictly increasing.",
        "bbox": [
          0.14666666666666667,
          0.18848484848484848,
          0.49019607843137253,
          0.2672727272727273
        ],
        "order": 3

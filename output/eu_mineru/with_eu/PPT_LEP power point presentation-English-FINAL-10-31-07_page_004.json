        "observed_type": "title",
        "canon_role": "section_header",
        "text": "Executive Order No. 13166:",
        "bbox": [
          0.24933333333333332,
          0.04888888888888889,
          0.746,
          0.104
        ],
        "order": 1
      },
      {
        "id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_1",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Improving Access to Services for Persons with Limited English Proficiency (LEP)",
        "bbox": [
          0.08333333333333333,
          0.12088888888888889,
          0.9126666666666666,
          0.2604444444444444
        ],
        "order": 2
      },
      {
        "id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "August 11, 2000: President Bill Clinton issued the Executive Order 13166.",
        "bbox": [
          0.10733333333333334,
          0.29333333333333333,
          0.9133333333333333,
          0.38666666666666666
        ],
        "order": 3
      },
      {
        "id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Designed to improve access to federally conducted and federally assisted programs/activities for LEP persons",
        "bbox": [
          0.10933333333333334,
          0.4017777777777778,
          0.8686666666666667,
          0.496
        ],
        "order": 4
      },
      {
        "id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Federal agencies were asked to develop and implement a system to provide LEP persons access to services.",
        "bbox": [
          0.10866666666666666,
          0.5084444444444445,
          0.896,
          0.6017777777777777
        ],
        "order": 5
      },
      {
        "id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Each federal agency was asked to prepare a plan to improve access to LEP persons, and submit plans to the U.S. Department of Justice.",
        "bbox": [
          0.10866666666666666,
          0.6151111111111112,
          0.9253333333333333,
          0.7564444444444445
        ],
        "order": 6
      },
      {
        "id": "mineru_PPT_LEP power point presentation-English-FINAL-10-31-07_page_004_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Executive Order charged the Department of Justice with the responsibility of providing LEP guidance to federal agencies.",
        "bbox": [
          0.108,
          0.7688888888888888,
          0.876,
          0.9111111111111111
        ],
        "order": 7
      }
    ]
  }

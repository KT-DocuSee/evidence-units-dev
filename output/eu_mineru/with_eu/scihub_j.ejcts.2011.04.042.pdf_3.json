      {
        "id": "mineru_scihub_j.ejcts.2011.04.042.pdf_3_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "There were nine patients in whom the donor-recipient weight mismatch was 3 or greater (5.5%). By the end of the follow-up period，, there was only 11%(1/9) mortality, compared with 18.2% (23/126) for those with a ratio of <3 (p = 0.76).",
        "bbox": [
          0.5165588869292573,
          0.834471248672432,
          0.9163237311385459,
          0.8896980731300258
        ],
        "order": 14
      },
      {
        "id": "mineru_scihub_j.ejcts.2011.04.042.pdf_3_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Data on postoperative RV function was available in 158 out of 161 patients. Thirty-eight patients (24%) developed RV failure. In the lower tertile group, 18.9% developed postoperative RV failure, in the midle group 24.5% and in the upper tertile group 28.8%; this was not statistically different (p = 0.48) (Table 3).",
        "bbox": [
          0.08387223202038017,
          0.8623881049916553,
          0.4844209288653733,
          0.9309664694280079
        ],
        "order": 15

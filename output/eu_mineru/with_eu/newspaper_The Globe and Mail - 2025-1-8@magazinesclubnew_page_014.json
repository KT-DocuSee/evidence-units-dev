          0.4983084577114428
        ],
        "order": 21
      },
      {
        "id": "mineru_newspaper_The Globe and Mail - 2025-1-8@magazinesclubnew_page_014_12",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Fill in the grid so that each row of nine squares, each column of nine and each section of nine (three squares by three) contains the numbers 1 through 9 in any order. There is only one solution to each puzzle.",
        "bbox": [
          0.0325,
          0.4891542288557214,

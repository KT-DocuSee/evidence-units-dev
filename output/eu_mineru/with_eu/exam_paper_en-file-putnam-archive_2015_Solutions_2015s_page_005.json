        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "which takes values in {−1, 0, 1}; we then have",
        "bbox": [
          0.12941176470588237,
          0.3145454545454546,
          0.4337254901960784,
          0.3303030303030303
        ],

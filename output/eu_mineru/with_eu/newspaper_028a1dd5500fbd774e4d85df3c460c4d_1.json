          0.028095117204028096,
          0.8540305010893247,
          0.06092916984006093
        ],
        "order": 4
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_5",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.859840232389252,
          0.028095117204028096,
          0.9958847736625515,
          0.08631632394008631
        ],
        "order": 5
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_4",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "据了解，5年来，北京农学院将 大学生村官纳入学校科技推广服 务体系中，整合各种资源，充分发 挥大学生知识和年龄优势，使一大 批大学生村官在学校的支持下帮 助农民致富，促进了当地产业发 展，得到了当地政府和村民的高度 评价和充分认可。他们中有4 担任村党支部副书记、10人当选为 村党支部委员，18人荣获北京市优 秀大学生“村官”称号。",
        "bbox": [
          0.7199225369160009,
          0.061606160616061605,
          0.8545146453643185,
          0.09477870864009477
        ],
        "order": 6
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_6",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "刘铁军",
        "bbox": [
          0.9479544904381506,
          0.086993314716087,
          0.9770031469377874,
          0.09444021325209444
        ],
        "order": 7
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_73",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "学费政策覆盖范围、设立了普通高 中国家助学金制度。",
        "bbox": [
          0.8612926652142339,
          0.16484725395616484,
          0.9963689179375453,
          0.1810950325801811
        ],
        "order": 10
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_55",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "12月20日，记者从教育部在 北京召开的“2010年高校国家奖学 金获奖学生暨全国学生资助工作 先进单位表彰大会”了解到，经过 多年不懈努力，我国家庭经济困难 学生资助政策已经形成了一个比 较系统、比较完善的体系，其覆盖 范围之广、资助力度之大、资助比 例之高，历史上前所未有。",
        "bbox": [
          0.7179859598160252,
          0.18143352796818144,
          0.8549987896393125,
          0.2562410087162562
        ],
        "order": 12
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_72",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "在高等学校，2009年中央和地 方财政投入资助经费约175亿元， 全国有5万名学生获得国家奖学 金,61万名学生获得国家励志奖学 金，400万名学生获得国家助学金， 超过100万名学生获得国家助学贷 款，4万多名毕业生获得学费补偿 和助学贷款代偿；在中等职业学 校，中央和地方财政投入经费200 多亿元，近1200万名学生获得国家 助学金，所有农村家庭经济困难学 生和涉农专业学生享受免学费政 策；在义务教育阶段，2009年，中央 和地方用于免费教科书、家庭经济 困难寄宿生生活补助的总资金达 269亿元，全国免除了近1.5亿义务 教育阶段学生的学杂费，为1.38亿 学生免费提供了国家教科书，向中 西部1224万名家庭经济困难的寄 宿生提供了生活补助。",
        "bbox": [
          0.8608085209392399,
          0.1821105187441821,
          0.9973372064875333,
          0.347973258864348
        ],
        "order": 13
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_45",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.5645122246429436,
          0.22205297452822206,
          0.6957153231663036,
          0.29686045527629684
        ],
        "order": 15
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_15",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "现代农业离不开信息化，发 达国家的成功经验表明，农业信 息化是现代农业的重要标志。当 前，我国已进入加快传统农业改 造，走中国特色农业现代化道路 的关键时刻，如何发挥农业信息 智能服务在发展现代农业中不可 替代的作用，我国农业信息领域 专家、中国农业科学院农业信息 研究所所长许世卫，提出的发展 农业信息智能服务技术的观点， 引起业界关注，记者日前为此专 访了许世卫研究员。",
        "bbox": [
          0.01597676107480029,
          0.23863924854023863,
          0.14717985959816024,
          0.3472962680883473
        ],
        "order": 17
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_29",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "信息化是当今发展最迅速、最活跃的科技因素，正在对我国现代农业的 发展产生着深刻影响。当前物联网、云计算和3G等信息技术在农业各领域、 各环节的研究应用步伐正在加快，如何抓住机遇，让农业信息智能服务在建 设现代农业中充分发挥作用，对于走中国特色农业现代化道路意义重大。",
        "bbox": [
          0.17429193899782136,
          0.24371667936024372,
          0.5223916727184701,
          0.28501311669628504
        ],
        "order": 18
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_59",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "教育部部长袁贵仁指出，党的 十六大以来，国家把促进教育公平 作为基本教育政策，推动教育公平 迈出重大步伐。先后在高等学校 和中等职业学校建立健全了家庭 经济困难学生资助政策体系，对中 等职业学校农村家庭经济困难学 生和涉农专业学生实行免学费政 策，在义务教育阶段学校全面免除 了城乡所有学生的学杂费，为农村 学生提供免费教科书，并为家庭经 济困难的寄宿生提供生活补助。 全国教育工作会议召开和教育规 划纲要颁布后，各级政府和有关部 门迅速行动，相继出台一系列新的 资助政策，提高了普通高校国家助 学金标准、扩大了中等职业学校免",
        "bbox": [
          0.7184701040910191,
          0.25657950410425656,
          0.8549987896393125,
          0.3990860624523991
        ],
        "order": 19
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_47",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者：我们了解到，农业信息 智能服务是推进农业现代化的重 要手段，是转变农业发展方式的 重要途径。用信息技术改造传统 农业、装备现代农业，用信息手段 推广农业技术，用信息服务提升 农业生产水平，是发展现代农业、 建设社会主义新农村的重要措 施。请介绍一些目前比较成熟的 农业信息智能服务技术。",
        "bbox": [
          0.5645122246429436,
          0.2978759414402979,
          0.6952311788913096,
          0.38080731150038083
        ],
        "order": 20
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_24",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "决劳动力成本上升问题；可以通 过风险分析，进行早期发现、早期 预警、早期干预，防止生产消费的 大起大落，平抑波动、控制波幅， 从而相对保障农业生产的稳定性； 可以通过点对点的个性化服务，有 针对性地迅速普及农业科技知识、 及时传输农业市场信息，有利于提 高农民素质和培养新型农民，增加 农业产业科技含量和附加值，促进 农业增效和农民增收，从而相对提 高农业比较效益；可以通过指导产 业规划、教育培训，整合农业资源， 推进“田间”管理数字化，实现精 准灌溉、施肥和用药，从而相对缓 解农业可持续性挑战。",
        "bbox": [
          0.15347373517308158,
          0.3053228399763053,
          0.28467683369644153,
          0.439028518236439
        ],
        "order": 21
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_32",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "用现代信息技术手段，对农业生 产的各种要素信息，进行标准化 采集、科学化管理、自动化控制、 精准化服务，提高管理支持，降低 生产成本，提高产业效益。",
        "bbox": [
          0.29000242072137494,
          0.3056613353643057,
          0.420721374969741,
          0.3472962680883473
        ],
        "order": 22
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_42",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.429920116194626,
          0.305999830752306,
          0.5533769063180828,
          0.3137852246763138
        ],
        "order": 23
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_40",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者：传统的农情数据采集 费时、费事，不能满足指导生产、 科学研究的需要。现代农业对农 情信息的及时性、准确性、全面 性、科学性都提出了更高的要 求。农情准确获取是农业信息智 能服务的基础和前提，如何获得 精准的农情信息呢?",
        "bbox": [
          0.42749939481965626,
          0.31446221545231445,
          0.5577342047930284,
          0.3804688161123805
        ],
        "order": 24
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_18",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者：信息化已成为我们这 个时代的标志，成为推动经济社 会发展的重要力量。有些专家提 出信息化与农业现代化相融合的 概念，可否理解为二者的融合就 是农业信息智能服务，可否对此 给读者进行一个描述。",
        "bbox": [
          0.01646090534979424,
          0.347973258864348,
          0.1466957153231663,
          0.4058559702124059
        ],
        "order": 25
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_35",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "农业信息智能服务技术应该 包括三个方面，即农情精准获取 技术、数据自动处理技术和信息 推送应用技术。",
        "bbox": [
          0.29097070927136287,
          0.347973258864348,
          0.420721374969741,
          0.38013032072438013
        ],
        "order": 26
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_71",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "会上，包括金融机构、省级学 生资助管理中心等在内的76家 单位被授予全国学生资助工作先 进单位称号；49958名学生获得 2009~2010学年度国家奖学金，每 奖励8000元。",
        "bbox": [
          0.8608085209392399,
          0.348988745028349,
          0.9963689179375453,
          0.39874756706439873
        ],
        "order": 27
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_33",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者：上世纪90年代以来， 信息获取技术、信息处理技术取得 突飞猛进发展，农业信息智能服务 已成为当今世界最具影响力的农业 信息化发展前沿领域。现在提出 的发展农业信息智能服务技术是 不是农业信息化概念上的深化?",
        "bbox": [
          0.29048656499636893,
          0.3811458068883811,
          0.42023723069474705,
          0.439028518236439
        ],
        "order": 28
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_39",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "许世卫：精准地获取农情信 息，可以随时感知农业变化脉搏， 对提高农业信息智能服务水平和 促进现代农业发展步伐都有着重 要的意义。由于过去在农业信息 资源采集、处理和利用过程中，不 同地区、不同部门、不同机构对农 情的采集、定义、描述及应用等大多 自主确定了自己的标准，导致了农 情数据采集不仅浪费了巨大的人 力、物力，而且又人为地造成信息隔 离、数据鸿沟，难以具有可比性，不 能得到有效整合、共享利用。",
        "bbox": [
          0.42701525054466233,
          0.3811458068883811,
          0.5582183490680223,
          0.48946433104848946
        ],
        "order": 29
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_46",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "许世卫：助力现代农业腾飞 是农业信息智能服务的目的和归 宿。现在比较成熟的农业信息推 送应用技术主要包括农业生产适 用技术个性化推送服务，化解基 层用户在海量信息面前“信息迷 向”问题；作物品种优化布局辅助 决策服务，为农业管理部门决策 提供支持；农业信息智能服务技 术平台建设，解决服务渠道问题； 农业基础经济信息快速查询系 统，解决信息查询困难问题等。 农业信息技术、数字农业研究已 经取得了很大成效，一批具有较 高理论意义和实用价值的技术产 品已经研制成功，并且已经开展 了应用示范。",
        "bbox": [
          0.5645122246429436,
          0.3811458068883811,
          0.6957153231663036,
          0.5226368790725227
        ],
        "order": 30
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_14",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "许世卫：当前，随着我国全面 小康社会建设的大力推进，加快 农业发展方式转变，大力推进农 业信息化已经成为当务之急。农 业信息智能服务是农业信息化的 核内容。农业信息智能服务是 利用诸如物联网、云计算技术等 先进信息技术对农业信息进行智 能采集、加工、传播和应用的过 程，是农业领域“信息物化”的过 程，是把“信息”转变为农业生产 力的过程。通过农业信息智能服 务可以有效化解农业在发展中所 遇到的危机。",
        "bbox": [
          0.01597676107480029,
          0.4065329609884065,
          0.14717985959816024,
          0.5226368790725227
        ],
        "order": 31
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_78",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.8617768094892277,
          0.439028518236439,
          0.9987896393125151,
          0.4975882203604976
        ],
        "order": 33
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_31",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "许世卫：农业信息智能服务 技术的提出，并不只是概念上的 变化，它是经济、社会和科技发展 的必然，是一种助推现代农业科 学化发展和兼顾高产、优质、高 效、生态、安全农业综合目标的有 效技术系统。",
        "bbox": [
          0.29000242072137494,
          0.43936701362443936,
          0.420721374969741,
          0.4975882203604976
        ],
        "order": 34
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_57",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "近日，一个全日制中职教学班 在山东省嘉祥县满硐乡南武山村 举行了开学典礼，农民不用花一分 钱，就可以到全日制中职班学习农 业科技和创业技能，三年拿到中专 学历证书，为农民致富和产业转型 奠定了良好基础。",
        "bbox": [
          0.7179859598160252,
          0.43936701362443936,
          0.8559670781893004,
          0.4975882203604976
        ],
        "order": 35
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_27",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者：通过多年的农业信息 科研实践，在我国您首先提出了 农业信息智能服务以及发展农业 信息智能服务技术这个观点。农 业信息智能服务的定义是什么？ 以及农业信息智能服务技术应该 包括哪些方面?",
        "bbox": [
          0.1539578794480755,
          0.4397055090124397,
          0.28467683369644153,
          0.4975882203604976
        ],
        "order": 36
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_38",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "为破解这一难题，中国农业 科学院农业信息研究所制定了农 情信息分类标准和编制各类农情 信息分类代码表。它是针对调查 农情信息的需求，分析国内网络农 业信息资源建设现状和现行的网 络农业信息资源组织方法，引人元 数据与知识组织方法理论，研究 形成了农情信息规范采集标准。",
        "bbox": [
          0.42701525054466233,
          0.49014132182449016,
          0.5577342047930284,
          0.5652872979605653
        ],
        "order": 37
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_60",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "据了解，嘉祥经山东省农广校 批准，今年进行第一次试点，开办了 农业种植、畜牧养殖两个班，招生规 模100人，学制3年。本次中职教育 班的最大特点是进村办班，免学费， 前两年每个学员还可获得每年1500 元生活补助费。这两个教学班利用 南武山小学闲置教室作为教学点，",
        "bbox": [
          0.7184701040910191,
          0.49792671574849795,
          0.8559670781893004,
          0.564948802572565
        ],
        "order": 38
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_26",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "许世卫：农业信息智能服务 是解决当前农业发展危机问题的 重要途径，是适应现代农业发展 的，更高水平、更深层次的农业信 息服务形式。农业信息智能服务 是现代农业发展依靠科技进步的 新需要，必将开辟信息技术服务 于现代农业建设的新天地。",
        "bbox": [
          0.1539578794480755,
          0.49826521113649824,
          0.2841926894214476,
          0.5646103071845646
        ],
        "order": 39
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_34",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "农业信息智能服务是农业信 息化的核心内容，是加快农业生 产方式转变的表现形式，是服务 “三农”的最佳途径。传统的农业 服务模式存在许多不足之处，不 能满足农业生产和消费的需要。 农业信息智能服务具有独特的优 势：互动性、智能性、主动性、即时 性、预见性。",
        "bbox": [
          0.29048656499636893,
          0.49826521113649824,
          0.420721374969741,
          0.5727341964965728
        ],
        "order": 40
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_77",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "据介绍，该村计划今年再发展 大棚50个，两年内发展到200个。 嘉祥也准备在办好今年两个教学 班的基础上，从2011年起，每年在 仲山、万张、老僧堂、黄垓等7个乡 镇至少开办两个教学班，培养具有 种植、养殖专业学历的农村实用人 立足于当地群众种植、养殖大棚多， 有发展特色农业愿望的基础，很快 就完成了招生计划。县农业局投入 8万元改善了教学条件，从县农业 局、畜牧局选聘了12名具有中级职 称以上专家作为代课教师，并制定 了完善的教学管理制度。",
        "bbox": [
          0.8617768094892277,
          0.49826521113649824,
          0.9987896393125151,
          0.5568249132605568
        ],
        "order": 41
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_48",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "但是，不得不承认，农业信息 技术研究成果与应用示范还存在 较大落差：信息的提供者与接收 者不对称，信息服务缺少整体性 和个性化；在浩瀚的信息内容面 前，使用者无从下手；智能化程度 低，农业软件门槛过高和操作复 杂;标准化程度低，信息采集手工 干预过多、信息采集不够及时和 准确等，需要我们在“十二五”期 间，关注和解决这一问题，让农业 信息智能服务技术为我国现代农 业插上腾飞的翅膀。",
        "bbox": [
          0.5645122246429436,
          0.522975374460523,
          0.6957153231663036,
          0.6312938986206313
        ],
        "order": 42
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_17",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者：我国正面临着一个新 的农业发展转折点，机遇与挑战 并存，当前，在发展现代农业中我 们遇到了农业劳动力成本渐高，农 业生产稳定性较差，农业比较效益 不高，农业可持续发展面临挑战等 问题，农业信息智能服务技术可 否化解这些矛盾、走出困境?",
        "bbox": [
          0.01646090534979424,
          0.5233138698485233,
          0.1466957153231663,
          0.5896589658965896
        ],
        "order": 43
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_74",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "才1000。 吕兵兵陈常领",
        "bbox": [
          0.8612926652142339,
          0.5568249132605568,
          0.9832970225127088,
          0.5646103071845646
        ],
        "order": 44
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_25",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "什么是农业信息智能服务? 农业信息智能服务是以农业种 植、养殖、加工、经营过程中各类 事件为服务对象，以基础海量数 据、动态即时数据获取和智能信 息处理系统为核心技术，以分布 式、互动性、主动型、自动化等为 特征的信息服务。其核心是：利",
        "bbox": [
          0.1539578794480755,
          0.564948802572565,
          0.28467683369644153,
          0.6319708893966319
        ],
        "order": 45
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_41",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "另外，针对目前信息内容不 全面，一些重要信息遗漏，难以表 述农产品信息的内涵和实质，在 信息分析时笼统采用平均的方法 等问题，中国农科院农业信息研 究所首次提出了全息农产品信息 的概念，通过完整描述农产品在 相关环节主要显性和隐形信息因 被你咨询，达到为我所用之目的。",
        "bbox": [
          0.42749939481965626,
          0.564948802572565,
          0.5582183490680223,
          0.6316323940086316
        ],
        "order": 46
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_30",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "面对海量的信息，特别是日 益发达的科学技术、瞬息万变的 市场供求，农民的迷茫，农业信息 智能服务的优越性更加凸显，它 可以分层次地区别对待，可以有 针对性地一对一指导，也可以提 供多元化选择，还可以被你选择、",
        "bbox": [
          0.29000242072137494,
          0.5734111872725735,
          0.420721374969741,
          0.6319708893966319
        ],
        "order": 48
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_13",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "许世卫：通过农业信息智能 服务技术，可以简化农业管理程 序，降低劳动强度，提高劳动效 率，减少农业用工数量，提高农业 生产的自动化水平，从而相对解",
        "bbox": [
          0.015008472524812393,
          0.58999746128459,
          0.14621157104817237,
          0.6319708893966319
        ],
        "order": 49
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_76",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "发到小麦种植户手中，让农户们学 会科学浇水；农资部门配齐化肥、 农药，确保物资供应到位；供电公 司对所有技术人员进行了再培训， 并成立17支冬灌服务小分队，对全 县所有IC卡机井箱进行了消缺检 查，及时处理安全隐患800多处。 他们还开辟冬灌业扩绿色通道，配 备20辆抢险车随时待命，确保农民 冬灌用电。 马立涛常新社",
        "bbox": [
          0.8617768094892277,
          0.6028602860286029,
          0.9973372064875333,
          0.6868071422526868
        ],
        "order": 50
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_63",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "连日来，河北省保定市徐水县 采取多种措施加强冬小麦管理，确 保71万亩小麦安全过冬。",
        "bbox": [
          0.7204066811909949,
          0.6035372768046036,
          0.8554829339143064,
          0.6282474401286282
        ],
        "order": 51
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_62",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "该县从农业、教育、科协、乡镇 等部门抽调50多名技术人员组成 14支下乡助农小分队，做好苗情、 墒情、病虫草情调查，掌握生产动 态，并向农民讲解冬小麦管理知 识，解答农民疑问；该县还印发5万 张冬小麦冬灌技术标准明白纸，下",
        "bbox": [
          0.7199225369160009,
          0.6285859355166286,
          0.8569353667392883,
          0.6871456376406871
        ],
        "order": 52
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_20",
        "observed_type": "image_body",
        "canon_role": "picture",
        "text": "",
        "bbox": [
          0.14960058097313,
          0.6465261910806466,
          0.5785524086177681,
          0.826944232884827
        ],
        "order": 53
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_11",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "罕见疾病BH4缺乏症 将有药可医",
        "bbox": [
          0.006293875574921327,
          0.6553270711686553,
          0.1336238198983297,
          0.6976389946686976
        ],
        "order": 54
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_51",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "山东省枣庄市北庄 镇有个“留守童快乐 之家”，这是由该镇7名 大学生村官在2009年11 月共同创办的，每天有2 至3名大学生村官在这 里陪伴留守儿童做一些 有益孩子们健康成长的 活动，让其家长安心在 外务工。图为近日大学 生村官李冰（中）在“留 守儿童快乐之家”教孩 子们剪纸。",
        "bbox": [
          0.5901718712176228,
          0.6593890158246594,
          0.6855482933914306,
          0.7673690445967674
        ],
        "order": 55
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_7",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "本报记者周铮",
        "bbox": [
          0.002420721374969741,
          0.7071168655327071,
          0.1345921084483176,
          0.7155792502327156
        ],
        "order": 57
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_10",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "四氢生物蝶呤(BH₂)缺乏症是 一种遗传性罕见疾病，我国每年 1600万新儿中约有200例罹患 该病，如不及时诊治，会严重损伤 患儿脑组织，出现智力低下、癫痫、 运动功能障碍、肌张力异常、精神 行为异常、肤色变浅、毛发稀黄、湿 疹、身体散发鼠尿味等症状，疾病 给患者和家庭造成无尽的伤害。",
        "bbox": [
          0.0033890099249576375,
          0.7226876533807227,
          0.13798111837327523,
          0.7978336295167978
        ],
        "order": 58
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_56",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "近日，湖北省孝感市汉川脉旺 镇两台大型挖掘机正在疏通一横 渠。这是孝感市今冬明春计划建 设的众多农田水利项目中的一 个。截至12月2日，孝感市已开工 各类水利工程3600多处，完成投资 5亿元，累计完成土石方1600万方， 为发展现代农业打造基础保障。",
        "bbox": [
          0.7179859598160252,
          0.725057121096725,
          0.8554829339143064,
          0.7920792079207921
        ],
        "order": 59
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_79",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "区，重点进行塘堰改造和末级渠系 建设，提高供水保证率。",
        "bbox": [
          0.8632292423142096,
          0.7253956164847254,
          0.9968530622125393,
          0.7416433951087417
        ],
        "order": 60
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_75",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "从今年起，该市计划用3年时 间，筹资15亿元，基本解决小塘堰、 小泵站、小渠道等方面的突出问 题。孝感市整合涉农专项资金用 于农田水利设施建设，每年政策性 资金投入在3亿元以上。在财力紧 张的情况下，市县两级共落实3000 余万元“以奖代补”资金，撬动民间 资本投入8696万元。",
        "bbox": [
          0.8617768094892277,
          0.741981890496742,
          0.9973372064875333,
          0.8167893712448168
        ],
        "order": 61
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_52",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "吉喆项启朵摄",
        "bbox": [
          0.6109900750423626,
          0.7683845307607684,
          0.6768336964415396,
          0.7765084200727765
        ],
        "order": 62
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_53",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "孝感北高南低，易旱易涝。该 市因地制宜，在南部平原湖区重点 进行堤防整治和深沟大渠疏竣，提 高防洪排涝标准；在北部山丘地 号）造型墙对各分主题展区进行区 域分割，互动展品点缀其中。情景 化、艺术化的布展形式与互动式、 参与式的展品相结合，让互动、参 与、体验和直观、形象、易于理解， 成为专题展览的一大亮点。",
        "bbox": [
          0.7175018155410312,
          0.7927561986967927,
          0.8549987896393125,
          0.8255902513328256
        ],
        "order": 63
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_8",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "医学不断进步，目前BH缺乏 症可以通过对新生儿进行疾病筛 查，检出高苯丙氨酸血症（HPA）后 进进一步检查可以确诊。我国 新生儿遗传性疾病研究专家、中华 预防医学会儿童保健分会新生儿 筛查学组副组长、北京大学第一医 院科杨艳玲教授1216向记 者透露，现在我国已经把HPA列 入新生儿筛查疾病，从默克雪兰诺 公司引进的个治疗BH缺乏症 药物科望(Kuvan)已经获得国家 食品药品监督管理局批准，将于明 年在我国医院应用，改变过去我们 对BH缺乏症束手无策的状况，使 该罕见病成为有药可医的病，为患 儿和其父母带来希望。",
        "bbox": [
          0.002904865649963689,
          0.7981721249047982,
          0.1384652626482692,
          0.9406786832529407
        ],
        "order": 64
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_68",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "仅仅是需要公众承担起来的一份 责任，同时也意味着一种新的发展 机会、一种新的生活时尚。”现场一 位参观者如是说。",
        "bbox": [
          0.8588719438392641,
          0.8337141406448337,
          0.9939481965625756,
          0.8668866886688669
        ],
        "order": 66
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_22",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "一件衣物，从其生产、流通、 使用到废弃后的处理，每一个环节 都在排放二氧化碳，一条约400克 的涤纶裤，“一生”所消耗的能源 相当于排放47千克二氧化碳，是 其自重的117倍！“碳”的大量排 放，让极端天气、冰川消融、海平面 上升、动植物灭绝等愈发频繁，人 们也愈来愈清晰而真切地感受到 了由此给人类及生态系统带来的 不利影响。",
        "bbox": [
          0.15153715807310578,
          0.84996191926885,
          0.28661341079641733,
          0.9416941694169417
        ],
        "order": 69
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_69",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "为挖掘和延伸专题展览的教 育功能，中国科技馆在展览期间 还组织了“低碳、我先”系列教 育活动，包括“变废为宝，创意无 限”动制作、“我的低碳生活” 绘画作品征集以及“志愿者讲低 碳”等相关活动，同时组织“科学 讲坛——低碳生活系列讲座”，邀 请相关专家在展览期间进行科普 讲座。",
        "bbox": [
          0.8588719438392641,
          0.8675636794448676,
          0.9944323408375696,
          0.9501565541169501
        ],
        "order": 70
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_36",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "起因、影响和可能的解决方法， 充分认识温室气体减排的重要 性和紧迫性，中国科技馆从12月 15日至2011年6月推出“低碳生 活”专题展览，免费向公众开放， 引导公众改变生活观念，减少二 氧化碳排放，降低全球变暖效应。 地球村的“碳”危机、自然界的 “碳”循环、你和我的“碳”足迹、高 科技的减“碳”术和新生活的低 “碳”路，“低碳生活”专题展览围",
        "bbox": [
          0.2914548535463568,
          0.8993822459168994,
          0.42943597191963206,
          0.9928069730049928
        ],
        "order": 72
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_44",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "绕感受危机、认识低碳、了解低 碳、践行低碳四个方面，设置上述 五个分主题展区，主要展示人类 长期以来高碳发展引发的气候、 生态、能源、资源等种种危机与挑 战，引发人们对高碳发展和生活 方式的重新审视与反思；诠释碳 元素的存在形式和碳元素在自然 界的循环与运动，使人们明确低 碳概念；揭示碳排放、温室效应、 气候变化与每个人日常生活衣食 素，全面、准确描述和定义农产品 时间、空间、内容等相关属性，实 现农产品信息实质和数据表达的 对应。全息农产品信息研究 工作的完成，必将极大地推进我 国农业信息工作的标准化进程， 为农业信息资源的共享利用奠定 基础，是着眼于现代农业发展的 长远考虑。",
        "bbox": [
          0.4337932703945776,
          0.8997207413048998,
          0.5703219559428709,
          0.9928069730049928
        ],
        "order": 73
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_49",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "住行及生活方式的关系；让观念 体验低碳科技的发展与进步，了 解节能减排、绿色低碳技术的大 推将有效地降低类活动碳 排放；从衣食住行各方面感受低 碳生活的新鲜方式，引导人们改 变生活观念，从点滴做起，积极践 低碳生活方式。",
        "bbox": [
          0.5751633986928104,
          0.9000592366929001,
          0.7112079399661099,
          0.9674198189049674
        ],
        "order": 74
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_54",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "",
        "bbox": [
          0.7175018155410312,
          0.9007362274689007,
          0.8516097797143549,
          0.9504950495049505
        ],
        "order": 75
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "据了解，目前国内开展BH缺 乏症的鉴别诊断及治疗的医院主 要有：上海新华医院、中日友好医 院、北京大学第一医院、济南妇幼 保健院、浙江大学儿童医院、州 妇幼保健院、山西儿童医院和西安 童医院等。",
        "bbox": [
          0.002904865649963689,
          0.941017178640941,
          0.1384652626482692,
          0.9992383853769993
        ],
        "order": 76
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_21",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "再来比较一个数据，人类食用 1千克牛肉，所排放的二氧化碳为 36.5千克，而吃同等分量的果蔬后， 所排放的二氧化碳仅为该数值的 1/9……",
        "bbox": [
          0.15105301379811184,
          0.9427096555809427,
          0.28564512224642946,
          0.9833291021409833
        ],
        "order": 77
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_58",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "记者在现场发现，每一位参观 者都兴致勃勃地参与展品的低碳 互动，不时发出种种感概，或惊喜、 或惊讶、或担忧、或乐观，抑或某种 无可言状的态度…“绿色低碳不",
        "bbox": [
          0.7179859598160252,
          0.9515105356689515,
          0.8516097797143549,
          0.9928069730049928
        ],
        "order": 78
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_70",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "现场的一位负责人告诉记者， 北京展出结束后，展览还将在全国 范围内进行巡回展出，以帮助更多 理解低碳概念，让更多在常 生活中参与低碳，保护生态环境。",
        "bbox": [
          0.859840232389252,
          0.9515105356689515,
          0.9939481965625756,
          0.9928069730049928
        ],
        "order": 79
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_50",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "68件动展品，约200块展板， 2300平展出积。展厅以多 组展板构成的“C”形（碳的元素符",
        "bbox": [
          0.5770999757927863,
          0.9677583142929678,
          0.710723795691116,
          0.9928069730049928
        ],
        "order": 80
      },
      {
        "id": "mineru_newspaper_028a1dd5500fbd774e4d85df3c460c4d_1_28",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "为了让公众了解候变化的",
        "bbox": [
          0.16993464052287582,
          0.9843445883049844,

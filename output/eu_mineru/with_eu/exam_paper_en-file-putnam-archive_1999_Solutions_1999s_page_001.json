      {
        "id": "mineru_exam_paper_en-file-putnam-archive_1999_Solutions_1999s_page_001_2",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "A−1 Note that if r(x) and s(x) are any two functions, then",
        "bbox": [
          0.09254901960784313,
          0.16484848484848486,
          0.47372549019607846,
          0.1806060606060606
        ],

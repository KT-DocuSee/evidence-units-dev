  {
    "eu_id": "EU-0007",
    "kind": "text_cluster_panel",
    "page": "exam_paper_en-file-putnam-archive_1999_Solutions_1999s_page_001",
    "primary_id": "mineru_exam_paper_en-file-putnam-archive_1999_Solutions_1999s_page_001_13",

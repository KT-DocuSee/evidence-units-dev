        "id": "mineru_exam_paper_en-file-putnam-archive_2003_Solutions_2003s_page_001_17",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Applying the weighted AM-GM inequality between matching terms in the two sums yields",
        "bbox": [

    "elements": [
      {
        "id": "mineru_jiaocaineedrop_5f9c4ab08cac7457e9111a30e4664920607ea2c115a1433d7be98e97e64244ca.pdf_2_9",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "Has your lab developed any new testing systems or procedures?",
        "bbox": [
          0.34186046511627904,
          0.6089191232048375,
          0.6054263565891473,
          0.6397581254724112
        ],
        "order": 12
      },
      {
        "id": "mineru_jiaocaineedrop_5f9c4ab08cac7457e9111a30e4664920607ea2c115a1433d7be98e97e64244ca.pdf_2_10",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "This past year we established a toxi- cology laboratory designed to evaluate the toxicity of sediments to aquatic",
        "bbox": [
          0.34186046511627904,
          0.6427815570672714,
          0.6007751937984496,
          0.690551776266062
        ],
        "order": 13
      }
    ]
  },
  {
    "eu_id": "EU-0005",
    "kind": "text_cluster_panel",
    "page": "jiaocaineedrop_5f9c4ab08cac7457e9111a30e4664920607ea2c115a1433d7be98e97e64244ca.pdf_2",

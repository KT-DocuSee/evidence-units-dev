  },
  {
    "eu_id": "EU-0003",
    "kind": "section_text_panel",
    "page": "newspaper_5aedf678eff04d8ebac3692d54103e19_1",
    "primary_id": "mineru_newspaper_5aedf678eff04d8ebac3692d54103e19_1_1",
    "source": "header_anchor",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_5aedf678eff04d8ebac3692d54103e19_1_1",
        "observed_type": "title",
        "canon_role": "section_header",

      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2901_24",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "学会原谅和忘记，和他/她谈一谈，说你很 抱歉，告诉他/她你的感受，给他/她写一 张道歉便条",
        "bbox": [
          0.6047516198704104,

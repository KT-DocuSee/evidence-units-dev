          0.8948884089272858,
          0.7461637093105017
        ],
        "order": 24
      },
      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2901_23",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "learn to forgive/fa'grv/ and forget, talk to him/her,say you're sorry, tell him/her your feelings, write him/her a sorry note",

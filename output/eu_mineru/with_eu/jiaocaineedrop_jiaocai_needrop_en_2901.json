      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2901_21",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "我和我最好的朋友吵了一架，我觉得 情绪很低落。我该怎么办?",

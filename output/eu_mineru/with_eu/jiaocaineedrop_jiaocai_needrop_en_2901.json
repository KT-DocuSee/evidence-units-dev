      {
        "id": "mineru_jiaocaineedrop_jiaocai_needrop_en_2901_20",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "I had a quarrel/kworal/ with my best friendandI'm feeling really down. What should I do?",
        "bbox": [
          0.10319174466042716,
          0.615791868304587,
          0.5584353251739861,
          0.6500392935434504

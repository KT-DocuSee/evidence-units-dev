    "source": "header_anchor",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_019d4d5296ba8f1c21277d72fb0cf0db_1_17",
        "observed_type": "title",
        "canon_role": "section_header",
        "text": "我国拟修改刑法严惩“马路杀”",
        "bbox": [
          0.005809731299927378,
          0.3824997884403825,
          0.26676349552166545,
          0.4089024287044089
        ],
        "order": 28
      }
    ]
  },
  {
    "eu_id": "EU-0010",
    "kind": "section_text_panel",
    "page": "newspaper_019d4d5296ba8f1c21277d72fb0cf0db_1",
    "primary_id": "mineru_newspaper_019d4d5296ba8f1c21277d72fb0cf0db_1_18",
    "source": "header_anchor",
    "member_count": 1,
    "elements": [
      {
        "id": "mineru_newspaper_019d4d5296ba8f1c21277d72fb0cf0db_1_18",
        "observed_type": "title",
        "canon_role": "section_header",

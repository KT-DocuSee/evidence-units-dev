      {
        "id": "mineru_newspaper_baa51a22898f0d534a6c404ba8f12fb1_1_3",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "2.Pursuant to 39 U.S.C. 505, the Commission appoints Curtis E. Kidd to serve as an officer of the Commission (Public Representative) to represent the interests of the general public in this proceeding.",
        "bbox": [
          0.07294117647058823,

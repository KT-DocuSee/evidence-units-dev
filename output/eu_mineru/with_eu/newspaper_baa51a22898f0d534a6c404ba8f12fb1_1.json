        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "4. The Secretary shall arrange for publication of this order in the Federal Register.",
        "bbox": [
          0.07215686274509804,
          0.28484848484848485,
          0.33725490196078434,
          0.32242424242424245
        ],
        "order": 16
      },

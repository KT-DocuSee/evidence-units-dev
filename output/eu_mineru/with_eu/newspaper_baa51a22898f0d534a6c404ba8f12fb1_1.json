        "observed_type": "list",
        "canon_role": "support_paragraph",
        "text": "AGENcy: Postal Regulatory Commission. ACTION: Notice.",
        "bbox": [
          0.6509803921568628,
          0.23575757575757575,
          0.9207843137254902,
          0.263030303030303

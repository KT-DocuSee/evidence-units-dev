      {
        "id": "mineru_newspaper_e6083de4647ef28434cb6a598b073ae4_1_24",
        "observed_type": "text",
        "canon_role": "support_paragraph",
        "text": "同志们、朋友们！",
        "bbox": [
          0.8540305010893247,
          0.287044089024287,
          0.9179375453885258,
          0.2944909875602945
        ],
        "order": 15
